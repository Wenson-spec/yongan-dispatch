                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">客户:</span>
                                  <Input className="h-7 text-sm w-24" value={firstOrder.customerName || ""} onChange={(e) => { group.orders.forEach((o: any) => handleFieldEdit(o._idx, "customerName", e.target.value)); }} placeholder="客户名 *" />
                                </div>
                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">货物:</span>
                                  <Input className="h-7 text-sm w-20" value={firstOrder.cargoName || ""} onChange={(e) => { group.orders.forEach((o: any) => handleFieldEdit(o._idx, "cargoName", e.target.value)); }} placeholder="货物名 *" />
                                </div>
                                <span className="text-sm font-bold text-blue-700">{group.totalWeight.toFixed(3)}t</span>
                                <span className="text-xs text-muted-foreground">|</span>
                                <span className="text-xs">{firstOrder.originCity || "-"} → {firstOrder.destinationCity || "-"}</span>
                                <span className="text-xs text-muted-foreground">仓库: {firstOrder.warehouseName || "-"}</span>
                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">报价:</span>
                                  <Input className="h-7 text-sm w-24" placeholder="输入总价分摊"
                                    defaultValue={(() => { const t = group.orders.reduce((s: number, o: any) => s + (parseFloat(o.customerPrice) || 0), 0); return t > 0 ? t.toFixed(2) : ""; })()}
                                    onBlur={(e) => {
                                      const totalPrice = parseFloat(e.target.value);
                                      if (!totalPrice || totalPrice <= 0) return;
                                      const totalWeight = group.orders.reduce((s: number, o: any) => s + (parseFloat(o.weight) || 0), 0);
                                      if (totalWeight <= 0) {
                                        const avg = (totalPrice / group.orders.length).toFixed(2);
                                        group.orders.forEach((o: any, i: number) => {
                                          handleFieldEdit(o._idx, "customerPrice", i === group.orders.length - 1 ? (totalPrice - parseFloat(avg) * (group.orders.length - 1)).toFixed(2) : avg);
                                        });
                                      } else {
                                        let allocated = 0;
                                        group.orders.forEach((o: any, i: number) => {
                                          const w = parseFloat(o.weight) || 0;
                                          if (i === group.orders.length - 1) { handleFieldEdit(o._idx, "customerPrice", (totalPrice - allocated).toFixed(2)); }
                                          else { const share = Math.round(totalPrice * (w / totalWeight) * 100) / 100; allocated += share; handleFieldEdit(o._idx, "customerPrice", share.toFixed(2)); }
                                        });
                                      }
                                      toast.success(`已按吨位分摊运费收入 ¥${totalPrice.toFixed(2)} 到 ${group.orders.length} 个子订单`);
                                    }}
                                  />
                                </div>
                              </div>
                              {/* 大板标记 - 右上角 */}
                              {group.orders.some((o: any) => o.isLargeSlab || detectLargeSlab(o.cargoName, o.shippingNote || '', o.remarks).isLargeSlab) && (
                                <Badge className="text-[10px] bg-purple-600 absolute top-2 right-2">大板</Badge>
                              )}
                              {/* 第二行：地址、备注、发货备注 */}
                              <div className="flex items-start gap-3 flex-wrap mt-2 pl-9">
                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">地址:</span>
                                  <span className="text-xs">{firstOrder.deliveryAddress || "-"}</span>
                                </div>
                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">收货人:</span>
                                  <span className="text-xs">{firstOrder.receiverName || "-"}</span>
                                </div>
                                <div className="flex items-center gap-1">
                                  <span className="text-xs text-muted-foreground">电话:</span>
                                  <span className="text-xs">{firstOrder.receiverPhone || "-"}</span>
                                </div>
                                <span className="text-xs text-muted-foreground">|</span>
                                <div className="flex items-center gap-1 flex-1 min-w-[200px]">
                                  <span className="text-xs text-muted-foreground whitespace-nowrap">备注:</span>
                                  <Input className="h-7 text-xs flex-1" value={parentRemarks || ""} onChange={(e) => setParentRemarks(e.target.value)} placeholder="备注" />
                                </div>
                                <div className="flex items-center gap-1 flex-1 min-w-[250px]">
                                  <span className="text-xs text-muted-foreground whitespace-nowrap">发货备注:</span>
                                  <Input className="h-7 text-xs flex-1 bg-yellow-50 border-yellow-300" value={(firstOrder as any).shippingNote || ""} onChange={(e) => { group.orders.forEach((o: any) => handleFieldEdit(o._idx, "shippingNote", e.target.value)); }} placeholder="规格、托数等发货注意事项" />
                                </div>
                              </div>
                            </div>
                            {/* 子运单行 */}
                            {isExpanded && group.orders.map((order) => {
                              const idx = (order as any)._idx;
                              const det = order.isLargeSlab ? { isLargeSlab: true, detectedKeywords: [], detectedSpecs: [] } : detectLargeSlab(order.cargoName, order.shippingNote || '', order.remarks);
                              return (
                                <div key={order._uid} className={`border-t px-3 py-2 relative ${det.isLargeSlab ? "bg-purple-50/50" : "bg-blue-50/30"}`}>
                                  {/* 子订单第一行 */}
                                  <div className="flex items-center gap-2 flex-wrap">
                                    <span className="text-xs text-muted-foreground w-8 pl-4">└ {idx + 1}</span>
                                    <span className="text-[10px] text-muted-foreground">{BUSINESS_TYPE_LABELS[businessTypes[idx] || "outsource"]}</span>
                                    <Input className={`h-7 text-sm w-32 ${CONFIDENCE_COLORS[order.confidence?.orderNumber || "high"]}`} value={order.orderNumber} onChange={(e) => handleFieldEdit(idx, "orderNumber", e.target.value)} />
                                    <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.customerName || "high"]}`} value={order.customerName} onChange={(e) => handleFieldEdit(idx, "customerName", e.target.value)} />
                                    <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.cargoName || "high"]}`} value={order.cargoName} onChange={(e) => handleFieldEdit(idx, "cargoName", e.target.value)} />
                                    <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.weight || "high"]}`} value={order.weight} onChange={(e) => handleFieldEdit(idx, "weight", e.target.value)} />
                                    <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.originCity || "high"]}`} value={order.originCity} onChange={(e) => handleFieldEdit(idx, "originCity", e.target.value)} />
                                    <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.warehouseName || "high"]}`} value={order.warehouseName || ""} onChange={(e) => handleFieldEdit(idx, "warehouseName", e.target.value)} placeholder="仓库" />
                                    <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.destinationCity || "high"]}`} value={order.destinationCity} onChange={(e) => handleFieldEdit(idx, "destinationCity", e.target.value)} />
                                    <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.customerPrice || "high"]}`} value={order.customerPrice || ""} onChange={(e) => handleFieldEdit(idx, "customerPrice", e.target.value)} placeholder="元" />
                                  </div>
                                  {/* 大板+删除 - 右上角 */}
                                  <div className="absolute top-2 right-2 flex items-center gap-1">
                                    {det.isLargeSlab && <Badge className="text-[10px] bg-purple-600">大板</Badge>}
                                    <Button variant="ghost" size="sm" className="h-6 w-6 p-0 text-red-500 hover:bg-red-50" onClick={() => setPendingRemoveUid(order._uid)}><Trash2 className="h-3 w-3" /></Button>
                                  </div>
                                  {/* 子订单第二行 */}
                                  <div className="flex items-center gap-2 flex-wrap mt-1 pl-12">
                                    <Input className={`h-7 text-xs flex-1 min-w-[150px] ${CONFIDENCE_COLORS[order.confidence?.deliveryAddress || "high"]}`} value={order.deliveryAddress || ""} onChange={(e) => handleFieldEdit(idx, "deliveryAddress", e.target.value)} placeholder="详细地址" />
                                    <Input className={`h-7 text-xs w-20 ${CONFIDENCE_COLORS[order.confidence?.receiverName || "high"]}`} value={order.receiverName || ""} onChange={(e) => handleFieldEdit(idx, "receiverName", e.target.value)} placeholder="收货人" />
                                    <Input className={`h-7 text-xs w-28 ${CONFIDENCE_COLORS[order.confidence?.receiverPhone || "high"]}`} value={order.receiverPhone || ""} onChange={(e) => handleFieldEdit(idx, "receiverPhone", e.target.value)} placeholder="电话" />
                                    <Input className={`h-7 text-xs flex-1 min-w-[120px] ${CONFIDENCE_COLORS[order.confidence?.remarks || "high"]}`} value={order.remarks || ""} onChange={(e) => handleFieldEdit(idx, "remarks", e.target.value)} placeholder="备注" />
                                    <Input className="h-7 text-xs flex-1 min-w-[150px] bg-yellow-50 border-yellow-300" value={(order as any).shippingNote || ""} onChange={(e) => handleFieldEdit(idx, "shippingNote", e.target.value)} placeholder="发货备注" />
                                  </div>
                                </div>
                              );
                            })}
                          </div>
                        );
                      }

                      // 单独订单卡片 - 两行布局
                      const order = group.orders[0];
                      const idx = (order as any)._idx;
                      const det = order.isLargeSlab ? { isLargeSlab: true, detectedKeywords: [], detectedSpecs: [] } : detectLargeSlab(order.cargoName, order.shippingNote || '', order.remarks);
                      return (
                        <div key={order._uid} className={`border rounded-lg p-3 relative ${det.isLargeSlab ? "bg-purple-50/50 border-purple-200" : ""}`}>
                          {/* 第一行：基础信息 */}
                          <div className="flex items-center gap-2 flex-wrap">
                            <span className="text-xs text-muted-foreground w-6">{idx + 1}</span>
                            <Select value={businessTypes[idx] || "outsource"} onValueChange={(v) => { setBusinessTypes((prev) => { const u = [...prev]; u[idx] = v; return u; }); }}>
                              <SelectTrigger className="h-7 text-sm w-20"><SelectValue /></SelectTrigger>
                              <SelectContent>
                                {Object.entries(BUSINESS_TYPE_LABELS).map(([k, v]) => (<SelectItem key={k} value={k}>{v}</SelectItem>))}
                              </SelectContent>
                            </Select>
                            <Input className={`h-7 text-sm w-32 ${CONFIDENCE_COLORS[order.confidence?.orderNumber || "high"]}`} value={order.orderNumber} onChange={(e) => handleFieldEdit(idx, "orderNumber", e.target.value)} />
                            <Input className={`h-7 text-sm w-28 ${CONFIDENCE_COLORS[order.confidence?.mergedPlanNumber || "high"]}`} value={order.mergedPlanNumber || ""} onChange={(e) => handleFieldEdit(idx, "mergedPlanNumber", e.target.value)} placeholder="合并计划号" />
                            <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.customerName || "high"]}`} value={order.customerName} onChange={(e) => handleFieldEdit(idx, "customerName", e.target.value)} placeholder="客户 *" />
                            <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.cargoName || "high"]}`} value={order.cargoName} onChange={(e) => handleFieldEdit(idx, "cargoName", e.target.value)} placeholder="货物 *" />
                            <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.weight || "high"]}`} value={order.weight} onChange={(e) => handleFieldEdit(idx, "weight", e.target.value)} />
                            <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.originCity || "high"]}`} value={order.originCity} onChange={(e) => handleFieldEdit(idx, "originCity", e.target.value)} />
                            <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.warehouseName || "high"]}`} value={order.warehouseName || ""} onChange={(e) => handleFieldEdit(idx, "warehouseName", e.target.value)} placeholder="仓库" />
                            <Input className={`h-7 text-sm w-20 ${CONFIDENCE_COLORS[order.confidence?.destinationCity || "high"]}`} value={order.destinationCity} onChange={(e) => handleFieldEdit(idx, "destinationCity", e.target.value)} />
                            <Input className={`h-7 text-sm w-24 ${CONFIDENCE_COLORS[order.confidence?.customerPrice || "high"]}`} value={order.customerPrice || ""} onChange={(e) => handleFieldEdit(idx, "customerPrice", e.target.value)} placeholder="元" />
                          </div>
                          {/* 大板+删除 - 右上角 */}
                          <div className="absolute top-2 right-2 flex items-center gap-1">
                            {det.isLargeSlab && <Badge className="text-[10px] bg-purple-600">大板</Badge>}
                            <Button variant="ghost" size="sm" className="h-6 w-6 p-0 text-red-500 hover:bg-red-50" onClick={() => setPendingRemoveUid(order._uid)}><Trash2 className="h-3 w-3" /></Button>
                          </div>
                          {/* 第二行：地址、备注、发货备注 */}
                          <div className="flex items-center gap-2 flex-wrap mt-2 pl-8">
                            <Input className={`h-7 text-xs flex-1 min-w-[150px] ${CONFIDENCE_COLORS[order.confidence?.deliveryAddress || "high"]}`} value={order.deliveryAddress || ""} onChange={(e) => handleFieldEdit(idx, "deliveryAddress", e.target.value)} placeholder="详细地址" />
                            <Input className={`h-7 text-xs w-20 ${CONFIDENCE_COLORS[order.confidence?.receiverName || "high"]}`} value={order.receiverName || ""} onChange={(e) => handleFieldEdit(idx, "receiverName", e.target.value)} placeholder="收货人" />
                            <Input className={`h-7 text-xs w-28 ${CONFIDENCE_COLORS[order.confidence?.receiverPhone || "high"]}`} value={order.receiverPhone || ""} onChange={(e) => handleFieldEdit(idx, "receiverPhone", e.target.value)} placeholder="电话" />
                            <Input className={`h-7 text-xs flex-1 min-w-[120px] ${CONFIDENCE_COLORS[order.confidence?.remarks || "high"]}`} value={order.remarks || ""} onChange={(e) => handleFieldEdit(idx, "remarks", e.target.value)} placeholder="备注" />
                            <Input className="h-7 text-xs flex-1 min-w-[150px] bg-yellow-50 border-yellow-300" value={(order as any).shippingNote || ""} onChange={(e) => handleFieldEdit(idx, "shippingNote", e.target.value)} placeholder="发货备注（规格、托数等）" />
                          </div>
                        </div>
                      );
                    })}
                  </div>

                  <div className="flex items-center justify-between mt-4">
                    <span className="text-sm text-muted-foreground">
                      请检查识别结果，修正黄色/橙色高亮字段后提交
                    </span>
                    <Button
                      onClick={handleBatchSubmitClick}
                      disabled={isSubmitting || submitted || parsedOrders.length === 0}
                    >
                      {isSubmitting ? (
                        <Loader2 className="h-4 w-4 mr-1 animate-spin" />
                      ) : submitted ? (
                        <Check className="h-4 w-4 mr-1" />
                      ) : (
                        <Save className="h-4 w-4 mr-1" />
                      )}
                      {isSubmitting ? "提交中..." : submitted ? "已提交" : `批量创建 ${parsedOrders.length} 条订单`}
                    </Button>
                  </div>
                </CardContent>
              </Card>
              </>
            )}
          </TabsContent>
        </Tabs>
      </div>

      {/* 大板强制确认弹窗 */}
      <Dialog open={largeSlabDialog} onOpenChange={setLargeSlabDialog}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2 text-purple-700">
              <Package className="h-5 w-5" />
              检测到大板货物
            </DialogTitle>
            <DialogDescription>
              系统检测到该订单可能为大板货物，请确认：
            </DialogDescription>
          </DialogHeader>
          <div className="space-y-3 py-2">
            {largeSlabDetection.keywords.length > 0 && (
              <div className="flex items-center gap-2">
                <span className="text-sm text-muted-foreground">检测到关键词：</span>
                {largeSlabDetection.keywords.map((kw, i) => (
                  <Badge key={i} className="bg-purple-100 text-purple-700">{kw}</Badge>
                ))}
              </div>
            )}
            {largeSlabDetection.specs.length > 0 && (
              <div className="flex items-center gap-2">
                <span className="text-sm text-muted-foreground">检测到大板规格：</span>
                {largeSlabDetection.specs.map((spec, i) => (
                  <Badge key={i} className="bg-orange-100 text-orange-700">{spec}</Badge>
                ))}
              </div>
            )}
            <div className="bg-purple-50 border border-purple-200 rounded-lg p-3 text-sm">
              <p className="font-medium text-purple-800 mb-1">大板订单需要额外信息：</p>
              <ul className="text-purple-700 space-y-1 text-xs">
                <li>• 整车大板：需填写<strong>计费重量</strong>（客户给的包车重量，如32吨）</li>
                <li>• 零担大板：需填写<strong>架数</strong>（如3架）</li>
              </ul>
            </div>
          </div>
          <DialogFooter className="gap-2">
            <Button variant="outline" onClick={handleDenyLargeSlab}>
              不是大板，直接提交
            </Button>
            <Button className="bg-purple-600 hover:bg-purple-700" onClick={handleConfirmLargeSlab}>
              <Package className="h-4 w-4 mr-1" />
              确认是大板
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 加急确认弹窗 - 提交前强制确认 */}
      <AlertDialog open={pendingRemoveUid !== null} onOpenChange={(open) => { if (!open) setPendingRemoveUid(null); }}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>确认删除该条录单内容？</AlertDialogTitle>
            <AlertDialogDescription>
              删除后该条智能粘贴识别结果将从当前提交列表移除，且不会自动恢复。请确认该行不再需要后再继续。
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel onClick={() => setPendingRemoveUid(null)}>取消</AlertDialogCancel>
            <AlertDialogAction
              onClick={() => {
                if (pendingRemoveUid) {
                  handleRemoveOrder(pendingRemoveUid);
                }
              }}
            >
              确认删除
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>

      <AlertDialog open={urgentConfirmOpen} onOpenChange={setUrgentConfirmOpen}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle className="flex items-center gap-2 text-lg">
              <AlertTriangle className="h-5 w-5 text-amber-600" />
              提交前确认
            </AlertDialogTitle>
            <AlertDialogDescription asChild>
              <div className="space-y-3">
                <p className="text-base font-medium text-gray-900">
                  请确认本批 {parsedOrders.length} 条订单的加急状态：
                </p>
                {parsedOrders.some(o => o.isUrgent) ? (
                  <div className="bg-red-50 border border-red-200 rounded-lg p-3">
                    <div className="flex items-center gap-2 mb-1">
                      <Badge variant="destructive" className="animate-pulse">加急</Badge>
                      <span className="font-medium text-red-800">本批订单已标记为加急</span>
                    </div>
                    <p className="text-sm text-red-700">加急理由：{parsedOrders[0]?.urgentReason || "未填写"}</p>
                  </div>
                ) : (
                  <div className="bg-green-50 border border-green-200 rounded-lg p-3">
                    <div className="flex items-center gap-2">
                      <Badge variant="outline" className="bg-green-100 text-green-700 border-green-300">普通</Badge>
                      <span className="font-medium text-green-800">本批订单为普通订单（非加急）</span>
                    </div>
                  </div>
                )}
                <p className="text-sm text-muted-foreground">如需修改加急状态，请点击“返回修改”</p>
              </div>
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>返回修改</AlertDialogCancel>
            <AlertDialogAction onClick={() => { setUrgentConfirmOpen(false); handleBatchSubmit(); }}>
              确认提交
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </DashboardLayout>
  );
}
