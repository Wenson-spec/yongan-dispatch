const POD_STATUS_LABELS: Record<string, string> = {
  none: "未处理",
  uploaded: "已上传",
  verified: "已核验",
  original_sent: "原件已寄出",
  original_received: "已收原件",
};

const getOrderPodOwnership = (order: any) => order?.podRecordOwnership || order?.podOwnership || null;

const getOrderPodBusinessStatus = (order: any) => order?.podEffectiveStatus || "none";

const getOrderPodOriginalStatus = (order: any) => order?.podOriginalStatus || null;

const getOrderPodSentAt = (order: any) => order?.podOriginalSentAt || null;

const isCurrentOrderPodOwner = (order: any) => getOrderPodOwnership(order) === "current_order";

const hasPodBeenSent = (order: any) => {
  const originalStatus = getOrderPodOriginalStatus(order);
  const businessStatus = getOrderPodBusinessStatus(order);
  return originalStatus === "sent"
    || originalStatus === "received"
    || businessStatus === "original_sent"
    || businessStatus === "original_received";
};

const isAwaitingPodOriginalSend = (order: any) => !hasPodBeenSent(order);

const canMarkPodAsSent = (order: any) => {
  const businessStatus = getOrderPodBusinessStatus(order);
  const originalStatus = getOrderPodOriginalStatus(order);
  return isCurrentOrderPodOwner(order)
    && originalStatus !== "sent"
    && originalStatus !== "received"
    && (businessStatus === "none" || businessStatus === "uploaded");
};

const canCancelPodSent = (order: any) => getOrderPodOriginalStatus(order) === "sent" && isCurrentOrderPodOwner(order);

const getPodStatusToneClass = (status: string) => (
  status === "original_sent" ? "bg-blue-100 text-blue-700" :
  status === "original_received" ? "bg-green-100 text-green-700" :
  status === "uploaded" ? "bg-amber-100 text-amber-700" :
  "bg-gray-100 text-gray-700"
);

type DangerActionMenuProps = {
  onRollback?: () => void;
  rollbackDisabled?: boolean;
  rollbackLabel?: string;
  onDelete?: () => void;
  deleteDisabled?: boolean;
  deleteLabel?: string;
  triggerLabel?: string;
  triggerClassName?: string;
};

const DangerActionMenu = ({
  onRollback,
  rollbackDisabled = false,
  rollbackLabel = "退回上一步",
  onDelete,
  deleteDisabled = false,
  deleteLabel = "删除订单",
  triggerLabel,
  triggerClassName,
}: DangerActionMenuProps) => {
  if (!onRollback && !onDelete) {
    return null;
  }

  return (
    <DropdownMenu>
      <DropdownMenuTrigger asChild>
        <Button
          size="sm"
          variant="ghost"
          className={triggerClassName || (triggerLabel
            ? "h-8 px-2 text-orange-600 border border-orange-300 hover:bg-orange-50 hover:text-orange-700"
            : "h-7 w-7 p-0 text-muted-foreground hover:text-foreground")}
        >
          <MoreHorizontal className={triggerLabel ? "h-4 w-4 mr-1" : "h-3.5 w-3.5"} />
          {triggerLabel || null}
        </Button>
      </DropdownMenuTrigger>
      <DropdownMenuContent align="end">
        {onRollback && (
          <DropdownMenuItem onClick={onRollback} disabled={rollbackDisabled}>
            <Undo2 className="mr-2 h-3.5 w-3.5 text-orange-600" />
            {rollbackLabel}
          </DropdownMenuItem>
        )}
        {onDelete && (
          <DropdownMenuItem onClick={onDelete} disabled={deleteDisabled}>
            <Trash2 className="mr-2 h-3.5 w-3.5 text-red-600" />
            {deleteLabel}
          </DropdownMenuItem>
        )}
      </DropdownMenuContent>
    </DropdownMenu>
  );
};

const formatPodSentDate = (order: any) => {
  const sentAt = getOrderPodSentAt(order);
  return sentAt ? new Date(sentAt).toLocaleDateString("zh-CN") : "-";
};

const getPodTrackingPendingCount = (orders: any[]) => orders.filter(isAwaitingPodOriginalSend).length;

const getPodSentProgressCount = (orders: any[]) => orders.filter(hasPodBeenSent).length;
;
const getVisibleDispatchGroup = (order: any) =>
  order?.dispatchRecordLabel ||
  order?.dispatchGroupLabel ||
  order?.dispatchRecordNumber ||
  order?.dispatchRecordCode ||
  order?.mergedPlanNumber ||
  null;

const getVehicleTripLabel = (order: any) =>
  [order?.plateNumber, order?.driverName].filter(Boolean).join(" / ") || "待补车次信息";

const getDispatchHeadline = (order: any) => {
  // 优先显示F/P订单号：customerOrderNumber（F开头）或mergedPlanNumber（P开头）
  if (order?.customerOrderNumber) return order.customerOrderNumber;
  if (order?.mergedPlanNumber) return order.mergedPlanNumber;
  const dispatchGroup = getVisibleDispatchGroup(order);
  return dispatchGroup ? `正式外请分组：${dispatchGroup}` : `同车次：${getVehicleTripLabel(order)}`;
};

const getDispatchSubline = (order: any) => {
  const dispatchGroup = getVisibleDispatchGroup(order);
  if (dispatchGroup) {
    return order?.mergedPlanNumber && dispatchGroup !== order?.mergedPlanNumber
      ? `参考批次：${order.mergedPlanNumber} · 当前页面优先按正式外请分组展示。`
      : "当前页面优先按正式外请分组展示。";
  }
  return `当前未形成正式外请分组，回退按同车次展示：${getVehicleTripLabel(order)}`;
};

const getTripSupportLine = (order: any) => {
  const trip = getVehicleTripLabel(order);
  return trip === "待补车次信息" ? "请先补齐车辆与司机信息后再继续整组操作。" : `当前车次：${trip}`;
};

const getDispatchGroupKey = (order: any) => {
  const dispatchGroup = getVisibleDispatchGroup(order);
  if (dispatchGroup) return `dispatch_${dispatchGroup}`;
  if (order?.plateNumber && order?.dispatchDate) {
    const dateStr = new Date(order.dispatchDate).toISOString().slice(0, 10);
    return `trip_${order.plateNumber}_${dateStr}`;
  }
  return `single_${order?.id ?? order?.orderNumber ?? "unknown"}`;
};

const getLatestReturnReason = (order: any) => {
  const rawReason = order?.lastReturnReason || order?.lastReturnDescription || "";
  const normalizedReason = typeof rawReason === "string" ? rawReason.trim() : "";
  return normalizedReason || null;
};

const getLatestReturnMeta = (order: any) => {
  const metaParts = [
    order?.lastReturnBy ? `审批人：${order.lastReturnBy}` : null,
    order?.lastReturnAt ? `时间：${fmtShort(order.lastReturnAt)}` : null,
  ].filter(Boolean);
  return metaParts.join(" · ");
};

type ApprovalRiskBadge = {
  label: string;
  className: string;
};

function parseApprovalReasonText(reasonText?: string | null) {
  const normalized = reasonText?.trim() ?? "";
  if (!normalized) {
    return { mainReason: "", remarkPart: "" };
  }
  const hasRemark = normalized.includes("备注：");
  return {
    mainReason: hasRemark ? normalized.split("备注：")[0].trim() : normalized,
    remarkPart: hasRemark ? normalized.split("备注：")[1]?.trim() ?? "" : "",
  };
}

function getApprovalDeltaTone(priceDelta: number | null, deltaRate: number | null) {
  if (priceDelta === null) return "border-slate-200 bg-slate-50 text-slate-600";
  if (priceDelta > 0 || (deltaRate !== null && deltaRate > 0)) {
    return deltaRate !== null && deltaRate >= 10
      ? "border-red-200 bg-red-50 text-red-700"
      : "border-amber-200 bg-amber-50 text-amber-700";
  }
  if (priceDelta < 0) return "border-emerald-200 bg-emerald-50 text-emerald-700";
  return "border-slate-200 bg-slate-50 text-slate-600";
}

function getApprovalRiskBadges(item: any): ApprovalRiskBadge[] {
  const combinedText = `${item.reason ?? ""} ${item.remarks ?? ""}`;
  const badges: ApprovalRiskBadge[] = [];

  if (item.isUrgent) {
    badges.push({ label: "加急", className: "border-red-200 bg-red-50 text-red-700" });
  }

  if (/押金|到付|现金|垫付|预付/.test(combinedText)) {
    badges.push({ label: "特殊费用", className: "border-amber-200 bg-amber-50 text-amber-700" });
  }

  return badges;
}

function ApprovalDecisionBadges({ items }: { items: any[] }) {
  const badges = items.reduce<ApprovalRiskBadge[]>((acc, currentItem) => {
    getApprovalRiskBadges(currentItem).forEach((badge) => {
      if (!acc.some((existing) => existing.label === badge.label)) {
        acc.push(badge);
      }
    });
    return acc;
  }, []);
  const receivingSummary = summarizeApprovalTextList(
    items.map((currentItem) => getApprovalReceivingSummary(currentItem)),
  );

  if (badges.length === 0 && !receivingSummary) {
    return <span className="text-xs text-muted-foreground">常规审批</span>;
  }

  return (
    <div className="space-y-2">
      {badges.length > 0 ? (
        <div className="flex flex-wrap gap-1">
          {badges.map((badge) => (
            <Badge key={badge.label} variant="outline" className={`text-[10px] ${badge.className}`}>
              {badge.label}
            </Badge>
          ))}
        </div>
      ) : (
        <span className="text-xs text-muted-foreground">常规审批</span>
      )}
      {receivingSummary ? (
        <div className="rounded-md border border-orange-200 bg-orange-50 px-2.5 py-2 text-[11px] leading-5 text-orange-900">
          <div className="text-[10px] font-medium text-orange-700">收货备注</div>
          <div className="mt-1 break-words text-wrap-safe">{receivingSummary}</div>
        </div>
      ) : null}
    </div>
  );
}

function sanitizeApprovalSummaryText(value?: string | null) {
  if (typeof value !== "string") {
    return "";
  }
  return value
    .split(/[；;]+/)
    .map((part) => part.trim())
    .filter((part) => part && !/^总吨位[:：]/.test(part) && !/^总重量[:：]/.test(part))
    .join("；");
}

function getApprovalSummaryTexts(values: Array<string | null | undefined>) {
  return Array.from(
    new Set(
      values
        .map((value) => sanitizeApprovalSummaryText(value))
        .filter(Boolean),
    ),
  );
}

function summarizeApprovalTextList(values: Array<string | null | undefined>) {
  const texts = getApprovalSummaryTexts(values);
  if (texts.length === 0) {
    return "";
  }
  if (texts.length === 1) {
    return texts[0];
  }
  if (texts.length === 2) {
    return texts.join("；");
  }
  return `${texts.slice(0, 2).join("；")}；另有${texts.length - 2}条补充说明`;
}

function getApprovalReceivingSummary(item: any) {
  const directNote = sanitizeApprovalSummaryText(item?.receivingNote);
  if (directNote) {
    return directNote;
  }

  const expectedReceiveText = item?.expectedReceiveAt
    ? `预计收货 ${fmtDate(item.expectedReceiveAt)}`
    : "";
  const nextFollowUpText = item?.nextFollowUpAt
    ? `下次跟进 ${fmtDate(item.nextFollowUpAt)}`
    : "";
  const reasonText = sanitizeApprovalSummaryText(item?.receivingReason);

  if (item?.receivingStatus === "wait_notice") {
    return ["等通知", expectedReceiveText, nextFollowUpText, reasonText].filter(Boolean).join("；");
  }
  if (item?.receivingStatus === "not_receivable") {
    return ["暂不收货", reasonText, nextFollowUpText, expectedReceiveText].filter(Boolean).join("；");
  }
  if (item?.receivingStatus === "receivable") {
    return ["可收货", expectedReceiveText, reasonText].filter(Boolean).join("；");
  }

  return [reasonText, expectedReceiveText, nextFollowUpText].filter(Boolean).join("；");
}

function getApprovalGroupReasonSummary(items: any[]) {
  return summarizeApprovalTextList(
    items.map((currentItem) => parseApprovalReasonText(currentItem.reason).mainReason),
  );
}

function getApprovalGroupRemarkSummary(items: any[]) {
  return summarizeApprovalTextList(
    items.flatMap((currentItem) => {
      const parsed = parseApprovalReasonText(currentItem.reason);
      return [parsed.remarkPart, currentItem.remarks];
    }),
  );
}

function getApprovalGroupSpecialFlagSummary(items: any[]) {
  const flags: string[] = [];
  if (items.some((currentItem) => currentItem.isUrgent)) {
    flags.push("含加急单");
  }
  if (items.some((currentItem) => /押金|到付|现金|垫付|预付/.test(`${currentItem.reason ?? ""} ${currentItem.remarks ?? ""}`))) {
    flags.push("含特殊费用说明");
  }
  return flags.join("；");
}

function getApprovalGroupPreviousStatusSummary(items: any[]) {
  return getApprovalSummaryTexts(
    items.map((currentItem) =>
      currentItem.previousStatus ? getOrderStatusLabel(currentItem.previousStatus) || currentItem.previousStatus : "",
    ),
  ).join(" / ");
}

function getApprovalGroupDecisionSummary(items: any[]) {
  const groupPriceSnapshot = getApprovalGroupPriceSnapshot(items);
  const requestedText = groupPriceSnapshot.requestedPrice !== null
    ? `整组申请总额 ${formatMoney(String(groupPriceSnapshot.requestedPrice))}`
    : "整组申请总额待确认";

  if (
    groupPriceSnapshot.originalPrice === null
    || groupPriceSnapshot.requestedPrice === null
    || groupPriceSnapshot.priceDelta === null
  ) {
    return `按组合订单整组价格决策；${requestedText}`;
  }

  const baselineText = `整组基准 ${formatMoney(String(groupPriceSnapshot.originalPrice))}`;
  if (groupPriceSnapshot.priceDelta === 0) {
    return `按组合订单整组价格决策；${requestedText}；${baselineText}；与整组基准持平`;
  }

  const deltaDirection = groupPriceSnapshot.priceDelta > 0 ? "上浮" : "回落";
  const deltaAmount = formatMoney(String(Math.abs(groupPriceSnapshot.priceDelta)));
  const deltaRate = groupPriceSnapshot.deltaRate !== null
    ? `（${groupPriceSnapshot.priceDelta > 0 ? "+" : "-"}${Math.abs(groupPriceSnapshot.deltaRate)}%）`
    : "";

  return `按组合订单整组价格决策；${requestedText}；${baselineText}；较整组基准${deltaDirection} ${deltaAmount}${deltaRate}`;
}

function getApprovalGroupPriceSnapshot(items: any[]) {
  return getSharedApprovalGroupPriceSnapshot(items);
}

function getApprovalIncomeFreightValue(items: any[]) {
  return Number(
    items.reduce((sum, currentItem) => {
      const customerPrice = parseFloat(String(currentItem.customerPrice ?? ""));
      if (Number.isFinite(customerPrice) && customerPrice > 0) {
        return sum + customerPrice;
      }
      const quotedPrice = parseFloat(String(currentItem.quotedPrice ?? ""));
      return sum + (Number.isFinite(quotedPrice) && quotedPrice > 0 ? quotedPrice : 0);
    }, 0).toFixed(2),
  );
}

function ApprovalSummaryContent({
  item,
  itemOrderId,
  items,
}: {
  item: any;
  itemOrderId: number;
  items?: any[];
}) {
  const summarySourceItems = items?.length ? items : [item].filter(Boolean);
  const referenceItem = summarySourceItems[0] ?? item ?? {};
  const isGroupSummary = summarySourceItems.length > 1;
  const approvalTypeLabel = isGroupSummary ? getApprovalTypeSummary(summarySourceItems) : getApprovalTypeLabel(referenceItem?.approvalType);
  const totalWeightValue = Number(
    summarySourceItems.reduce((sum, currentItem) => sum + (parseFloat(String(currentItem.weight ?? currentItem.loadingWeight ?? 0)) || 0), 0).toFixed(3),
  );

  const deliveryAddress = [referenceItem.deliveryAddress, referenceItem.receivingAddress, referenceItem.destinationAddress, referenceItem.unloadingAddress]
    .find((value) => typeof value === "string" && value.trim()) as string | undefined;
  const customerName = isGroupSummary
    ? Array.from(new Set(summarySourceItems.map((currentItem) => currentItem.customerName).filter(Boolean))).join("、") || "-"
    : referenceItem.customerName || "-";
  const cargoName = isGroupSummary
    ? Array.from(new Set(summarySourceItems.map((currentItem) => currentItem.cargoName || currentItem.productName).filter(Boolean))).join("、") || "-"
    : referenceItem.cargoName || referenceItem.productName || "-";
  const warehouseName = referenceItem.warehouseName || referenceItem.originCity || "-";
  const receivingNote = summarizeApprovalTextList(
    summarySourceItems.map((currentItem) => getApprovalReceivingSummary(currentItem)),
  );
  const totalIncomeFreightValue = getApprovalIncomeFreightValue(summarySourceItems);

  return (
    <div className="min-w-0 space-y-3">
      <div className="flex min-w-0 flex-wrap items-center gap-2">
        <Badge variant="outline" className="text-[11px]">
          {approvalTypeLabel || "待审批"}
        </Badge>
      </div>

      <div className="rounded-xl border border-slate-200 bg-gradient-to-br from-white to-slate-50/80 p-4 shadow-sm">
        <div className="text-xs font-medium uppercase tracking-[0.14em] text-slate-500">
          {isGroupSummary ? "第一层 · 组合主单摘要" : "第一层 · 当前订单摘要"}
        </div>

        <div className="mt-3 grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
          <div className="rounded-lg border border-slate-200 bg-white/90 p-3.5">
            <div className="text-[11px] font-medium text-slate-500">客户</div>
            <div className="mt-1 text-sm font-semibold text-slate-900 break-words text-wrap-safe">{customerName}</div>
          </div>
          <div className="rounded-lg border border-slate-200 bg-white/90 p-3.5">
            <div className="text-[11px] font-medium text-slate-500">货物简称</div>
            <div className="mt-1 text-sm font-semibold text-slate-900 break-words text-wrap-safe">{cargoName}</div>
          </div>
          <div className="rounded-lg border border-slate-200 bg-white/90 p-3.5">
            <div className="text-[11px] font-medium text-slate-500">发货仓库</div>
            <div className="mt-1 text-sm text-slate-800 break-words text-wrap-safe">{warehouseName}</div>
          </div>
          <div className="rounded-lg border border-slate-200 bg-white/90 p-3.5 lg:col-span-2 xl:col-span-2">
            <div className="text-[11px] font-medium text-slate-500">收货地址</div>
            <div className="mt-1 text-sm leading-6 text-slate-800 break-words text-wrap-safe">
              {[referenceItem.destinationCity, deliveryAddress].filter(Boolean).join(" · ") || referenceItem.destinationCity || "待补收货地址"}
            </div>
          </div>
          <div className="rounded-lg border border-slate-200 bg-white/90 p-3.5">
            <div className="text-[11px] font-medium text-slate-500">重量</div>
            <div className="mt-1 text-sm font-semibold text-slate-900">{totalWeightValue > 0 ? `${totalWeightValue.toFixed(3)}t` : "-"}</div>
          </div>
          <div className="rounded-lg border border-emerald-200 bg-emerald-50/70 p-3.5">
            <div className="text-[11px] font-medium text-emerald-700">收入运费</div>
            <div className="mt-1 text-sm font-semibold text-emerald-900">{totalIncomeFreightValue > 0 ? formatMoney(String(totalIncomeFreightValue)) : "-"}</div>
          </div>
          <div className="rounded-lg border border-orange-200 bg-orange-50/70 p-3.5 lg:col-span-2 xl:col-span-3">
            <div className="text-[11px] font-medium text-orange-700">收货备注</div>
            <div className="mt-1 text-sm leading-6 text-orange-900 break-words text-wrap-safe">{receivingNote || "-"}</div>
          </div>
          <div className="rounded-lg border border-blue-200 bg-blue-50/70 p-3.5 lg:col-span-2 xl:col-span-3">
            <div className="text-[11px] font-medium text-blue-700">发货备注</div>
            <div className="mt-1 text-sm leading-6 text-blue-900 break-words text-wrap-safe">{referenceItem.shippingNote || referenceItem.remarks || "-"}</div>
          </div>
        </div>
      </div>

      <div className="rounded-xl border border-slate-200 bg-slate-50/40 p-1 shadow-sm">
        <ApprovalHistory
          orderId={itemOrderId}
          childOrderRefs={isGroupSummary ? summarySourceItems.map((currentItem) => ({
            orderId: currentItem.orderId ?? currentItem.id,
            orderNumber: currentItem.orderNumber ?? null,
            systemCode: currentItem.systemCode ?? null,
            customerName: currentItem.customerName ?? null,
            cargoName: currentItem.cargoName ?? currentItem.productName ?? null,
            originCity: currentItem.originCity ?? null,
            warehouseName: currentItem.warehouseName ?? null,
            destinationCity: currentItem.destinationCity ?? null,
            deliveryAddress: currentItem.deliveryAddress ?? currentItem.destinationAddress ?? null,
            receivingAddress: currentItem.receivingAddress ?? null,
            unloadingAddress: currentItem.unloadingAddress ?? null,
            weight: currentItem.weight ?? currentItem.loadingWeight ?? null,
            referencePrice: currentItem.dispatchPrice ?? currentItem.quotedPrice ?? currentItem.actualFreight ?? null,
          })) : []}
        />
      </div>
    </div>
  );
}

function ApprovalPriceComparison({ item, items }: { item: any; items?: any[] }) {
  const priceSourceItems = items?.length ? items : [item].filter(Boolean);
  const referenceItem = priceSourceItems[0] ?? item ?? {};
  const isGroupPrice = priceSourceItems.length > 1;
  const groupPriceSnapshot = isGroupPrice ? getApprovalGroupPriceSnapshot(priceSourceItems) : null;
  const originalPrice = isGroupPrice ? groupPriceSnapshot?.originalPrice ?? null : getApprovalOriginalPrice(referenceItem);
  const originalPriceLabel = isGroupPrice ? "整组基准价" : getApprovalOriginalPriceLabel(referenceItem);
  const requestedPrice = isGroupPrice ? groupPriceSnapshot?.requestedPrice ?? null : getApprovalRequestedPrice(referenceItem);
  const priceDelta = isGroupPrice ? groupPriceSnapshot?.priceDelta ?? null : getApprovalPriceDelta(referenceItem);
  const deltaRate = isGroupPrice ? groupPriceSnapshot?.deltaRate ?? null : getApprovalPriceDeltaRate(referenceItem);
  const missingOriginalCount = isGroupPrice ? groupPriceSnapshot?.missingOriginalCount ?? 0 : 0;
  const missingRequestedCount = isGroupPrice ? groupPriceSnapshot?.missingRequestedCount ?? 0 : 0;
  const totalIncomeFreightValue = getApprovalIncomeFreightValue(priceSourceItems);
  const deltaTone = getApprovalDeltaTone(priceDelta, deltaRate);
  const riskHint =
    priceDelta === null
      ? ""
      : priceDelta > 0
        ? deltaRate !== null && deltaRate >= 10
          ? "涨幅偏高"
          : "建议复核"
        : priceDelta < 0
          ? "价格回落"
          : "与原价持平";

  return (
    <div className="space-y-1.5">
      <div className="flex flex-wrap items-center gap-1.5 text-[12px] leading-5">
        <span className="rounded-md bg-slate-100 px-2 py-1 text-[10px] text-slate-500">{originalPriceLabel}</span>
        <span className="font-semibold text-slate-700">{originalPrice !== null ? formatMoney(String(originalPrice)) : "-"}</span>
        <ArrowRight className="h-3.5 w-3.5 text-slate-400" />
        <span className="rounded-md bg-orange-50 px-2 py-1 text-[10px] text-orange-700">{isGroupPrice ? "整组申请价" : "申请价"}</span>
        <span className="font-semibold text-orange-600">{requestedPrice !== null ? formatMoney(String(requestedPrice)) : "-"}</span>
      </div>
      <div className="flex flex-wrap items-center gap-1.5 text-[12px] leading-5">
        <span className="rounded-md bg-emerald-50 px-2 py-1 text-[10px] text-emerald-700">
          {isGroupPrice ? "整组收入运费" : "收入运费"}
        </span>
        <span className="font-semibold text-emerald-700">{totalIncomeFreightValue > 0 ? formatMoney(String(totalIncomeFreightValue)) : "-"}</span>
      </div>
      <div className="flex flex-wrap items-center gap-1.5">
        {priceDelta !== null ? (
          <>
            <span className={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium ${deltaTone}`}>
              差额 {priceDelta > 0 ? "+" : ""}{formatMoney(String(priceDelta))}
            </span>
            {deltaRate !== null && (
              <span className={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium ${deltaTone}`}>
                涨幅 {deltaRate > 0 ? "+" : ""}{deltaRate}%
              </span>
            )}
            {riskHint && (
              <span className={`inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium ${deltaTone}`}>
                {riskHint}
              </span>
            )}
          </>
        ) : (
          <span className="text-[11px] text-muted-foreground">暂无可对比基准价</span>
        )}
      </div>
    </div>
  );
}

/**
 * 外请调度员找车台
 * 核心流程：待找车 → 录入车辆+报价+押金 → 审批/直接确认
 * 审批规则：运费>调度价 或 有备注 → 提交审批；运费≤调度价且无备注 → 直接确认派车
 */
export default function FindVehicle() {
  const { hasPermission } = usePermissions();
  const [, setLocation] = useLocation();
  const utils = trpc.useUtils();
  const [activeTab, setActiveTab] = useState("pending");
  const FAST_POLL_INTERVAL = 12000;
  const NORMAL_POLL_INTERVAL = 30000;
  const BACKGROUND_POLL_INTERVAL = 60000;
  const getTabPollInterval = useCallback((tabValue: string, fallback = BACKGROUND_POLL_INTERVAL) => {
    if (activeTab === tabValue) return FAST_POLL_INTERVAL;
    if (["pending", "approval", "dispatched", "pod-processing"].includes(activeTab)) return fallback;
    return false;
  }, [activeTab]);
  const pendingListParams = useMemo(() => ({ status: "pending_vehicle", businessType: "outsource" as const, pageSize: 100 }), []);
  const dispatchedListParams = useMemo(() => ({ status: "dispatched", businessType: "outsource" as const, pageSize: 100 }), []);
  const transitListParams = useMemo(() => ({ status: "in_transit", businessType: "outsource" as const, pageSize: 100 }), []);
  const deliveredListParams = useMemo(() => ({ status: "delivered", businessType: "outsource" as const, pageSize: 100 }), []);
  const signedListParams = useMemo(() => ({ status: "signed", businessType: "outsource" as const, pageSize: 100 }), []);
  const approvalListParams = useMemo(() => ({ status: "pending" as const }), []);
  const [depositSearch, setDepositSearch] = useState("");
  const depositSearchParams = useMemo(() => ({
    page: 1,
    pageSize: 500,
    keyword: depositSearch || undefined,
    businessType: "outsource" as const,
  }), [depositSearch]);
  const refreshFindVehicleViews = useCallback(async (targets: Array<"pending" | "approval" | "dispatched" | "transit" | "delivered" | "signed" | "deposit" | "stats" | "preview" | "groupReceived" | "podTracking">) => {
    await Promise.all(targets.map((target) => {
      switch (target) {
        case "pending":
          return utils.order.list.invalidate(pendingListParams);
        case "approval":
          return utils.approval.list.invalidate(approvalListParams);
        case "dispatched":
          return utils.order.list.invalidate(dispatchedListParams);
        case "transit":
          return utils.order.list.invalidate(transitListParams);
        case "delivered":
          return utils.order.list.invalidate(deliveredListParams);
        case "signed":
          return utils.order.list.invalidate(signedListParams);
        case "deposit":
          return utils.order.list.invalidate(depositSearchParams);
        case "stats":
          return utils.pod.depositStats.invalidate();
        case "preview":
          return utils.order.getOutsourceSuborderPreviews.invalidate();
        case "groupReceived":
          return utils.pod.checkGroupsReceived.invalidate();
        case "podTracking":
          return utils.pod.checkGroupsReceived.invalidate();
        default:
          return Promise.resolve();
      }
    }));
  }, [approvalListParams, deliveredListParams, depositSearchParams, dispatchedListParams, pendingListParams, signedListParams, transitListParams, utils]);
  const invalidateLightweightTargets = useCallback(async (targets: Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking">) => {
    if (targets.length === 0) return;
    await Promise.all(targets.map((target) => {
      switch (target) {
        case "approval":
          return utils.approval.list.invalidate(approvalListParams);
        case "stats":
          return utils.pod.depositStats.invalidate();
        case "preview":
          return utils.order.getOutsourceSuborderPreviews.invalidate();
        case "groupReceived":
        case "podTracking":
          return utils.pod.checkGroupsReceived.invalidate();
        default:
          return Promise.resolve();
      }
    }));
  }, [approvalListParams, utils]);
  const snapshotOrderListCaches = useCallback((paramsList: any[]) => paramsList.map((params) => ({
    params,
    data: utils.order.list.getData(params),
  })), [utils]);
  const restoreOrderListCaches = useCallback((snapshots: Array<{ params: any; data: any }>) => {
    snapshots.forEach(({ params, data }) => {
      utils.order.list.setData(params, data as any);
    });
  }, [utils]);
  const getStatusRefreshPlan = useCallback((status: string) => {
    switch (status) {
      case "pending_approval":
        return { full: [] as Array<"pending" | "dispatched" | "delivered" | "signed" | "deposit">, lightweight: ["approval", "preview"] as Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking"> };
      case "dispatched":
        return { full: ["deposit"] as Array<"pending" | "dispatched" | "delivered" | "signed" | "deposit">, lightweight: ["stats", "preview"] as Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking"> };
      case "delivered":
        return { full: [] as Array<"pending" | "dispatched" | "delivered" | "signed" | "deposit">, lightweight: ["groupReceived", "podTracking", "preview"] as Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking"> };
      case "signed":
        return { full: ["deposit"] as Array<"pending" | "dispatched" | "delivered" | "signed" | "deposit">, lightweight: ["stats", "groupReceived", "podTracking", "preview"] as Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking"> };
      default:
        return { full: [] as Array<"pending" | "dispatched" | "delivered" | "signed" | "deposit">, lightweight: ["preview"] as Array<"approval" | "stats" | "preview" | "groupReceived" | "podTracking"> };
    }
  }, []);
  const refreshAfterStatusMutation = useCallback(async (status: string) => {
    const plan = getStatusRefreshPlan(status);
    await Promise.all([
      refreshFindVehicleViews(plan.full),
      invalidateLightweightTargets(plan.lightweight),
    ]);
  }, [getStatusRefreshPlan, invalidateLightweightTargets, refreshFindVehicleViews]);
  const [dispatchDialog, setDispatchDialog] = useState<any>(null);
  const [vehiclePlate, setVehiclePlate] = useState("");
  const [driverName, setDriverName] = useState("");
  const [driverPhone, setDriverPhone] = useState("");
  const [quotePrice, setQuotePrice] = useState("");
  const [depositAmount, setDepositAmount] = useState("0");
  const [depositError, setDepositError] = useState(false);
  const [depositRefundable, setDepositRefundable] = useState("yes");
  const [dispatcherRemark, setDispatcherRemark] = useState("");
  const [receivingNote, setReceivingNote] = useState("");
  const [driverIdCard, setDriverIdCard] = useState("");

  // 待找车队列：外请订单 pending_vehicle 状态
  const { data: pendingData, refetch: refetchPending } = trpc.order.list.useQuery(
    pendingListParams,
    { refetchInterval: getTabPollInterval("pending", NORMAL_POLL_INTERVAL), staleTime: 8_000 }
  );

  // 待审批（已提交报价等待客服经理审批）
  const { data: approvalData, refetch: refetchApproval } = trpc.approval.list.useQuery(
    approvalListParams,
    { refetchInterval: getTabPollInterval("approval", NORMAL_POLL_INTERVAL), staleTime: 8_000 }
  );

  // 已调度（审批通过后）
  const { data: dispatchedData, refetch: refetchDispatched } = trpc.order.list.useQuery(
    dispatchedListParams,
    { refetchInterval: getTabPollInterval("dispatched", NORMAL_POLL_INTERVAL), staleTime: 10_000 }
  );

  // 运输中
  const { data: transitData, refetch: refetchTransit } = trpc.order.list.useQuery(
    transitListParams,
    { refetchInterval: getTabPollInterval("transit", NORMAL_POLL_INTERVAL), staleTime: 10_000 }
  );

  // 已送达+已签收（用于回单跟踪）
  const { data: deliveredData, refetch: refetchDelivered } = trpc.order.list.useQuery(
    deliveredListParams,
    { refetchInterval: getTabPollInterval("pod-processing", NORMAL_POLL_INTERVAL), staleTime: 10_000 }
  );
  const { data: signedData, refetch: refetchSigned } = trpc.order.list.useQuery(
    signedListParams,
    { refetchInterval: getTabPollInterval("pod-processing", NORMAL_POLL_INTERVAL), staleTime: 10_000 }
  );

  // === 押金管理数据查询 ===
  const { data: depositData, isLoading: depositLoading, refetch: refetchDeposit } = trpc.order.list.useQuery(
    depositSearchParams,
    { refetchInterval: getTabPollInterval("pod-processing", NORMAL_POLL_INTERVAL), staleTime: 15_000 }
  );
  const { data: depositStats, refetch: refetchStats } = trpc.pod.depositStats.useQuery(
    undefined,
    { refetchInterval: activeTab === "pod-processing" ? NORMAL_POLL_INTERVAL : BACKGROUND_POLL_INTERVAL, staleTime: 20_000 }
  );
  const [showImageDialog, setShowImageDialog] = useState(false);
  const [imageUrl, setImageUrl] = useState("");
  const [depositStatusFilter, setDepositStatusFilter] = useState<string>("all");

  const allDepositOrders = depositData?.items ?? [];
  // 改动：包含所有订单（含押金为0的），押金为0时直接当做已退还处理
  const depositOrders = allDepositOrders.filter(o => o.depositAmount !== undefined && o.depositAmount !== null);
  const pendingRefund = depositOrders.filter(o => o.depositStatus === "paid");
  const refundedOrders = depositOrders.filter(o => o.depositStatus === "refunded");
  const nonRefundable = depositOrders.filter(o => o.depositStatus === "not_refundable");
  const filteredPendingRefund = useMemo(() => {
    return pendingRefund;
  }, [pendingRefund]);

  // 退押金分组逻辑：优先按正式外请分组展示，未形成正式分组时回退按同车次展示
  const [expandedDepositGroups, setExpandedDepositGroups] = useState<Set<string>>(new Set());
  const toggleDepositGroup = (key: string) => {
    setExpandedDepositGroups(prev => { const n = new Set(prev); if (n.has(key)) n.delete(key); else n.add(key); return n; });
  };
  // 查询退押金Tab合并组的回单到齐状态
  const depositMpns = useMemo(() => {
    const mpns = new Set<string>();
    for (const o of filteredPendingRefund) {
      if (o.mergedPlanNumber) mpns.add(o.mergedPlanNumber);
    }
    return Array.from(mpns);
  }, [filteredPendingRefund]);
  const { data: groupReceivedMap } = trpc.pod.checkGroupsReceived.useQuery(
    { mergedPlanNumbers: depositMpns },
    { enabled: depositMpns.length > 0, refetchInterval: getTabPollInterval("pod-processing", NORMAL_POLL_INTERVAL), staleTime: 15_000 }
  );
  const setOrderListCache = useCallback((params: any, updater: (items: any[]) => any[]) => {
    utils.order.list.setData(params, (old: any) => {
      if (!old) return old;
      const prevItems = Array.isArray(old.items) ? old.items : [];
      const nextItems = updater(prevItems);
      return {
        ...old,
        items: nextItems,
        total: typeof old.total === "number"
          ? Math.max(0, old.total + (nextItems.length - prevItems.length))
          : nextItems.length,
      };
    });
  }, [utils]);
  const getCachedOrders = useCallback((params: any, orderIds: number[]) => {
    const cache = utils.order.list.getData(params) as any;
    if (!cache?.items) return [] as any[];
    const idSet = new Set(orderIds);
    return cache.items.filter((item: any) => idSet.has(item.id));
  }, [utils]);
  const removeOrdersFromListCache = useCallback((params: any, orderIds: number[]) => {
    const idSet = new Set(orderIds);
    setOrderListCache(params, (items) => items.filter((item: any) => !idSet.has(item.id)));
  }, [setOrderListCache]);
  const prependOrdersToListCache = useCallback((params: any, orders: any[]) => {
    if (orders.length === 0) return;
    setOrderListCache(params, (items) => {
      const incoming = new Map(orders.map((order) => [order.id, order]));
      return [...orders, ...items.filter((item: any) => !incoming.has(item.id))];
    });
  }, [setOrderListCache]);
  const patchOrdersInListCache = useCallback((params: any, orderIds: number[], patch: Record<string, any> | ((order: any) => Record<string, any>)) => {
    if (orderIds.length === 0) return;
    const idSet = new Set(orderIds);
    setOrderListCache(params, (items) => items.map((item: any) => {
      if (!idSet.has(item.id)) return item;
      const nextPatch = typeof patch === "function" ? patch(item) : patch;
      return { ...item, ...nextPatch };
    }));
  }, [setOrderListCache]);
  const getOptimisticTransitionParams = useCallback((status: string) => {
    switch (status) {
      case "pending_approval":
        return { source: pendingListParams, target: null as any };
      case "dispatched":
        return { source: pendingListParams, target: dispatchedListParams };
      case "delivered":
        return { source: dispatchedListParams, target: deliveredListParams };
      case "signed":
        return { source: dispatchedListParams, target: signedListParams };
      default:
        return { source: null as any, target: null as any };
    }
  }, [deliveredListParams, dispatchedListParams, pendingListParams, signedListParams]);
  const applyOptimisticStatusTransition = useCallback((orderIds: number[], status: string, patch: Record<string, any>) => {
    const { source, target } = getOptimisticTransitionParams(status);
    if (!source) return null;
    const previousSource = utils.order.list.getData(source);
    const previousTarget = target ? utils.order.list.getData(target) : null;
    const optimisticOrders = getCachedOrders(source, orderIds).map((order: any) => ({ ...order, status, ...patch }));
    removeOrdersFromListCache(source, orderIds);
    if (target) {
      prependOrdersToListCache(target, optimisticOrders);
    }
    return { source, target, previousSource, previousTarget };
  }, [getCachedOrders, getOptimisticTransitionParams, prependOrdersToListCache, removeOrdersFromListCache, utils]);
  const restoreOptimisticStatusTransition = useCallback((context: any) => {
    if (!context?.source) return;
    utils.order.list.setData(context.source, context.previousSource as any);
    if (context.target) {
      utils.order.list.setData(context.target, context.previousTarget as any);
    }
  }, [utils]);
  const findVehicleOrderListParams = useMemo(() => ([
    pendingListParams,
    dispatchedListParams,
    transitListParams,
    deliveredListParams,
    signedListParams,
    depositSearchParams,
  ]), [deliveredListParams, depositSearchParams, dispatchedListParams, pendingListParams, signedListParams, transitListParams]);
  const removeOrdersFromAllFindVehicleCaches = useCallback((orderIds: number[]) => {
    findVehicleOrderListParams.forEach((params) => removeOrdersFromListCache(params, orderIds));
  }, [findVehicleOrderListParams, removeOrdersFromListCache]);
  const patchOrdersAcrossFindVehicleCaches = useCallback((orderIds: number[], patch: Record<string, any> | ((order: any) => Record<string, any>)) => {
    findVehicleOrderListParams.forEach((params) => patchOrdersInListCache(params, orderIds, patch));
  }, [findVehicleOrderListParams, patchOrdersInListCache]);
  const applyOptimisticFieldPatch = useCallback((orderIds: number[], patch: Record<string, any>) => {
    const snapshots = snapshotOrderListCaches(findVehicleOrderListParams);
    patchOrdersAcrossFindVehicleCaches(orderIds, patch);
    return { snapshots };
  }, [findVehicleOrderListParams, patchOrdersAcrossFindVehicleCaches, snapshotOrderListCaches]);
  const restoreOptimisticFieldPatch = useCallback((context: any) => {
    restoreOrderListCaches(context?.snapshots ?? []);
  }, [restoreOrderListCaches]);
  const applyOptimisticDeletion = useCallback((orderIds: number[]) => {
    const orderSnapshots = snapshotOrderListCaches(findVehicleOrderListParams);
    const approvalSnapshot = utils.approval.list.getData(approvalListParams);
    removeOrdersFromAllFindVehicleCaches(orderIds);
    utils.approval.list.setData(approvalListParams, (old: any) => {
      if (!old?.items) return old;
      const idSet = new Set(orderIds);
      const nextItems = old.items.filter((item: any) => !idSet.has(item.orderId));
      return {
        ...old,
        items: nextItems,
        total: typeof old.total === "number" ? Math.max(0, old.total + (nextItems.length - old.items.length)) : nextItems.length,
      };
    });
    return { orderSnapshots, approvalSnapshot };
  }, [approvalListParams, findVehicleOrderListParams, removeOrdersFromAllFindVehicleCaches, snapshotOrderListCaches, utils]);
  const restoreOptimisticDeletion = useCallback((context: any) => {
    restoreOrderListCaches(context?.orderSnapshots ?? []);
    utils.approval.list.setData(approvalListParams, context?.approvalSnapshot as any);
  }, [approvalListParams, restoreOrderListCaches, utils]);
  const derivePodEffectiveStatus = useCallback((order: any, nextOriginalStatus: string | null) => {
    if (nextOriginalStatus === "received") return "original_received";
    if (nextOriginalStatus === "sent") return "original_sent";
    return order?.podDeliveryNoteUrl ? "uploaded" : "none";
  }, []);
  const groupedPendingRefund = useMemo(() => {
    const groups: Map<string, any[]> = new Map();
    for (const order of filteredPendingRefund) {
      const key = getDispatchGroupKey(order);
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key)!.push(order);
    }
    return Array.from(groups.entries()).map(([key, items]) => {
      // 检查该组回单寄出与财务签收进度，供“回单处理”页签联动展示
      let podTotalCount = items.length;
      let podSentCount = items.filter((item: any) => hasPodBeenSent(item)).length;
      let podReceivedCount = items.filter((item: any) => getOrderPodOriginalStatus(item) === "received").length;
      let allPodsSent = podTotalCount > 0 ? podSentCount === podTotalCount : false;
      let allPodsReceived = podTotalCount > 0 ? podReceivedCount === podTotalCount : false;
      const mpn = items[0]?.mergedPlanNumber;
      if (mpn && groupReceivedMap) {
        const progress = groupReceivedMap[mpn];
        if (progress) {
          allPodsSent = progress.allSent;
          allPodsReceived = progress.allReceived;
          podSentCount = progress.sentCount;
          podTotalCount = progress.totalCount;
          podReceivedCount = progress.receivedCount;
        } else {
          allPodsSent = false;
          allPodsReceived = false;
        }
      }
      const primaryOrder = items[0] as any;
      const visibleDispatchGroup =
        primaryOrder?.dispatchRecordLabel ||
        primaryOrder?.dispatchGroupLabel ||
        primaryOrder?.dispatchRecordNumber ||
        primaryOrder?.dispatchRecordCode ||
        primaryOrder?.mergedPlanNumber ||
        null;
      const vehicleTripLabel = [primaryOrder?.plateNumber, primaryOrder?.driverName].filter(Boolean).join(" / ") || "待补车次信息";
      return {
        key,
        items,
        isMerged: items.length > 1,
        plateNumber: items[0]?.plateNumber || "-",
        driverName: items[0]?.driverName || "-",
        driverPhone: items[0]?.driverPhone || "-",
        totalDeposit: items.reduce((sum: number, o: any) => sum + parseFloat(String(o.depositAmount || "0")), 0),
        customerNames: Array.from(new Set(items.map((o: any) => o.customerName).filter(Boolean))).join("、"),
        routes: Array.from(new Set(items.map((o: any) => `${o.originCity || "?"}\u2192${o.destinationCity || "?"}`))).join("、"),
        visibleDispatchGroup,
        groupHeadline: visibleDispatchGroup ? `正式外请分组：${visibleDispatchGroup}` : `回退车次：${vehicleTripLabel}`,
        groupSubline: visibleDispatchGroup
          ? (primaryOrder?.mergedPlanNumber && visibleDispatchGroup !== primaryOrder?.mergedPlanNumber
              ? `参考批次：${primaryOrder?.mergedPlanNumber} · 回单处理与退押金优先按正式外请分组处理。`
              : "回单处理与退押金优先按正式外请分组处理。")
          : `当前未形成正式外请分组，回单处理暂按同车次处理：${vehicleTripLabel}`,
        allPodsSent,
        allPodsReceived,
        podSentCount,
        podReceivedCount,
        podTotalCount,
      };

    });
  }, [filteredPendingRefund, groupReceivedMap]);
  const blockedPendingRefundOrderIds = useMemo(() => {
    const ids = new Set<number>();
    for (const group of groupedPendingRefund) {
      if (!group.allPodsSent) {
        group.items.forEach((order: any) => ids.add(order.id));
      }
    }
    return ids;
  }, [groupedPendingRefund]);
  const awaitingFinanceConfirmOrderIds = useMemo(() => {
    const ids = new Set<number>();
    for (const group of groupedPendingRefund) {
      if (group.allPodsSent && !group.allPodsReceived) {
        group.items.forEach((order: any) => ids.add(order.id));
      }
    }
    return ids;
  }, [groupedPendingRefund]);
  const filteredDoneDeposit = useMemo(() => {
    let items = [...refundedOrders, ...nonRefundable];
    if (depositStatusFilter !== "all") items = items.filter((o) => o.depositStatus === depositStatusFilter);
    return items;
  }, [refundedOrders, nonRefundable, depositStatusFilter]);
  const [expandedDoneDepositGroups, setExpandedDoneDepositGroups] = useState<Set<string>>(new Set());
  const toggleDoneDepositGroup = (key: string) => {
    setExpandedDoneDepositGroups(prev => {
      const next = new Set(prev);
      if (next.has(key)) next.delete(key);
      else next.add(key);
      return next;
    });
  };
  const groupedDoneDeposit = useMemo(() => {
    const groups: Map<string, any[]> = new Map();
    const ungrouped: any[] = [];
    for (const order of filteredDoneDeposit) {
      const key = getDispatchGroupKey(order);
      const items = groups.get(key) || [];
      items.push(order);
      groups.set(key, items);
    }
    const grouped = Array.from(groups.entries()).flatMap(([key, items]) => {
      if (items.length <= 1) {
        ungrouped.push(items[0]);
        return [];
      }
      const primaryOrder = items[0] as any;
      return [{
        key,
        items,
        totalDeposit: items.reduce((sum: number, item: any) => sum + parseFloat(String(item.depositAmount || "0")), 0),
        refundedCount: items.filter((item: any) => item.depositStatus === "refunded").length,
        notRefundableCount: items.filter((item: any) => item.depositStatus === "not_refundable").length,
        groupHeadline: getDispatchHeadline(primaryOrder),
        groupSubline: getDispatchSubline(primaryOrder),
        customerCargoSummary: getGroupCustomerCargoSummary(items),
        routeSummary: getGroupRouteSummary(items),
        vehicleSummary: `${primaryOrder?.plateNumber || "-"} / ${primaryOrder?.driverName || "-"}`,
      }];
    });
    return { groups: grouped, ungrouped };
  }, [filteredDoneDeposit]);
  const stats = depositStats || { pendingTotal: "0", refundedTotal: "0", nonRefundableTotal: "0", pendingCount: 0, refundedCount: 0, nonRefundableCount: 0 };

  // === 外请超期回单监控 ===
  const [overdueFilter, setOverdueFilter] = useState<string>("all");
  const { data: outsourceOverdueStats, refetch: refetchOutsourceOverdue } = trpc.pod.outsourceOverdueStats.useQuery(
    undefined,
    { refetchInterval: 15000 }
  );
  const outsourceOverdueData = useMemo(() => {
    if (!outsourceOverdueStats) return { yellow: 0, orange: 0, red: 0, total: 0, items: [] as any[] };
    const items = outsourceOverdueStats.items || [];
    const yellow = items.filter((i: any) => i.level === "yellow").length;
    const orange = items.filter((i: any) => i.level === "orange").length;
    const red = items.filter((i: any) => i.level === "red").length;
    return { yellow, orange, red, total: yellow + orange + red, items };
  }, [outsourceOverdueStats]);
  const filteredOutsourceOverdueItems = useMemo(() => {
    if (!outsourceOverdueData.items.length) return [];
    if (overdueFilter === "all") return outsourceOverdueData.items;
    return outsourceOverdueData.items.filter((i: any) => i.level === overdueFilter);
  }, [outsourceOverdueData.items, overdueFilter]);

  const handleViewImage = (url: string) => {
    setImageUrl(url);
    setShowImageDialog(true);
  };

  // 各Tab搜索状态
  const [pendingSearch, setPendingSearch] = useState("");
  const [approvalSearch, setApprovalSearch] = useState("");
  const [dispatchedSearch, setDispatchedSearch] = useState("");
  const [podSearch, setPodSearch] = useState("");
  // 分页状态
  const [pendingPage, setPendingPage] = useState(1);
  const [pendingPageSize, setPendingPageSize] = useState(100);
  const [approvalPage, setApprovalPage] = useState(1);
  const [approvalPageSize, setApprovalPageSize] = useState(100);
  const [dispatchedPage, setDispatchedPage] = useState(1);
  const [dispatchedPageSize, setDispatchedPageSize] = useState(100);
  const [podPage, setPodPage] = useState(1);
  const [podPageSize, setPodPageSize] = useState(100);
  const [depositPendingPage, setDepositPendingPage] = useState(1);
  const [depositPendingPageSize, setDepositPendingPageSize] = useState(100);
  const [depositDonePage, setDepositDonePage] = useState(1);
  const [depositDonePageSize, setDepositDonePageSize] = useState(100);
  const [overduePage, setOverduePage] = useState(1);
  const [overduePageSize, setOverduePageSize] = useState(100);

  const [receivingNoteOrder, setReceivingNoteOrder] = useState<any>(null);
  const [confirmVehicleOrder, setConfirmVehicleOrder] = useState<any>(null);
  const [confirmVehicleGroupOrders, setConfirmVehicleGroupOrders] = useState<any[]>([]);
  const [deleteTargetId, setDeleteTargetId] = useState<number | null>(null);
  const [rollbackTargetId, setRollbackTargetId] = useState<number | null>(null);
  const [rollbackReason, setRollbackReason] = useState("");
  const [revertTargetStatus, setRevertTargetStatus] = useState("pending_vehicle");
  const [selectedIds, setSelectedIds] = useState<Set<number>>(new Set());
  const selectedPendingRefundSummary = useMemo(() => {
    const selectedOrderIds = filteredPendingRefund.filter((o) => selectedIds.has(o.id)).map((o) => o.id);
    const blockedIds = selectedOrderIds.filter((id) => blockedPendingRefundOrderIds.has(id));
    const awaitingFinanceIds = selectedOrderIds.filter((id) => awaitingFinanceConfirmOrderIds.has(id));
    const refundableIds = selectedOrderIds.filter((id) => !blockedPendingRefundOrderIds.has(id) && !awaitingFinanceConfirmOrderIds.has(id));
    return {
      selectedOrderIds,
      blockedIds,
      awaitingFinanceIds,
      refundableIds,
    };
  }, [filteredPendingRefund, selectedIds, blockedPendingRefundOrderIds, awaitingFinanceConfirmOrderIds]);
  const [batchRollbackOpen, setBatchRollbackOpen] = useState(false);
  const [batchRollbackReason, setBatchRollbackReason] = useState("");
  const [batchDeleteOpen, setBatchDeleteOpen] = useState(false);
  const [urgentDialogInfo, setUrgentDialogInfo] = useState<{
    orderIds: number[];
    orders: any[];
    action: "mark" | "clear";
    scopeLabel: string;
  } | null>(null);
  const [urgentReason, setUrgentReason] = useState("");
  const [batchApproveOpen, setBatchApproveOpen] = useState(false);
  const [batchApproveAction, setBatchApproveAction] = useState<"approve" | "reject">("approve");
  const [batchApproveComment, setBatchApproveComment] = useState("");
  const [expandedApprovalHistoryOrderIds, setExpandedApprovalHistoryOrderIds] = useState<Set<number>>(new Set());
  // 批量找车状态
  const [batchDispatchOpen, setBatchDispatchOpen] = useState(false);
  const [batchVehiclePlate, setBatchVehiclePlate] = useState("");
  const [batchDriverName, setBatchDriverName] = useState("");
  const [batchDriverPhone, setBatchDriverPhone] = useState("");
  const [batchQuotePrice, setBatchQuotePrice] = useState("");
  const [batchDepositAmount, setBatchDepositAmount] = useState("");
  const [batchDepositRefundable, setBatchDepositRefundable] = useState("yes");
  const [batchDispatcherRemark, setBatchDispatcherRemark] = useState("");
  const [batchReceivingNote, setBatchReceivingNote] = useState("");
  const vehicleSearch = trpc.vehicle.lookupByPlate.useMutation();

  const toggleSelect = (id: number) => {
    setSelectedIds(prev => { const next = new Set(prev); if (next.has(id)) next.delete(id); else next.add(id); return next; });
  };
  const toggleApprovalHistory = useCallback((orderId: number) => {
    setExpandedApprovalHistoryOrderIds((prev) => {
      const next = new Set(prev);
      if (next.has(orderId)) next.delete(orderId);
      else next.add(orderId);
      return next;
    });
  }, []);
  const replaceSelectedIds = useCallback((ids: number[]) => {
    setSelectedIds(new Set(ids));
  }, []);
  const openBatchRollbackDialog = useCallback((ids: number[]) => {
    if (ids.length === 0) {
      toast.error("请先选择需要退回的订单");
      return;
    }
    replaceSelectedIds(ids);
    setBatchRollbackReason("");
    setBatchRollbackOpen(true);
  }, [replaceSelectedIds]);
  const openBatchDeleteDialog = useCallback((ids: number[]) => {
    if (ids.length === 0) {
      toast.error("请先选择需要删除的订单");
      return;
    }
    replaceSelectedIds(ids);
    setBatchDeleteOpen(true);
  }, [replaceSelectedIds]);
  const openUrgentDialog = useCallback((orders: any[], scopeLabel: string) => {
    const normalizedOrders = orders
      .map((order: any) => ({
        ...order,
        id: order.orderId ?? order.id,
      }))
      .filter((order: any) => typeof order.id === "number");
    if (normalizedOrders.length === 0) {
      toast.error("未找到可操作的订单");
      return;
    }
    const shouldClear = normalizedOrders.every((order: any) => order.isUrgent);
    setUrgentDialogInfo({
      orderIds: normalizedOrders.map((order: any) => order.id),
      orders: normalizedOrders,
      action: shouldClear ? "clear" : "mark",
      scopeLabel,
    });
    setUrgentReason(shouldClear ? "" : normalizedOrders.find((order: any) => order.isUrgent)?.urgentReason || "");
  }, []);

  const getDeleteLockReason = useCallback((order: any) => getMergedChildDeleteLockReason(order), []);
  const getRollbackLockReason = useCallback((order: any) => getMergedChildRollbackLockReason(order), []);
  const openDeleteDialog = useCallback((order: any, orderId?: number | null) => {
    const lockReason = getDeleteLockReason(order);
    if (lockReason) {
      toast.error(lockReason);
      return;
    }
    const resolvedId = orderId ?? order?.orderId ?? order?.id;
    if (!resolvedId) return;
    setDeleteTargetId(resolvedId);
  }, [getDeleteLockReason]);
  const openRollbackDialog = useCallback((order: any, orderId?: number | null) => {
    const lockReason = getRollbackLockReason(order);
    if (lockReason) {
      toast.error(lockReason);
      return;
    }
    const resolvedId = orderId ?? order?.orderId ?? order?.id;
    if (!resolvedId) return;
    setRollbackTargetId(resolvedId);
    setRollbackReason("");
  }, [getRollbackLockReason]);

  const rollbackMutation = trpc.order.rollbackStatus.useMutation({
    onSuccess: async (res) => {
      await refreshFindVehicleViews(["pending", "approval", "dispatched"]);
      toast.success(`订单已退回：${res.fromLabel} → ${res.toLabel}`);
      setRollbackTargetId(null);
      setRollbackReason("");
    },
    onError: (err: any) => toast.error(err.message),
  });
  // 指定目标状态退回（增强版：强制清空派车信息+清理回单+重置押金）
  const revertMutation = trpc.order.revertStatus.useMutation({
    onSuccess: async (res) => {
      await refreshFindVehicleViews(["pending", "approval", "dispatched"]);
      toast.success(`订单已退回：${res.fromLabel} → ${res.toLabel}`);
      setRollbackTargetId(null);
      setRollbackReason("");
      setRevertTargetStatus("pending_vehicle");
    },
    onError: (err: any) => toast.error(err.message),
  });
  const batchRollbackMutation = trpc.order.batchRollback.useMutation({
    onSuccess: async (res) => {
      await refreshFindVehicleViews(["pending", "approval", "dispatched"]);
      const msg = res.skipCount > 0 ? `成功退回 ${res.successCount} 个，${res.skipCount} 个跳过` : `成功退回 ${res.successCount} 个订单`;
      toast.success(msg);
      setSelectedIds(new Set()); setBatchRollbackOpen(false); setBatchRollbackReason("");
    },
    onError: (err: any) => toast.error(err.message),
  });
  const batchApprove = trpc.approval.batchExecute.useMutation({
    onSuccess: async (data) => {
      toast.success(`批量${batchApproveAction === "approve" ? "通过" : "驳回"}成功，处理 ${data.count}/${data.total} 个`);
      setBatchApproveOpen(false);
      setBatchApproveComment("");
      setSelectedIds(new Set());
      await refreshFindVehicleViews(["pending", "approval", "dispatched", "preview"]);
    },
    onError: (e: any) => toast.error(e.message),
  });
  // 整组派车（合并计划号专用：运费分摊+押金防重）
  const batchDispatchMutation = trpc.order.batchDispatch.useMutation({
    onMutate: async (variables) => applyOptimisticStatusTransition(variables.orderIds, "dispatched", {
      plateNumber: variables.plateNumber,
      driverName: variables.driverName ?? null,
      driverPhone: variables.driverPhone ?? null,
      depositAmount: variables.depositAmount,
      depositRefundable: variables.depositRefundable,
      dispatcherRemark: variables.dispatcherRemark ?? null,
      receivingNote: variables.receivingNote ?? null,
    }),
    onSuccess: async (data) => {
      toast.success(`整组派车成功，共 ${data.count} 个订单，运费已按重量分摊`);
      setBatchDispatchOpen(false);
      setBatchVehiclePlate(""); setBatchDriverName(""); setBatchDriverPhone("");
      setBatchQuotePrice(""); setBatchDepositAmount(""); setBatchDepositRefundable("yes");
      setBatchDispatcherRemark(""); setBatchReceivingNote("");
      setSelectedIds(new Set());
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["stats", "preview"]),
      ]);
    },
    onError: (e, _variables, context) => {
      restoreOptimisticStatusTransition(context);
      toast.error(e.message);
    },
  });

  // 批量状态更新（非派车场景，保留以备其他批量操作使用）
  const batchUpdateStatus = trpc.order.batchUpdateStatus.useMutation({
    onMutate: async (variables) => applyOptimisticStatusTransition(variables.orderIds, variables.status, {
      plateNumber: variables.plateNumber,
      driverName: variables.driverName,
      driverPhone: variables.driverPhone,
      actualFreight: variables.actualFreight,
      depositAmount: variables.depositAmount,
      depositRefundable: variables.depositRefundable,
      dispatcherRemark: variables.dispatcherRemark,
      receivingNote: variables.receivingNote,
    }),
    onSuccess: async (data, variables) => {
      toast.success(`批量操作成功，共 ${data.count} 个订单已处理`);
      setBatchDispatchOpen(false);
      setBatchVehiclePlate(""); setBatchDriverName(""); setBatchDriverPhone("");
      setBatchQuotePrice(""); setBatchDepositAmount(""); setBatchDepositRefundable("yes");
      setBatchDispatcherRemark(""); setBatchReceivingNote("");
      setSelectedIds(new Set());
      await refreshAfterStatusMutation(variables.status);
    },
    onError: (e, _variables, context) => {
      restoreOptimisticStatusTransition(context);
      toast.error(e.message);
    },
  });

  const deleteMutation = trpc.order.delete.useMutation({
    onMutate: async (variables) => applyOptimisticDeletion([variables.id]),
    onSuccess: async () => {
      toast.success("订单已删除");
      setDeleteTargetId(null);
      await invalidateLightweightTargets(["approval", "stats", "preview", "groupReceived", "podTracking"]);
    },
    onError: (err, _variables, context) => {
      restoreOptimisticDeletion(context);
      toast.error(err.message);
    },
  });
  const batchDeleteMutation = trpc.order.batchDelete.useMutation({
    onMutate: async (variables) => applyOptimisticDeletion(variables.ids),
    onSuccess: async (res) => {
      toast.success(`已批量删除 ${res.count} 个订单`);
      setBatchDeleteOpen(false);
      setSelectedIds(new Set());
      await invalidateLightweightTargets(["approval", "stats", "preview", "groupReceived", "podTracking"]);
    },
    onError: (err: any, _variables, context) => {
      restoreOptimisticDeletion(context);
      toast.error(err.message || "批量删除失败");
    },
  });
  const updateStatus = trpc.order.updateStatus.useMutation({
    onMutate: async (variables) => applyOptimisticStatusTransition([variables.id], variables.status, {
      actualFreight: variables.actualFreight,
      depositAmount: variables.depositAmount,
      depositRefundable: variables.depositRefundable,
      dispatcherRemark: variables.dispatcherRemark,
      receivingNote: variables.receivingNote,
    }),
    onSuccess: async (_data, variables) => {
      toast.success("操作成功");
      setDispatchDialog(null);
      resetForm();
      await refreshAfterStatusMutation(variables.status);
    },
    onError: (e, _variables, context) => {
      restoreOptimisticStatusTransition(context);
      toast.error(e.message);
    },
  });

  const updateOrderFields = trpc.order.updateOrderFields.useMutation({
    onMutate: async (variables) => applyOptimisticFieldPatch([variables.id], {
      ...variables,
      expectedReceiveAt: variables.expectedReceiveAt ?? undefined,
      nextFollowUpAt: variables.nextFollowUpAt ?? undefined,
    }),
    onSuccess: async (_data, variables) => {
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["approval", "stats", "preview", "groupReceived", "podTracking"]),
      ]);
      patchOrdersAcrossFindVehicleCaches([variables.id], {
        ...variables,
        expectedReceiveAt: variables.expectedReceiveAt ?? undefined,
        nextFollowUpAt: variables.nextFollowUpAt ?? undefined,
      });
    },
    onError: (e, _variables, context) => {
      restoreOptimisticFieldPatch(context);
      toast.error(e.message);
    },
  });

  const confirmUrgentToggle = async () => {
    if (!urgentDialogInfo) return;
    if (urgentDialogInfo.action === "mark" && !urgentReason.trim()) {
      toast.error("请填写加急原因");
      return;
    }
    let successCount = 0;
    for (const orderId of urgentDialogInfo.orderIds) {
      try {
        await updateOrderFields.mutateAsync({
          id: orderId,
          isUrgent: urgentDialogInfo.action === "mark",
          urgentReason: urgentDialogInfo.action === "mark" ? urgentReason.trim() : undefined,
        });
        successCount += 1;
      } catch (error: any) {
        toast.error(error.message || `订单 #${orderId} 更新失败`);
      }
    }
    if (successCount > 0) {
      toast.success(
        urgentDialogInfo.action === "mark"
          ? `已将 ${successCount} 个订单标记为加急`
          : `已取消 ${successCount} 个订单的加急标记`,
      );
      if (urgentDialogInfo.orderIds.length > 1) {
        setSelectedIds(new Set());
      }
    }
    setUrgentDialogInfo(null);
    setUrgentReason("");
  };

  const markPodSent = trpc.order.markPodSent.useMutation();
  const cancelPodSent = trpc.order.cancelPodSent.useMutation();
  const refundDepositMutation = trpc.order.refundDeposit.useMutation({
    onMutate: async (variables) => {
      const previousSigned = utils.order.list.getData(signedListParams);
      const previousDeposit = utils.order.list.getData(depositSearchParams);
      patchOrdersInListCache(signedListParams, [variables.id], { depositStatus: "refunded", depositRefunded: true, status: "settled" });
      patchOrdersInListCache(depositSearchParams, [variables.id], { depositStatus: "refunded", depositRefunded: true, status: "settled" });
      return { previousSigned, previousDeposit };
    },
    onSuccess: async () => {
      toast.success("押金已退还");
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["stats"]),
      ]);
    },
    onError: (err: any, _variables, context) => {
      utils.order.list.setData(signedListParams, context?.previousSigned as any);
      utils.order.list.setData(depositSearchParams, context?.previousDeposit as any);
      toast.error(err.message || "退押金失败");
    },
  });
  const batchRefundDepositMutation = trpc.order.batchRefundDeposit.useMutation({
    onMutate: async (variables) => {
      const previousSigned = utils.order.list.getData(signedListParams);
      const previousDeposit = utils.order.list.getData(depositSearchParams);
      patchOrdersInListCache(signedListParams, variables.ids, { depositStatus: "refunded", depositRefunded: true, status: "settled" });
      patchOrdersInListCache(depositSearchParams, variables.ids, { depositStatus: "refunded", depositRefunded: true, status: "settled" });
      return { previousSigned, previousDeposit };
    },
    onSuccess: async (res) => {
      toast.success(`批量退押成功，共 ${res.count} 笔`);
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["stats"]),
      ]);
      setSelectedIds(new Set());
    },
    onError: (err: any, _variables, context) => {
      utils.order.list.setData(signedListParams, context?.previousSigned as any);
      utils.order.list.setData(depositSearchParams, context?.previousDeposit as any);
      toast.error(err.message || "批量退押金失败");
    },
  });

  const handleMarkPodSent = async (
    candidates: any[],
    options?: {
      scopeLabel?: string;
      clearSelection?: boolean;
    },
  ) => {
    const eligibleOrders = candidates.filter(canMarkPodAsSent);
    if (eligibleOrders.length === 0) {
      toast.info("当前所选订单暂无可操作的回单寄出动作");
      return;
    }

    const results = await Promise.allSettled(
      eligibleOrders.map((order: any) => markPodSent.mutateAsync({ orderId: order.id })),
    );
    const successCount = results.filter((result) => result.status === "fulfilled").length;
    const failedMessages = Array.from(
      new Set(
        results
          .filter((result): result is PromiseRejectedResult => result.status === "rejected")
          .map((result) => result.reason instanceof Error ? result.reason.message : "回单寄出标记失败"),
      ),
    );

    if (successCount > 0) {
      const successOrderIds = eligibleOrders
        .filter((_order: any, index: number) => results[index]?.status === "fulfilled")
        .map((order: any) => order.id);
      const sentAt = new Date().toISOString();
      patchOrdersInListCache(deliveredListParams, successOrderIds, (order: any) => ({
        podOriginalStatus: "sent",
        podOriginalSentAt: sentAt,
        podEffectiveStatus: derivePodEffectiveStatus(order, "sent"),
      }));
      patchOrdersInListCache(signedListParams, successOrderIds, (order: any) => ({
        podOriginalStatus: "sent",
        podOriginalSentAt: sentAt,
        podEffectiveStatus: derivePodEffectiveStatus(order, "sent"),
      }));
      patchOrdersInListCache(depositSearchParams, successOrderIds, (order: any) => ({
        podOriginalStatus: "sent",
        podOriginalSentAt: sentAt,
        podEffectiveStatus: derivePodEffectiveStatus(order, "sent"),
      }));
      toast.success(
        options?.scopeLabel
          ? `${options.scopeLabel}标记 ${successCount} 个订单回单已寄出`
          : "已标记回单已寄出",
      );
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["groupReceived", "podTracking", "stats"]),
      ]);
      if (options?.clearSelection) {
        setSelectedIds(new Set());
      }
    }

    if (failedMessages.length > 0) {
      toast.error(failedMessages[0]);
    }
  };

  const handleCancelPodSent = async (
    candidates: any[],
    options?: {
      scopeLabel?: string;
      clearSelection?: boolean;
    },
  ) => {
    const eligibleOrders = candidates.filter(canCancelPodSent);
    if (eligibleOrders.length === 0) {
      toast.info("当前所选订单暂无可撤销的回单寄出状态");
      return;
    }

    const results = await Promise.allSettled(
      eligibleOrders.map((order: any) => cancelPodSent.mutateAsync({ orderId: order.id })),
    );
    const successCount = results.filter((result) => result.status === "fulfilled").length;
    const failedMessages = Array.from(
      new Set(
        results
          .filter((result): result is PromiseRejectedResult => result.status === "rejected")
          .map((result) => result.reason instanceof Error ? result.reason.message : "撤销回单寄出失败"),
      ),
    );

    if (successCount > 0) {
      const successOrderIds = eligibleOrders
        .filter((_order: any, index: number) => results[index]?.status === "fulfilled")
        .map((order: any) => order.id);
      patchOrdersInListCache(deliveredListParams, successOrderIds, (order: any) => ({
        podOriginalStatus: null,
        podOriginalSentAt: null,
        podEffectiveStatus: derivePodEffectiveStatus(order, null),
      }));
      patchOrdersInListCache(signedListParams, successOrderIds, (order: any) => ({
        podOriginalStatus: null,
        podOriginalSentAt: null,
        podEffectiveStatus: derivePodEffectiveStatus(order, null),
      }));
      patchOrdersInListCache(depositSearchParams, successOrderIds, (order: any) => ({
        podOriginalStatus: null,
        podOriginalSentAt: null,
        podEffectiveStatus: derivePodEffectiveStatus(order, null),
      }));
      toast.success(
        options?.scopeLabel
          ? `${options.scopeLabel}撤销 ${successCount} 个订单回单寄出`
          : "已撤销回单寄出",
      );
      await Promise.all([
        refreshFindVehicleViews(["deposit"]),
        invalidateLightweightTargets(["groupReceived", "podTracking", "stats"]),
      ]);
      if (options?.clearSelection) {
        setSelectedIds(new Set());
      }
    }

    if (failedMessages.length > 0) {
      toast.error(failedMessages[0]);
    }
  };

  const resetForm = () => {
    setVehiclePlate("");
    setDriverName("");
    setDriverPhone("");
    setDriverIdCard("");
    setQuotePrice("");
    setDepositAmount("0");
    setDepositError(false);
    setDepositRefundable("yes");
    setDispatcherRemark("");
    setReceivingNote("");
  };

  const pendingOrders = pendingData?.items ?? [];
  const dispatchedOrders = dispatchedData?.items ?? [];
  const transitOrders = transitData?.items ?? [];
  const deliveredOrders = deliveredData?.items ?? [];
  const signedOnlyOrders = signedData?.items ?? [];
  const [expandedOutsourceSuborders, setExpandedOutsourceSuborders] = useState<Set<number>>(new Set());
  const { data: allData } = trpc.order.list.useQuery(
    { pageSize: 200 },
    { refetchInterval: activeTab === "approval" ? NORMAL_POLL_INTERVAL : false, staleTime: 60_000 }
  );
  const allOrdersRaw = allData?.items ?? [];
  const allPreviewOrderIds = useMemo(() => allOrdersRaw.map((order: any) => order.id), [allOrdersRaw]);
  const { data: outsourceSuborderPreviewData } = trpc.order.getOutsourceSuborderPreviews.useQuery(
    { orderIds: allPreviewOrderIds.length > 0 ? allPreviewOrderIds : [0] },
    { enabled: allPreviewOrderIds.length > 0, staleTime: 30_000 }
  );
  const outsourceSuborderPreviewMap = useMemo(
    () => buildOutsourceSuborderPreviewMap(outsourceSuborderPreviewData?.items),
    [outsourceSuborderPreviewData],
  );
  const previewOrderIds = useMemo(() => {
    const ids = new Set<number>();
    outsourceSuborderPreviewMap.forEach((preview, orderId) => {
      if (preview?.parentOrders?.length > 0) ids.add(orderId);
    });
    return ids;
  }, [outsourceSuborderPreviewMap]);
  const isMergedLtlPickupOutsourceOrder = useCallback((order: any) => {
    if (!order || order.businessType !== "outsource") return false;
    const remarks = String(order.remarks || "");
    if (!remarks.includes("零担前段外请子链")) return false;
    const previewOrderId = order.orderId ?? order.id;
    if (typeof previewOrderId !== "number") return false;
    const preview = outsourceSuborderPreviewMap.get(previewOrderId);
    return (preview?.parentOrders?.length || 0) > 1;
  }, [outsourceSuborderPreviewMap]);
  const commandGroupLookup = useMemo<CommandGroupLookup>(() => {
    const byId = new Map<number, string>();
    const byOrderNumber = new Map<string, string>();

    for (const order of allOrdersRaw) {
      const groupKey = deriveCommandGroupKey(order);
      if (!groupKey) continue;

      const preview = outsourceSuborderPreviewMap.get(order.id);
      if (!preview || preview.parentOrders.length === 0) continue;

      for (const parentOrder of preview.parentOrders) {
        if (typeof parentOrder?.id === "number") {
          byId.set(parentOrder.id, groupKey);
        }

        const parentOrderNumber = typeof parentOrder?.orderNumber === "string"
          ? parentOrder.orderNumber.trim()
          : "";
        if (parentOrderNumber) {
          byOrderNumber.set(parentOrderNumber, groupKey);
        }

        const parentSystemCode = typeof parentOrder?.systemCode === "string"
          ? parentOrder.systemCode.trim()
          : "";
        if (parentSystemCode && !byOrderNumber.has(parentSystemCode)) {
          byOrderNumber.set(parentSystemCode, groupKey);
        }
      }
    }

    return { byId, byOrderNumber };
  }, [allOrdersRaw, outsourceSuborderPreviewMap]);
  const approvalGroupCarrierMap = useMemo(() => {
    const map = new Map<string, any>();
    for (const order of allOrdersRaw) {
      const groupKey = deriveCommandGroupKey(order);
      if (!groupKey) continue;

      const preview = outsourceSuborderPreviewMap.get(order.id);
      if (!preview || preview.parentOrders.length === 0) continue;

      const matchedParentOrder = preview.parentOrders.find((parentOrder: any) => {
        if (!parentOrder) return false;
        if (groupKey === `前段外请主单#${parentOrder.id}`) return true;
        const parentMergedPlanNumber = typeof parentOrder.mergedPlanNumber === "string"
          ? parentOrder.mergedPlanNumber.trim()
          : "";
        return parentMergedPlanNumber ? parentMergedPlanNumber === groupKey : false;
      }) ?? preview.parentOrders[0];

      if (!matchedParentOrder) continue;
      if (!map.has(groupKey)) map.set(groupKey, matchedParentOrder);
    }
    return map;
  }, [allOrdersRaw, outsourceSuborderPreviewMap]);
  const approvalItems = useMemo(
    () => normalizeCommandGroupItems(approvalData?.items, commandGroupLookup),
    [approvalData, commandGroupLookup],
  );
  const toggleOutsourceSuborderPreview = useCallback((orderId: number) => {
    setExpandedOutsourceSuborders((prev) => {
      const next = new Set(prev);
      if (next.has(orderId)) next.delete(orderId);
      else next.add(orderId);
      return next;
    });
  }, []);
  // 回单跟踪合并已送达+已签收订单
  const signedOrders = [...deliveredOrders, ...signedOnlyOrders];
  // 回单跟踪Tab的合并组回单进度查询
  const podTrackingMpns = useMemo(() => {
    const mpns = new Set<string>();
    for (const o of signedOrders) {
      if ((o as any).mergedPlanNumber) mpns.add((o as any).mergedPlanNumber);
    }
    return Array.from(mpns);
  }, [signedOrders]);
  const { data: podTrackingProgressMap } = trpc.pod.checkGroupsReceived.useQuery(
    { mergedPlanNumbers: podTrackingMpns },
    { enabled: podTrackingMpns.length > 0, refetchInterval: getTabPollInterval("pod-processing", NORMAL_POLL_INTERVAL), staleTime: 15_000 }
  );
  // 搜索过滤函数数
  const searchFilter = useCallback((orders: any[], keyword: string) => {
    if (!keyword.trim()) return orders;
    const kw = keyword.toLowerCase();
    return orders.filter((o: any) =>
      (o.orderNumber || "").toLowerCase().includes(kw) ||
      (o.systemCode || "").toLowerCase().includes(kw) ||
      (o.customerName || "").toLowerCase().includes(kw) ||
      (o.goodsType || "").toLowerCase().includes(kw) ||
      (o.originCity || "").toLowerCase().includes(kw) ||
      (o.destinationCity || "").toLowerCase().includes(kw) ||
      (o.plateNumber || "").toLowerCase().includes(kw) ||
      (o.driverName || "").toLowerCase().includes(kw) ||
      (o.mergedPlanNumber || "").toLowerCase().includes(kw)
    );
  }, []);

  const filteredPendingOrders = useMemo(() => searchFilter(pendingOrders, pendingSearch), [pendingOrders, pendingSearch, searchFilter]);
  const filteredApprovalOrders = useMemo(() => searchFilter(approvalItems, approvalSearch), [approvalItems, approvalSearch, searchFilter]);
  const filteredDispatchedOrders = useMemo(() => searchFilter(dispatchedOrders, dispatchedSearch), [dispatchedOrders, dispatchedSearch, searchFilter]);
  const filteredSignedOrders = useMemo(() => searchFilter(signedOrders, podSearch), [signedOrders, podSearch, searchFilter]);
  const [approvalGroupByPlan, setApprovalGroupByPlan] = useState(true);
  const {
    groupedData: approvalGrouped,
    expandedGroups: approvalExpanded,
    toggleGroup: toggleApprovalGroup,
  } = useMergedPlanGroups(filteredApprovalOrders, approvalGroupByPlan);
  const approvalDisplayGrouped = useMemo(
    () => flattenSingleItemCommandGroups(approvalGrouped, previewOrderIds),
    [approvalGrouped, previewOrderIds],
  );
  const approvalGroupGuide = useMemo(() => getCommandGroupGuide("approval"), []);
  const approvalCurrentSelectableOrderIds = useMemo(
    () => Array.from(new Set(
      filteredApprovalOrders
        .map((item: any) => item.orderId ?? item.id)
        .filter((id: unknown): id is number => typeof id === "number")
    )),
    [filteredApprovalOrders],
  );
  const approvalCurrentSelectedOrderIds = useMemo(
    () => approvalCurrentSelectableOrderIds.filter((id) => selectedIds.has(id)),
    [approvalCurrentSelectableOrderIds, selectedIds],
  );

  // 待找车Tab排序
  const pendingSortGetters = useMemo(() => ({
    createdAt: (o: any) => o.createdAt ? new Date(o.createdAt).getTime() : 0,
    weight: (o: any) => parseFloat(o.weight) || 0,
    dispatchPrice: (o: any) => parseFloat(o.dispatchPrice) || 0,
    customerName: (o: any) => o.customerName || "",
    isUrgent: (o: any) => o.isUrgent ? 1 : 0,
  }), []);
  const { sorted: sortedPendingOrders, sort: pendingSort, toggleSort: togglePendingSort } = useTableSort(filteredPendingOrders, pendingSortGetters);

  // 确认派车Tab排序
  const dispatchedSortGetters = useMemo(() => ({
    createdAt: (o: any) => o.createdAt ? new Date(o.createdAt).getTime() : 0,
    weight: (o: any) => parseFloat(o.weight) || 0,
    dispatchPrice: (o: any) => parseFloat(o.dispatchPrice) || 0,
    actualFreight: (o: any) => parseFloat(o.actualFreight) || 0,
    customerName: (o: any) => o.customerName || "",
  }), []);
  const { sorted: sortedDispatchedOrders, sort: dispatchedSort, toggleSort: toggleDispatchedSort } = useTableSort(filteredDispatchedOrders, dispatchedSortGetters);

  // 回单跟踪Tab排序
  const podSortGetters = useMemo(() => ({
    createdAt: (o: any) => o.createdAt ? new Date(o.createdAt).getTime() : 0,
    weight: (o: any) => parseFloat(o.weight) || 0,
    status: (o: any) => o.status || "",
    podStatus: (o: any) => getOrderPodBusinessStatus(o),
    customerName: (o: any) => o.customerName || "",
  }), []);
  const { sorted: sortedSignedOrders, sort: podSort, toggleSort: togglePodSort } = useTableSort(filteredSignedOrders, podSortGetters);
  const [expandedPodGroups, setExpandedPodGroups] = useState<Set<string>>(new Set());
  const togglePodGroup = (key: string) => {
    setExpandedPodGroups(prev => {
      const next = new Set(prev);
      if (next.has(key)) next.delete(key);
      else next.add(key);
      return next;
    });
  };
  const groupedSignedOrders = useMemo(() => {
    const groups: Map<string, any[]> = new Map();
    const ungrouped: any[] = [];
    for (const order of sortedSignedOrders) {
      const key = getDispatchGroupKey(order);
      const items = groups.get(key) || [];
      items.push(order);
      groups.set(key, items);
    }
    const grouped = Array.from(groups.entries()).flatMap(([key, items]) => {
      if (items.length <= 1) {
        ungrouped.push(items[0]);
        return [];
      }
      const primaryOrder = items[0] as any;
      const progress = primaryOrder?.mergedPlanNumber ? podTrackingProgressMap?.[primaryOrder.mergedPlanNumber] : null;
      const derivedSentCount = getPodSentProgressCount(items);
      return [{
        key,
        items,
        groupHeadline: getDispatchHeadline(primaryOrder),
        groupSubline: getDispatchSubline(primaryOrder),
        customerCargoSummary: getGroupCustomerCargoSummary(items),
        routeSummary: getGroupRouteSummary(items),
        vehicleSummary: `${primaryOrder?.plateNumber || "-"} / ${primaryOrder?.driverName || "-"}`,
        sentCount: progress?.sentCount ?? derivedSentCount,
        totalCount: progress?.totalCount ?? items.length,
        allPodsSent: progress?.allSent ?? derivedSentCount >= items.length,
      }];
    });
    return { groups: grouped, ungrouped };
  }, [sortedSignedOrders, podTrackingProgressMap]);

  // 待找车队列合并计划号分组
  const [groupByPlan, setGroupByPlan] = useState(true);
  const { groupedData: pendingGrouped, expandedGroups: pendingExpanded, toggleGroup: togglePendingGroup } = useMergedPlanGroups(filteredPendingOrders, groupByPlan);

  const renderOutsourceSuborderPreview = useCallback((order: any) => {
    const previewOrderId = order.orderId ?? order.id;
    const preview = outsourceSuborderPreviewMap.get(previewOrderId);
    if (!preview || preview.parentOrders.length === 0) return null;
    const isExpanded = expandedOutsourceSuborders.has(previewOrderId);
    return (
      <>
        <Button
          size="sm"
          variant="ghost"
          className="h-7 px-2 text-blue-600 hover:bg-blue-50 hover:text-blue-700"
          onClick={(event) => {
            event.stopPropagation();
            toggleOutsourceSuborderPreview(previewOrderId);
          }}
        >
          {isExpanded ? <ChevronDown className="h-3.5 w-3.5 mr-1" /> : <ChevronRight className="h-3.5 w-3.5 mr-1" />}
          关联主单{preview.parentOrders.length}单
        </Button>
        {isExpanded && (
          <div className="mt-2 rounded-lg border border-blue-100 bg-blue-50/60 p-2 text-xs text-slate-700">
            <div className="mb-2 font-medium text-blue-700">零担外请关联主单</div>
            <div className="space-y-2">
              {preview.parentOrders.map((parent: any) => (
                <div key={parent.id} className="rounded-md border border-blue-100 bg-white/90 px-2 py-2">
                  <div className="flex items-center justify-between gap-2">
                    <span className="font-mono text-[11px] text-slate-700">{parent.orderNumber || parent.systemCode || `#${parent.id}`}</span>
                    <Badge variant="outline" className="text-[10px]">{getOrderStatusLabel(parent.status)}</Badge>
                  </div>
                  <div className="mt-1 text-[11px] text-slate-600">{parent.customerName || "-"} · {parent.cargoName || "-"}</div>
                  <div className="mt-1 text-[11px] text-slate-500">{parent.originCity || "-"} → {parent.destinationCity || "-"} · {parent.weight ? `${parent.weight}t` : "-"}</div>
                  <div className="mt-1 flex flex-wrap items-center gap-2 text-[10px] text-slate-500">
                    <span>调度价 {parent.dispatchPrice ? formatMoney(parent.dispatchPrice) : "-"}</span>
                    <span>收货备注 {getApprovalReceivingSummary(parent) || "-"}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </>
    );
  }, [expandedOutsourceSuborders, outsourceSuborderPreviewMap, toggleOutsourceSuborderPreview]);

  const handleDispatch = (order: any) => {
    setDispatchDialog(order);
    resetForm();
  };

  const openGroupApprovalDialog = (items: any[], action: "approve" | "reject") => {
    if (items.length === 1 && isMergedChildOrder(items[0])) {
      toast.error("当前是组合单子订单，请在组头统一整组审批");
      return;
    }
    const orderIds = items
      .map((item: any) => item.orderId ?? item.id)
      .filter((id: unknown): id is number => typeof id === "number");
    setSelectedIds(new Set(orderIds));
    setBatchApproveAction(action);
    setBatchApproveComment("");
    setBatchApproveOpen(true);
  };

  const handlePlateBlur = async () => {
    if (!vehiclePlate.trim()) return;
    try {
      const result = await vehicleSearch.mutateAsync({ plateNumber: vehiclePlate.trim() });
      if (result.driver) {
        setDriverName(result.driver.name || "");
        setDriverPhone(result.driver.phone || "");
        toast.info("已匹配到司机信息");
      }
    } catch { /* new plate */ }
  };

  const mergedLtlPickupNeedsApproval = useMemo(() => {
    if (!dispatchDialog) return false;
    return isMergedLtlPickupOutsourceOrder(dispatchDialog);
  }, [dispatchDialog, isMergedLtlPickupOutsourceOrder]);

  // 判断是否需要审批：零担前段合并外请必须审批；其余仍按运费>原定价(quotedPrice) 或 运费>调度价(dispatchPrice) 或 有备注
  const needsApproval = useMemo(() => {
    if (!dispatchDialog) return false;
    if (mergedLtlPickupNeedsApproval) return true;
    const hasRemark = dispatcherRemark.trim().length > 0;
    if (hasRemark) return true;
    const freight = parseFloat(quotePrice) || 0;
    const quoted = parseFloat(dispatchDialog.quotedPrice) || 0;
    const dispatch = parseFloat(dispatchDialog.dispatchPrice) || 0;
    if (quoted > 0 && freight > quoted) return true;
    if (dispatch > 0 && freight > dispatch) return true;
    return false;
  }, [dispatchDialog, mergedLtlPickupNeedsApproval, quotePrice, dispatcherRemark]);

  const confirmDispatch = () => {
    if (!dispatchDialog) return;
    if (!depositAmount && depositAmount !== "0") {
      toast.error("请填写押金金额（无押金请填0）");
      setDepositError(true);
      return;
    }
    setDepositError(false);
    const noteVal = dispatchDialog.receivingNote || "";
    const targetStatus = needsApproval ? "pending_approval" : "dispatched";

    updateStatus.mutate({
      id: dispatchDialog.id,
      status: targetStatus,
      actualFreight: quotePrice || undefined,
      depositAmount: depositAmount,
      depositRefundable: depositRefundable === "yes",
      dispatcherRemark: dispatcherRemark.trim() || undefined,
      receivingNote: noteVal.trim() || undefined,
    });
  };

  return (
    <DashboardLayout>
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-xl font-semibold flex items-center gap-2">
              <Truck className="h-5 w-5 text-primary" />
              找车台
            </h1>
            <p className="text-sm text-muted-foreground mt-0.5">
              联系外部车队 → 录入车辆+报价+押金 → 提交审批/直接确认
            </p>
          </div>
          <div className="flex items-center gap-2 flex-wrap">
            {activeTab === "pending" && selectedIds.size > 0 && (
              <Button size="sm" variant="outline" className="text-blue-600 border-blue-300 hover:bg-blue-50" onClick={() => {
                const selectedOrders = pendingOrders.filter((o: any) => selectedIds.has(o.id));
                const noNote = selectedOrders.filter((o: any) => !o.receivingNote?.trim());
                if (noNote.length > 0) {
                  toast.error(`请先填写收货备注（${noNote.length}个订单未填写），再进行找车`);
                  return;
                }
                setBatchDispatchOpen(true);
              }}>
                <Truck className="h-4 w-4 mr-1" />
                批量找车+报价 ({selectedIds.size})
              </Button>
            )}
            {activeTab === "approval" && approvalCurrentSelectedOrderIds.length > 0 && hasPermission("approval.execute") && (
              <>
                <Button
                  size="sm"
                  className="bg-green-600 hover:bg-green-700 text-white"
                  onClick={() => openGroupApprovalDialog(
                    filteredApprovalOrders.filter((item: any) => approvalCurrentSelectedOrderIds.includes(item.orderId ?? item.id)),
                    "approve",
                  )}
                >
                  <CheckCircle2 className="h-4 w-4 mr-1" />
                  批量审批通过 ({approvalCurrentSelectedOrderIds.length})
                </Button>
                <Button
                  size="sm"
                  variant="outline"
                  className="border-red-300 text-red-600 hover:bg-red-50"
                  onClick={() => openGroupApprovalDialog(
                    filteredApprovalOrders.filter((item: any) => approvalCurrentSelectedOrderIds.includes(item.orderId ?? item.id)),
                    "reject",
                  )}
                >
                  <XCircle className="h-4 w-4 mr-1" />
                  批量驳回 ({approvalCurrentSelectedOrderIds.length})
                </Button>
              </>
            )}
            {/* 更多流程操作按钮已移除 */}
            <Button variant="outline" size="sm" onClick={() => { refetchPending(); refetchApproval(); refetchDispatched(); refetchTransit(); refetchDelivered(); refetchSigned(); refetchDeposit(); refetchStats(); }}>
              <RefreshCw className="h-4 w-4 mr-1" />
              刷新
            </Button>
          </div>
        </div>

        {/* 统计 */}
        <div className="grid grid-cols-2 md:grid-cols-7 gap-3">
          <Card>
            <CardContent className="p-3 flex items-center gap-3">
              <div className="p-2 rounded-lg bg-red-100">
                <Search className="h-4 w-4 text-red-600" />
              </div>
              <div>
                <div className="text-xs text-muted-foreground">待找车</div>
                <div className="text-lg font-bold text-red-600">{pendingOrders.length}</div>
              </div>
            </CardContent>
          </Card>
          <Card>
            <CardContent className="p-3 flex items-center gap-3">
              <div className="p-2 rounded-lg bg-purple-100">
                <DollarSign className="h-4 w-4 text-purple-600" />
              </div>
              <div>
                <div className="text-xs text-muted-foreground">待审批</div>
                <div className="text-lg font-bold text-purple-600">{approvalItems.length}</div>
              </div>
            </CardContent>
          </Card>
          <Card>
            <CardContent className="p-3 flex items-center gap-3">
              <div className="p-2 rounded-lg bg-blue-100">
                <Truck className="h-4 w-4 text-blue-600" />
              </div>
              <div>
                <div className="text-xs text-muted-foreground">已调度</div>
                <div className="text-lg font-bold">{dispatchedOrders.length}</div>
              </div>
            </CardContent>
          </Card>
          <Card>
            <CardContent className="p-3 flex items-center gap-3">
              <div className="p-2 rounded-lg bg-green-100">
                <Truck className="h-4 w-4 text-green-600" />
              </div>
              <div>
                <div className="text-xs text-muted-foreground">待送达</div>
                <div className="text-lg font-bold">{dispatchedOrders.length + transitOrders.length}</div>
              </div>
            </CardContent>
          </Card>
          <Card className="border-amber-200 bg-amber-50/40">
            <CardContent className="p-3 flex items-center justify-between gap-3">
              <div className="flex items-center gap-3">
                <div className="p-2 rounded-lg bg-amber-100">
                  <FileCheck className="h-4 w-4 text-amber-600" />
                </div>
                <div>
                  <div className="text-xs text-muted-foreground">回单待处理</div>
                  <div className="text-lg font-bold text-amber-600">{getPodTrackingPendingCount(signedOrders)}</div>
                  <div className="text-[11px] text-amber-700">在找车台“回单处理”页签继续完成原件寄出、财务确认衔接与押金闭环</div>
                </div>
              </div>
              <Button size="sm" variant="outline" className="border-amber-300 text-amber-700 hover:bg-amber-100" onClick={() => setActiveTab("pod-processing")}>前往处理</Button>
            </CardContent>
          </Card>
          <Card className="border-red-200 bg-red-50/30">
            <CardContent className="p-3 flex items-center justify-between gap-3">
              <div className="flex items-center gap-3">
                <div className="p-2 rounded-lg bg-red-100">
                  <DollarSign className="h-4 w-4 text-red-600" />
                </div>
                <div>
                  <div className="text-xs text-muted-foreground">待处理押金</div>
                  <div className="text-lg font-bold text-red-700">{stats.pendingCount} 笔</div>
                  <div className="text-sm font-semibold text-red-600">¥{parseFloat(stats.pendingTotal).toLocaleString("zh-CN", { minimumFractionDigits: 2 })}</div>
                </div>
              </div>
              <Button size="sm" variant="outline" className="border-red-300 text-red-700 hover:bg-red-100" onClick={() => setActiveTab("pod-processing")}>查看处理台</Button>
            </CardContent>
          </Card>
          <Card className="border-orange-200 bg-orange-50/40">
            <CardContent className="p-3 flex items-center justify-between gap-3">
              <div className="flex items-center gap-3">
                <div className="p-2 rounded-lg bg-orange-100">
                  <Siren className="h-4 w-4 text-orange-600" />
                </div>
                <div>
                  <div className="text-xs text-muted-foreground">超期回单监控</div>
                  <div className="text-lg font-bold text-orange-700">{outsourceOverdueData.total} 笔</div>
                  <div className="text-[11px] text-orange-700">黄 {outsourceOverdueData.yellow} / 橙 {outsourceOverdueData.orange} / 红 {outsourceOverdueData.red}</div>
                </div>
              </div>
              <Button size="sm" variant="outline" className="border-orange-300 text-orange-700 hover:bg-orange-100" onClick={() => setLocation("/station/pod-deposit")}>查看监控</Button>
            </CardContent>
          </Card>
        </div>

        <Tabs value={activeTab} onValueChange={setActiveTab}>
          <TabsList>
            <TabsTrigger value="pending">
              待找车
              {pendingOrders.length > 0 && (
                <Badge variant="destructive" className="ml-1.5 h-4 min-w-4 text-[10px] px-1">
                  {pendingOrders.length}
                </Badge>
              )}
            </TabsTrigger>
            <TabsTrigger value="approval">
              待审批
              {approvalItems.length > 0 && (
                <Badge className="ml-1.5 h-4 min-w-4 text-[10px] px-1 bg-purple-500">
                  {approvalItems.length}
                </Badge>
              )}
            </TabsTrigger>
            <TabsTrigger value="dispatched">确认派车 {dispatchedOrders.length > 0 && <Badge className="ml-1.5 h-4 min-w-4 text-[10px] px-1 bg-amber-500">{dispatchedOrders.length}</Badge>}</TabsTrigger>
            <TabsTrigger value="pod-processing">
              回单处理
              {Math.max(getPodTrackingPendingCount(signedOrders), stats.pendingCount) > 0 && (
                <Badge className="ml-1.5 h-4 min-w-4 text-[10px] px-1 bg-blue-600">
                  {Math.max(getPodTrackingPendingCount(signedOrders), stats.pendingCount)}
                </Badge>
              )}
            </TabsTrigger>
          </TabsList>

          <div className="mt-3 mb-3 rounded-xl border border-blue-200 bg-blue-50/70 px-4 py-3 text-xs text-blue-900">
            <div className="font-medium text-blue-800">当前页面分工说明</div>
            <div className="mt-1 leading-5 text-blue-700">
              找车台现已统一收口为<strong>待找车、待审批、确认派车、回单处理</strong>四个页签。其中“回单处理”承接原件寄出标记、等待财务确认、退押金等外请闭环动作；财务回单确认台仅保留确认收到、标记寄出/撤销寄出、超期监控等回单状态维护能力。
            </div>
          </div>

          {/* 待找车 */}
          <TabsContent value="pending">
            <div className="flex items-center gap-2 mb-3">
              <div className="relative min-w-[200px]">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                <Input placeholder="搜索订单号/客户/路线..." value={pendingSearch} onChange={(e) => setPendingSearch(e.target.value)} className="pl-9 h-8" />
              </div>
              <Button
                variant={groupByPlan ? "default" : "outline"}
                size="sm"
                className="h-8 text-xs"
                onClick={() => setGroupByPlan(!groupByPlan)}
              >
                {groupByPlan ? <Layers className="h-3 w-3 mr-1" /> : <List className="h-3 w-3 mr-1" />}
                {groupByPlan ? "分组" : "列表"}
              </Button>
            </div>
            <Card>
              <CardContent className="p-0">
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8"><Checkbox checked={sortedPendingOrders.length > 0 && sortedPendingOrders.every((o: any) => selectedIds.has(o.id))} onCheckedChange={() => { if (sortedPendingOrders.every((o: any) => selectedIds.has(o.id))) { const next = new Set(selectedIds); sortedPendingOrders.forEach((o: any) => next.delete(o.id)); setSelectedIds(next); } else { const next = new Set(selectedIds); sortedPendingOrders.forEach((o: any) => next.add(o.id)); setSelectedIds(next); } }} /></TableHead>
                      <TableHead>客户订单号</TableHead>
                      <SortableHeader sortKey="customerName" currentSort={pendingSort} onToggle={togglePendingSort}>客户 · 货物</SortableHeader>
                      <TableHead>路线</TableHead>
                      <SortableHeader sortKey="weight" currentSort={pendingSort} onToggle={togglePendingSort}>吨位</SortableHeader>
                      <SortableHeader sortKey="dispatchPrice" currentSort={pendingSort} onToggle={togglePendingSort}>调度价</SortableHeader>
                      <SortableHeader sortKey="createdAt" currentSort={pendingSort} onToggle={togglePendingSort}>下单日期</SortableHeader>
                      <SortableHeader sortKey="isUrgent" currentSort={pendingSort} onToggle={togglePendingSort}>紧急</SortableHeader>
                      <TableHead>📌 收货备注</TableHead>
                      <TableHead>操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredPendingOrders.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={10} className="text-center py-8 text-muted-foreground">
                          暂无待找车订单。待找车阶段按参考批次整理；确认派车后会切换为正式外请分组/车次口径展示。
                        </TableCell>
                      </TableRow>
                    ) : groupByPlan && pendingGrouped ? (
                      <>
                        {Array.from(pendingGrouped.groups.entries()).map(([planNumber, groupOrders]) => {
                          const isExpanded = pendingExpanded.has(planNumber);
                          const totalWeight = groupOrders.reduce((sum: number, o: any) => sum + parseFloat(o.weight || "0"), 0);
                          const destinations = Array.from(new Set(groupOrders.map((o: any) => o.destinationCity).filter(Boolean)));
                          const rejectedOrders = groupOrders.filter((o: any) => getLatestReturnReason(o));
                          const latestRejectedOrder = rejectedOrders.reduce((latest: any, current: any) => {
                            if (!latest) return current;
                            const latestTime = latest?.lastReturnAt ? new Date(latest.lastReturnAt).getTime() : 0;
                            const currentTime = current?.lastReturnAt ? new Date(current.lastReturnAt).getTime() : 0;
                            return currentTime > latestTime ? current : latest;
                          }, null);
                          return (
                            <React.Fragment key={planNumber}>
                              <TableRow
                                className="bg-blue-50 hover:bg-blue-100/80 cursor-pointer border-l-2 border-l-blue-500"
                                onClick={() => togglePendingGroup(planNumber)}
                              >
                                <TableCell onClick={(e: React.MouseEvent) => e.stopPropagation()}>
                                  <Checkbox
                                    checked={groupOrders.every((o: any) => selectedIds.has(o.id))}
                                    onCheckedChange={() => {
                                      const allSelected = groupOrders.every((o: any) => selectedIds.has(o.id));
                                      setSelectedIds(prev => {
                                        const next = new Set(prev);
                                        groupOrders.forEach((o: any) => allSelected ? next.delete(o.id) : next.add(o.id));
                                        return next;
                                      });
                                    }}
                                  />
                                </TableCell>
                                <TableCell>
                                  <div className="space-y-1">
                                    <div className="flex items-center gap-2">
                                      {isExpanded ? <ChevronDown className="h-4 w-4 text-blue-600" /> : <ChevronRight className="h-4 w-4 text-blue-600" />}
                                      <Layers className="h-4 w-4 text-blue-600" />
                                      <span className="font-bold text-blue-700">待找车参考批次 {planNumber}</span>
                                      <Badge variant="outline" className="text-[10px] px-1.5 bg-blue-100 text-blue-700 border-blue-300">
                                        {groupOrders.length}单
                                      </Badge>
                                      <Badge variant="outline" className="text-[10px] px-1.5 bg-white text-blue-700 border-blue-200">
                                        待确认派车后生成正式外请分组
                                      </Badge>
                                    </div>
                                    <div className="text-[10px] text-blue-700/80">当前仅作待找车内部整理参考，不作为回单、押金与财务处理口径。</div>
                                    {latestRejectedOrder && (
                                      <div className="rounded-md border border-amber-200 bg-amber-50/90 px-2 py-1 text-[10px] text-amber-800">
                                        <div className="font-medium">最近驳回 {rejectedOrders.length} 单：{getLatestReturnReason(latestRejectedOrder)}</div>
                                        {getLatestReturnMeta(latestRejectedOrder) && (
                                          <div className="mt-0.5 text-[10px] text-amber-700/80">{getLatestReturnMeta(latestRejectedOrder)}</div>
                                        )}
                                      </div>
                                    )}
                                  </div>
                                </TableCell>
                                <TableCell className="text-xs">
                                  {(() => {
                                    const customers = Array.from(new Set(groupOrders.map((o: any) => o.customerName).filter(Boolean)));
                                    const cargos = Array.from(new Set(groupOrders.map((o: any) => o.cargoName).filter(Boolean)));
                                    return `${customers.join("/") || "-"} · ${cargos.join("/") || "-"}`;
                                  })()}
                                </TableCell>
                                <TableCell className="text-sm">
                                  {groupOrders[0]?.originCity || "-"} → {destinations.length <= 2 ? destinations.join("、") : `${destinations[0]}等${destinations.length}地`}
                                </TableCell>
                                <TableCell className="text-sm font-bold text-blue-700">{totalWeight.toFixed(3)}t</TableCell>
                                <TableCell className="text-xs text-orange-600 font-medium">
                                  {formatMoney(groupOrders.reduce((sum: number, o: any) => sum + (parseFloat(o.dispatchPrice) || 0), 0).toString())}
                                </TableCell>
                                <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">
                                  <div>{fmtShort(groupOrders[0]?.orderDate || groupOrders[0]?.createdAt)}</div>
                                  <div className="text-[10px] text-orange-500">{daysAgo(groupOrders[0]?.orderDate || groupOrders[0]?.createdAt)}</div>
                                </TableCell>
                                <TableCell>
                                  {groupOrders.some((o: any) => o.isUrgent) && (
                                    <Badge variant="destructive" className="text-[10px]">
                                      <AlertTriangle className="h-3 w-3 mr-0.5" />加急
                                    </Badge>
                                  )}
                                </TableCell>
                                <TableCell onClick={(e: React.MouseEvent) => e.stopPropagation()}>
                                  <InlineEdit
                                    value={groupOrders[0]?.receivingNote || ""}
                                    placeholder="填写收货备注（同步全部子单）"
                                    onSave={(val) => {
                                      groupOrders.forEach((o: any) => updateOrderFields.mutate({ id: o.id, receivingNote: val }));
                                      toast.success(`已同步收货备注到 ${groupOrders.length} 个子订单`);
                                    }}
                                    className="max-w-[220px] text-wrap-safe table-text-compact"
                                    highlight
                                  />
                                </TableCell>
                                <TableCell onClick={(e: React.MouseEvent) => e.stopPropagation()}>
                                  <Button size="sm" onClick={() => {
                                    // 检查所有子单是否已填写收货备注
                                    const noNote = groupOrders.filter((o: any) => !o.receivingNote?.trim());
                                    if (noNote.length > 0) {
                                      toast.error(`请先填写收货备注（${noNote.length}个子单未填写），可在合并订单行统一填写`);
                                      return;
                                    }
                                    const next = new Set(selectedIds);
                                    groupOrders.forEach((o: any) => next.add(o.id));
                                    setSelectedIds(next);
                                    setBatchDispatchOpen(true);
                                  }}>
                                    <Search className="h-3 w-3 mr-1" />整组找车
                                  </Button>
                                </TableCell>
                              </TableRow>
                              {isExpanded && groupOrders.map((order: any) => (
                                <TableRow
                                  key={order.id}
                                  className={`${order.isUrgent ? "bg-red-50/50" : "bg-blue-50/30"} border-l-2 border-l-blue-200`}
                                >
                                  <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                                  <TableCell className="table-cell-readable font-mono text-xs align-top">
                                    <div className="flex flex-col gap-1">
                                      <div><span className="text-muted-foreground pl-2">└</span> {order.orderNumber || order.systemCode}</div>
                                      {getLatestReturnReason(order) && (
                                        <div className="rounded-md border border-amber-200 bg-amber-50/90 px-2 py-1 text-[10px] text-amber-800">
                                          <div className="flex items-center gap-1 font-medium"><TrendingDown className="h-3 w-3" />最近驳回原因</div>
                                          <div className="mt-0.5 break-words">{getLatestReturnReason(order)}</div>
                                          {getLatestReturnMeta(order) && <div className="mt-0.5 text-[10px] text-amber-700/80">{getLatestReturnMeta(order)}</div>}
                                        </div>
                                      )}
                                      {renderOutsourceSuborderPreview(order)}
                                    </div>
                                  </TableCell>
                                  <TableCell className="text-xs">
                                    {order.customerName} · {order.cargoName}
                                  </TableCell>
                                  <TableCell className="text-xs">
                                    <span className="flex items-center gap-1">
                                      {order.originCity} <ArrowRight className="h-3 w-3" /> {order.destinationCity}
                                    </span>
                                  </TableCell>
                                  <TableCell className="text-xs">
                            <div>{order.weight ? `${order.weight}t` : "-"}</div>
                            {order.chargeableWeight ? <div className="mt-1 text-[11px] text-muted-foreground">计费：{order.chargeableWeight}t</div> : null}
                          </TableCell>
                                  <TableCell className="text-xs font-medium text-orange-600">
                                    {formatMoney(order.dispatchPrice)}
                                  </TableCell>
                                  <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">
                                    {fmtShort(order.orderDate || order.createdAt)}
                                  </TableCell>
                                  <TableCell>
                                    {order.isUrgent && (
                                      <Badge variant="destructive" className="text-[10px]">
                                        <AlertTriangle className="h-3 w-3 mr-0.5" />加急
                                      </Badge>
                                    )}
                                  </TableCell>
                                  <TableCell>
                                    {(order as any).receivingNote ? (
                                      <div className="flex items-center gap-1">
                                        <span className="table-text-compact text-orange-700 text-wrap-safe max-w-[220px] leading-5" title={(order as any).receivingNote}>{(order as any).receivingNote}</span>
                                        <Button size="sm" variant="ghost" className="h-6 w-6 p-0 text-orange-500" onClick={() => setReceivingNoteOrder(order)} title="编辑收货备注">
                                          <FileText className="h-3 w-3" />
                                        </Button>
                                      </div>
                                    ) : (
                                      <Button size="sm" variant="outline" className="h-7 text-xs text-orange-600 border-orange-300 hover:bg-orange-50" onClick={() => setReceivingNoteOrder(order)}>
                                        <FileText className="h-3 w-3 mr-1" />填写
                                      </Button>
                                    )}
                                  </TableCell>
                                  <TableCell>
                                    <div className="flex items-center gap-1">
                                      <Button size="sm" onClick={() => {
                                        if (!(order as any).receivingNote?.trim()) {
                                          toast.error("请先填写收货备注再找车");
                                          return;
                                        }
                                        handleDispatch(order);
                                      }}>
                                        <Search className="h-3 w-3 mr-1" />找车+报价
                                      </Button>
                                      <DangerActionMenu
                                        onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(order) : undefined}
                                        rollbackDisabled={Boolean(getRollbackLockReason(order))}
                                        onDelete={hasPermission("order.delete") ? () => openDeleteDialog(order) : undefined}
                                        deleteDisabled={Boolean(getDeleteLockReason(order))}
                                      />
                                    </div>
                                  </TableCell>
                                </TableRow>
                              ))}
                            </React.Fragment>
                          );
                        })}
                        {pendingGrouped.ungrouped.map((order: any) => (
                          <TableRow
                            key={order.id}
                            className={order.isUrgent ? "bg-red-50 border-l-2 border-l-red-500" : ""}
                          >
                            <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                            <TableCell className="font-mono text-xs">
                              <div className="flex flex-col gap-1">
                                <div>{order.orderNumber || order.systemCode}</div>
                                {getLatestReturnReason(order) && (
                                  <div className="rounded-md border border-amber-200 bg-amber-50/90 px-2 py-1 text-[10px] text-amber-800">
                                    <div className="flex items-center gap-1 font-medium"><TrendingDown className="h-3 w-3" />最近驳回原因</div>
                                    <div className="mt-0.5 break-words">{getLatestReturnReason(order)}</div>
                                    {getLatestReturnMeta(order) && <div className="mt-0.5 text-[10px] text-amber-700/80">{getLatestReturnMeta(order)}</div>}
                                  </div>
                                )}
                                {renderOutsourceSuborderPreview(order)}
                              </div>
                            </TableCell>
                            <TableCell className="text-xs">
                              {order.customerName} · {order.cargoName}
                            </TableCell>
                            <TableCell className="text-xs">
                              <span className="flex items-center gap-1">
                                {order.originCity} <ArrowRight className="h-3 w-3" /> {order.destinationCity}
                              </span>
                            </TableCell>
                            <TableCell className="text-xs">
                            <div>{order.weight ? `${order.weight}t` : "-"}</div>
                            {order.chargeableWeight ? <div className="mt-1 text-[11px] text-muted-foreground">计费：{order.chargeableWeight}t</div> : null}
                          </TableCell>
                            <TableCell className="text-xs font-medium text-orange-600">
                              {formatMoney(order.dispatchPrice)}
                            </TableCell>
                            <TableCell className="text-xs text-muted-foreground">
                              <div>{fmtShort(order.orderDate || order.createdAt)}</div>
                              <div className="text-[10px] text-orange-500">{daysAgo(order.orderDate || order.createdAt)}</div>
                            </TableCell>
                            <TableCell>
                              {order.isUrgent && (
                                <Badge variant="destructive" className="text-[10px]">
                                  <AlertTriangle className="h-3 w-3 mr-0.5" />加急
                                </Badge>
                              )}
                            </TableCell>
                            <TableCell>
                              {(order as any).receivingNote ? (
                                <div className="flex items-center gap-1">
                                  <span className="table-text-compact text-orange-700 text-wrap-safe max-w-[220px] leading-5" title={(order as any).receivingNote}>{(order as any).receivingNote}</span>
                                  <Button size="sm" variant="ghost" className="h-6 w-6 p-0 text-orange-500" onClick={() => setReceivingNoteOrder(order)} title="编辑收货备注">
                                    <FileText className="h-3 w-3" />
                                  </Button>
                                </div>
                              ) : (
                                <Button size="sm" variant="outline" className="h-7 text-xs text-orange-600 border-orange-300 hover:bg-orange-50" onClick={() => setReceivingNoteOrder(order)}>
                                  <FileText className="h-3 w-3 mr-1" />填写
                                </Button>
                              )}
                            </TableCell>
                            <TableCell>
                              <div className="flex items-center gap-1">
<Button size="sm" onClick={() => {
                                if (!(order as any).receivingNote?.trim()) {
                                  toast.error("请先填写收货备注再找车");
                                  return;
                                }
                                handleDispatch(order);
                              }}>
                                <Search className="h-3 w-3 mr-1" />找车+报价
                              </Button>
                                <DangerActionMenu
                                  onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(order) : undefined}
                                  rollbackDisabled={Boolean(getRollbackLockReason(order))}
                                  onDelete={hasPermission("order.delete") ? () => openDeleteDialog(order) : undefined}
                                  deleteDisabled={Boolean(getDeleteLockReason(order))}
                                />
                              </div>
                            </TableCell>
                          </TableRow>
                        ))}
                      </>
                    ) : (
                      filteredPendingOrders.map((order) => (
                        <TableRow
                          key={order.id}
                          className={order.isUrgent ? "bg-red-50 border-l-2 border-l-red-500" : ""}
                        >
                          <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                          <TableCell className="font-mono text-xs">{order.orderNumber || order.systemCode}</TableCell>
                          <TableCell className="text-xs">
                            <div>{order.customerName} · {order.cargoName}</div>
                            {(order.isLargeSlab || order.cargoSpec || order.chargeableWeight || order.packageCount || order.palletCount || order.specialRequirements || order.largeSlabShippingRequired) ? (
                              <div className="mt-2 rounded-md border border-amber-200 bg-amber-50/50 px-2.5 py-2 text-[11px] leading-5 text-slate-700">
                                <div className="mb-1 flex flex-wrap gap-1.5">
                                  {order.isLargeSlab ? (
                                    <Badge variant="outline" className="border-amber-300 bg-white text-[10px] text-amber-700">大板</Badge>
                                  ) : null}
                                  {order.largeSlabShippingRequired ? (
                                    <Badge variant="outline" className="border-orange-300 bg-orange-50 text-[10px] text-orange-700">按大板发货要求执行</Badge>
                                  ) : null}
                                </div>
                                {order.cargoSpec ? <div>规格：{order.cargoSpec}</div> : null}
                                {(order.palletCount || order.packageCount) ? <div>托/架数：{order.palletCount || 0} 托 / {order.packageCount || 0} 架</div> : null}
                                {order.chargeableWeight ? <div>计费重量：{order.chargeableWeight}t</div> : null}
                                {order.specialRequirements ? <div className="text-orange-600">特殊要求：{order.specialRequirements}</div> : null}
                              </div>
                            ) : null}
                          </TableCell>
                          <TableCell className="text-xs">
                            <span className="flex items-center gap-1">
                              {order.originCity} <ArrowRight className="h-3 w-3" /> {order.destinationCity}
                            </span>
                          </TableCell>
                          <TableCell className="text-xs">
                            <div>{order.weight ? `${order.weight}t` : "-"}</div>
                            {order.chargeableWeight ? <div className="mt-1 text-[11px] text-muted-foreground">计费：{order.chargeableWeight}t</div> : null}
                          </TableCell>
                          <TableCell className="text-xs font-medium text-orange-600">
                            {formatMoney(order.dispatchPrice)}
                          </TableCell>
                          <TableCell>
                            {order.isUrgent && (
                              <Badge variant="destructive" className="text-[10px]">
                                <AlertTriangle className="h-3 w-3 mr-0.5" />
                                加急
                              </Badge>
                            )}
                          </TableCell>
                          <TableCell>
                            {(order as any).receivingNote ? (
                              <div className="flex items-center gap-1">
                                <span className="table-text-compact text-orange-700 text-wrap-safe max-w-[220px] leading-5" title={(order as any).receivingNote}>{(order as any).receivingNote}</span>
                                <Button size="sm" variant="ghost" className="h-6 w-6 p-0 text-orange-500" onClick={() => setReceivingNoteOrder(order)} title="编辑收货备注">
                                  <FileText className="h-3 w-3" />
                                </Button>
                              </div>
                            ) : (
                              <Button size="sm" variant="outline" className="h-7 text-xs text-orange-600 border-orange-300 hover:bg-orange-50" onClick={() => setReceivingNoteOrder(order)}>
                                <FileText className="h-3 w-3 mr-1" />填写
                              </Button>
                            )}
                          </TableCell>
                          <TableCell>
                            <div className="flex items-center gap-1">
                              <Button size="sm" onClick={() => {
                                if (!(order as any).receivingNote?.trim()) {
                                  toast.error("请先填写收货备注再找车");
                                  return;
                                }
                                handleDispatch(order);
                              }}>
                                <Search className="h-3 w-3 mr-1" />
                                找车+报价
                              </Button>
                              <DangerActionMenu
                                onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(order) : undefined}
                                rollbackDisabled={Boolean(getRollbackLockReason(order))}
                                onDelete={hasPermission("order.delete") ? () => openDeleteDialog(order) : undefined}
                                deleteDisabled={Boolean(getDeleteLockReason(order))}
                              />
                            </div>
                          </TableCell>
                        </TableRow>
                      ))
                    )}
                  </TableBody>
                </Table>
                <TablePagination total={filteredPendingOrders.length} page={pendingPage} pageSize={pendingPageSize} onPageChange={setPendingPage} onPageSizeChange={setPendingPageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 待审批 */}
          <TabsContent value="approval">
            <div className="flex items-center gap-2 mb-3">
              <div className="relative min-w-[200px]">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                <Input placeholder="搜索订单号/客户/司机..." value={approvalSearch} onChange={(e) => setApprovalSearch(e.target.value)} className="pl-9 h-8" />
              </div>
            </div>
            <Card>
              <CardContent className="p-0">
                <Table className="table-fixed text-[11px] [&_th]:px-2 [&_th]:py-2 [&_td]:px-2 [&_td]:py-2">
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8">
                        <Checkbox
                          checked={approvalCurrentSelectableOrderIds.length > 0 && approvalCurrentSelectableOrderIds.every((id) => selectedIds.has(id))}
                          onCheckedChange={() => {
                            if (approvalCurrentSelectableOrderIds.every((id) => selectedIds.has(id))) setSelectedIds(new Set());
                            else setSelectedIds(new Set(approvalCurrentSelectableOrderIds));
                          }}
                        />
                      </TableHead>
                      <TableHead className="w-[150px]">客户订单号</TableHead>
                      <TableHead className="w-[180px]">审批重点</TableHead>
                      <TableHead className="w-[96px]">路线</TableHead>
                      <TableHead className="w-[160px]">价格决策</TableHead>
                      <TableHead className="w-[72px]">申请人</TableHead>
                      <TableHead className="w-[52px]">紧急</TableHead>
                      <TableHead className="w-[120px]">操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredApprovalOrders.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={8} className="text-center py-8 text-muted-foreground">
                          <CheckCircle2 className="h-8 w-8 mx-auto mb-2 text-green-400" />
                          暂无待审批事项
                        </TableCell>
                      </TableRow>
                    ) : approvalDisplayGrouped ? (
                      <>
                        {Array.from(approvalDisplayGrouped.groups.entries()).map(([planNumber, items]) => {
                          const isExpanded = approvalExpanded.has(planNumber);
                          const totalRequested = items.reduce((sum: number, item: any) => sum + Number(item.requestedAmount || 0), 0);
                          const hasUrgent = items.some((item: any) => item.isUrgent);
                          const itemOrderIds = items
                            .map((item: any) => item.orderId ?? item.id)
                            .filter((id: unknown): id is number => typeof id === "number");
                          const isMergedGroup = items.length > 1;
                          const carrierOrder = items.reduce((foundCarrier: any, item: any) => {
                            if (foundCarrier) return foundCarrier;
                            const itemOrderId = item.orderId ?? item.id;
                            if (typeof itemOrderId !== "number") return foundCarrier;
                            const preview = outsourceSuborderPreviewMap.get(itemOrderId);
                            if (!preview || preview.parentOrders.length === 0) return foundCarrier;
                            const matchedParentOrder = preview.parentOrders.find((parentOrder: any) => {
                              if (!parentOrder) return false;
                              if (planNumber === `前段外请主单#${parentOrder.id}`) return true;
                              const parentMergedPlanNumber = typeof parentOrder.mergedPlanNumber === "string"
                                ? parentOrder.mergedPlanNumber.trim()
                                : "";
                              return parentMergedPlanNumber ? parentMergedPlanNumber === planNumber : false;
                            }) ?? preview.parentOrders[0];
                            return matchedParentOrder ?? foundCarrier;
                          }, approvalGroupCarrierMap.get(planNumber) ?? null);
                          const carrierOrderId = typeof carrierOrder?.id === "number" ? carrierOrder.id : null;
                          const leadApprovalItem = items[0];
                          const leadItem = carrierOrder ?? leadApprovalItem;
                          const leadHistoryOrderId = carrierOrderId
                            ?? (typeof leadApprovalItem?.orderId === "number"
                              ? leadApprovalItem.orderId
                              : typeof leadApprovalItem?.id === "number"
                                ? leadApprovalItem.id
                                : null);
                          const childItems = carrierOrderId !== null
                            ? items.filter((item: any) => (item.orderId ?? item.id) !== carrierOrderId)
                            : items;
                          const childOrderCount = childItems.length;
                          const leadDisplayTitle = carrierOrder
                            ? (carrierOrder.orderNumber || carrierOrder.systemCode || `#${carrierOrderId}`)
                            : planNumber;
                          const leadRouteSummary = carrierOrder?.originCity || carrierOrder?.destinationCity
                            ? `${carrierOrder.originCity || "-"} → ${carrierOrder.destinationCity || "-"}`
                            : getGroupRouteSummary(items);
                          const allSelected = itemOrderIds.length > 0 && itemOrderIds.every((id) => selectedIds.has(id));
                          const leadHistoryExpanded = typeof leadHistoryOrderId === "number" && expandedApprovalHistoryOrderIds.has(leadHistoryOrderId);
                          const leadSupplementNote = getApprovalGroupRemarkSummary(items);
                          if (!isMergedGroup || typeof leadHistoryOrderId !== "number") {
                            return null;
                          }

                          return (
                            <React.Fragment key={planNumber}>
                              <TableRow className={[hasUrgent ? "bg-red-50/60" : "bg-blue-50/40", "border-l-4 border-l-blue-400"].join(" ")}>
                                <TableCell>
                                  <Checkbox
                                    checked={allSelected}
                                    onCheckedChange={() => {
                                      setSelectedIds((prev) => {
                                        const next = new Set(prev);
                                        if (allSelected) itemOrderIds.forEach((id) => next.delete(id));
                                        else itemOrderIds.forEach((id) => next.add(id));
                                        return next;
                                      });
                                    }}
                                    aria-label={`选择组合主单 ${planNumber}`}
                                  />
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[150px] font-mono text-xs align-top">
                                  <div className="flex flex-col gap-2">
                                    <div className="flex flex-wrap items-center gap-1.5">
                                      <button
                                        type="button"
                                        className="inline-flex items-center gap-1 text-[10px] text-blue-700 hover:text-blue-800"
                                        onClick={() => toggleApprovalGroup(planNumber)}
                                        title={isExpanded ? "收起组合单" : "展开组合单"}
                                      >
                                        {isExpanded ? <ChevronDown className="h-3.5 w-3.5" /> : <ChevronRight className="h-3.5 w-3.5" />}
                                        <Badge variant="outline" className="border-blue-300 bg-blue-100 px-1.5 text-[10px] text-blue-700">
                                          同批 {items.length} 单
                                        </Badge>
                                      </button>
                                      <Badge variant="secondary" className="bg-white text-blue-700 border border-blue-200">
                                        {carrierOrder ? "主单" : "组合主单"}
                                      </Badge>
                                      <span className="font-semibold text-slate-900">{leadDisplayTitle}</span>
                                    </div>
                                    <div className="text-[11px] text-slate-600">
                                      {getGroupCustomerCargoSummary(items)}
                                    </div>
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[180px] align-top text-xs">
                                  <div className="space-y-2">
                                    <ApprovalDecisionBadges items={items} />
                                    {leadSupplementNote ? (
                                      <div className="rounded-md border border-amber-200 bg-amber-50 px-2.5 py-2 text-[11px] leading-5 text-amber-900">
                                        {leadSupplementNote}
                                      </div>
                                    ) : null}
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[96px] align-top text-xs">
                                  <div className="max-w-[96px] space-y-1">
                                    <span className="flex flex-wrap items-center gap-1 text-wrap-safe">
                                      {leadItem.originCity || "-"} <ArrowRight className="h-3 w-3 shrink-0" /> {leadItem.destinationCity || "-"}
                                    </span>
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[160px] align-top text-xs">
                                  <div className="space-y-2">
                                    <ApprovalPriceComparison item={leadApprovalItem} items={items} />
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[72px] text-xs text-muted-foreground align-top">
                                  {getApprovalApplicants(items)}
                                </TableCell>
                                <TableCell>
                                  {hasUrgent && <Badge variant="destructive" className="text-[10px]">加急</Badge>}
                                </TableCell>
                                <TableCell className="align-top">
                                  <div className="flex min-w-0 flex-col items-stretch gap-1">
                                    <Button
                                      size="sm"
                                      variant="outline"
                                      className={hasUrgent ? "h-7 w-full justify-center px-2 text-[11px] border-slate-300 text-slate-600 hover:bg-slate-50" : "h-7 w-full justify-center px-2 text-[11px] border-amber-300 text-amber-600 hover:bg-amber-50"}
                                      onClick={() => openUrgentDialog(items, `整组 ${planNumber}`)}
                                    >
                                      <Flame className="mr-1 h-3 w-3" />
                                      {hasUrgent ? "取消加急" : "加急"}
                                    </Button>
                                    <Button size="sm" className="h-7 w-full justify-center bg-green-600 px-2 text-[11px] text-white hover:bg-green-700" onClick={() => openGroupApprovalDialog(items, "approve")}>
                                      <CheckCircle2 className="mr-1 h-3 w-3" />通过
                                    </Button>
                                    <Button size="sm" variant="outline" className="h-7 w-full justify-center border-red-300 px-2 text-[11px] text-red-600 hover:bg-red-50" onClick={() => openGroupApprovalDialog(items, "reject")}>
                                      <XCircle className="mr-1 h-3 w-3" />驳回
                                    </Button>
                                    <div className="flex items-center justify-center gap-1 pt-0.5">
                                      <DangerActionMenu
                                        onRollback={hasPermission("order.rollback") ? () => openBatchRollbackDialog(itemOrderIds) : undefined}
                                        rollbackLabel="整组退回"
                                        onDelete={hasPermission("order.delete") ? () => openBatchDeleteDialog(itemOrderIds) : undefined}
                                        deleteLabel="整组删除"
                                      />
                                    </div>
                                  </div>
                                </TableCell>

                              </TableRow>
                              <TableRow className="bg-slate-50/25">
                                <TableCell colSpan={8} className="px-4 py-2">
                                  <div className="pl-5 pr-2">
                                    <ApprovalSummaryContent
                                      item={leadApprovalItem}
                                      items={items}
                                      itemOrderId={leadHistoryOrderId}
                                    />
                                  </div>
                                </TableCell>
                              </TableRow>

                            </React.Fragment>
                          );
                        })}
                        {approvalDisplayGrouped.ungrouped.map((item: any) => {
                          const itemOrderId = item.orderId ?? item.id;
                          return (
                            <React.Fragment key={item.id}>
                              <TableRow className={item.isUrgent ? "bg-red-50/50" : ""}>
                                <TableCell>
                                  <Checkbox checked={selectedIds.has(itemOrderId)} onCheckedChange={() => toggleSelect(itemOrderId)} />
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[150px] font-mono text-xs align-top">
                                  <div className="flex flex-col gap-1">
                                    <div>{item.orderNumber || item.systemCode || `#${item.orderId}`}</div>
                                    {renderOutsourceSuborderPreview(item)}
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[180px] align-top text-xs">
                                  <div className="space-y-2">
                                    <ApprovalDecisionBadges items={[item]} />
                                    <div className="text-[11px] leading-5 text-slate-600">当前为{getApprovalTypeLabel(item.approvalType)}审批</div>
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[96px] align-top text-xs">
                                  <span className="flex max-w-[96px] flex-wrap items-center gap-1 text-wrap-safe">
                                    {item.originCity || "-"} <ArrowRight className="h-3 w-3 shrink-0" /> {item.destinationCity || "-"}
                                  </span>
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[160px] align-top text-xs">
                                  <ApprovalPriceComparison item={item} />
                                </TableCell>
                                <TableCell className="table-cell-readable max-w-[72px] text-xs text-muted-foreground align-top">{item.applicantName || "-"}</TableCell>
                                <TableCell>
                                  {item.isUrgent && <Badge variant="destructive" className="text-[10px]">加急</Badge>}
                                </TableCell>
                                <TableCell className="align-top">
                                  <div className="flex flex-col items-stretch gap-1">
                                    <Button
                                      size="sm"
                                      variant="ghost"
                                      className={item.isUrgent ? "h-7 w-full justify-center p-0 text-slate-500 hover:text-slate-600 sm:w-7" : "h-7 w-full justify-center p-0 text-amber-500 hover:text-amber-600 sm:w-7"}
                                      onClick={() => openUrgentDialog([item], item.orderNumber || item.systemCode || `#${itemOrderId}`)}
                                      title={item.isUrgent ? "取消加急" : "标记加急"}
                                    >
                                      <Flame className="h-3.5 w-3.5" />
                                    </Button>
                                    <Button size="sm" className="w-full justify-center bg-green-600 text-white hover:bg-green-700 sm:w-auto" onClick={() => openGroupApprovalDialog([item], "approve")}>
                                      <CheckCircle2 className="h-3 w-3 mr-1" />通过
                                    </Button>
                                    <Button size="sm" variant="outline" className="w-full justify-center border-red-300 text-red-600 hover:bg-red-50 sm:w-auto" onClick={() => openGroupApprovalDialog([item], "reject")}>
                                      <XCircle className="h-3 w-3 mr-1" />驳回
                                    </Button>
                                    <DangerActionMenu
                                      onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(item, itemOrderId) : undefined}
                                      rollbackDisabled={Boolean(getRollbackLockReason(item))}
                                      onDelete={hasPermission("order.delete") ? () => openDeleteDialog(item, itemOrderId) : undefined}
                                      deleteDisabled={Boolean(getDeleteLockReason(item))}
                                    />
                                  </div>
                                </TableCell>
                              </TableRow>
                              <TableRow className="bg-slate-50/25">
                                <TableCell colSpan={8} className="px-4 py-2">
                                  <div className="pl-5 pr-2">
                                    <ApprovalSummaryContent
                                      item={item}
                                      itemOrderId={itemOrderId}
                                    />
                                  </div>
                                </TableCell>
                              </TableRow>
                            </React.Fragment>
                          );
                        })}
                      </>
                    ) : (
                      filteredApprovalOrders.map((item: any) => {
                        const itemOrderId = item.orderId ?? item.id;
                        return (
                          <React.Fragment key={item.id}>
                            <TableRow className={item.isUrgent ? "bg-red-50/50" : ""}>
                              <TableCell>
                                <Checkbox checked={selectedIds.has(itemOrderId)} onCheckedChange={() => toggleSelect(itemOrderId)} />
                              </TableCell>
                              <TableCell className="table-cell-readable max-w-[150px] font-mono text-xs align-top">
                                <div className="flex flex-col gap-1">
                                  <div>{item.orderNumber || item.systemCode || `#${item.orderId}`}</div>
                                  {renderOutsourceSuborderPreview(item)}
                                </div>
                              </TableCell>
                              <TableCell className="table-cell-readable max-w-[180px] align-top text-xs">
                                <div className="space-y-2">
                                  <ApprovalDecisionBadges items={[item]} />
                                  <div className="text-[11px] leading-5 text-slate-600">当前为{getApprovalTypeLabel(item.approvalType)}审批</div>
                                </div>
                              </TableCell>
                              <TableCell className="table-cell-readable max-w-[96px] align-top text-xs">
                                <span className="flex max-w-[96px] flex-wrap items-center gap-1 text-wrap-safe">
                                  {item.originCity || "-"} <ArrowRight className="h-3 w-3 shrink-0" /> {item.destinationCity || "-"}
                                </span>
                              </TableCell>
                              <TableCell className="table-cell-readable max-w-[160px] align-top text-xs">
                                <ApprovalPriceComparison item={item} />
                              </TableCell>
                              <TableCell className="table-cell-readable max-w-[72px] text-xs text-muted-foreground align-top">{item.applicantName || "-"}</TableCell>
                              <TableCell>
                                {item.isUrgent && <Badge variant="destructive" className="text-[10px]">加急</Badge>}
                              </TableCell>
                              <TableCell className="align-top">
                                <div className="flex min-w-0 flex-col items-stretch gap-1">
                                  <Button
                                    size="sm"
                                    variant="outline"
                                    className={item.isUrgent ? "h-7 w-full justify-center border-slate-300 px-2 text-[11px] text-slate-600 hover:bg-slate-50" : "h-7 w-full justify-center border-amber-300 px-2 text-[11px] text-amber-600 hover:bg-amber-50"}
                                    onClick={() => openUrgentDialog([item], item.orderNumber || item.systemCode || `#${itemOrderId}`)}
                                    title={item.isUrgent ? "取消加急" : "标记加急"}
                                  >
                                    <Flame className="mr-1 h-3 w-3" />
                                    {item.isUrgent ? "取消加急" : "加急"}
                                  </Button>
                                  <Button size="sm" className="h-7 w-full justify-center bg-green-600 px-2 text-[11px] text-white hover:bg-green-700" onClick={() => openGroupApprovalDialog([item], "approve")}>
                                    <CheckCircle2 className="mr-1 h-3 w-3" />通过
                                  </Button>
                                  <Button size="sm" variant="outline" className="h-7 w-full justify-center border-red-300 px-2 text-[11px] text-red-600 hover:bg-red-50" onClick={() => openGroupApprovalDialog([item], "reject")}>
                                    <XCircle className="mr-1 h-3 w-3" />驳回
                                  </Button>
                                  <div className="flex items-center justify-center gap-1 pt-0.5">
                                    <DangerActionMenu
                                      onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(item, itemOrderId) : undefined}
                                      rollbackDisabled={Boolean(getRollbackLockReason(item))}
                                      onDelete={hasPermission("order.delete") ? () => openDeleteDialog(item, itemOrderId) : undefined}
                                      deleteDisabled={Boolean(getDeleteLockReason(item))}
                                    />
                                  </div>
                                </div>
                              </TableCell>

                            </TableRow>
                            <TableRow className="bg-slate-50/25">
                              <TableCell colSpan={8} className="px-4 py-2">
                                <div className="pl-9">
                                  <ApprovalSummaryContent
                                    item={item}
                                    itemOrderId={itemOrderId}
                                  />
                                </div>
                              </TableCell>
                            </TableRow>
                          </React.Fragment>
                        );
                      })
                    )}
                  </TableBody>
                </Table>
                <TablePagination total={filteredApprovalOrders.length} page={approvalPage} pageSize={approvalPageSize} onPageChange={setApprovalPage} onPageSizeChange={setApprovalPageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 待派车 */}

          <TabsContent value="dispatched">
            <div className="flex items-center gap-2 mb-3">
              <div className="relative min-w-[200px]">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                <Input placeholder="搜索订单号/客户/车牌..." value={dispatchedSearch} onChange={(e) => setDispatchedSearch(e.target.value)} className="pl-9 h-8" />
              </div>
            </div>
            {/* 批量标记送达/签收操作栏 */}
            {selectedIds.size > 0 && activeTab === "dispatched" && (
              <div className="flex items-center gap-2 mb-3 p-2 bg-blue-50 rounded-lg">
                <span className="text-sm text-blue-700 font-medium">已选 {selectedIds.size} 个订单</span>
                <Button size="sm" variant="outline" className="text-green-600 border-green-300 hover:bg-green-50 h-7 text-xs" onClick={() => {
                  const toDeliver = filteredDispatchedOrders.filter((o: any) => selectedIds.has(o.id) && o.plateNumber && o.driverName);
                  if (toDeliver.length === 0) { toast.error("所选订单中没有已派车的订单，无法标记送达"); return; }
                  batchUpdateStatus.mutate({ orderIds: toDeliver.map((o: any) => o.id), status: "delivered" });
                }}>
                  <CheckCircle2 className="h-3 w-3 mr-1" />批量标记送达 ({filteredDispatchedOrders.filter((o: any) => selectedIds.has(o.id) && o.plateNumber && o.driverName).length})
                </Button>
                <Button size="sm" variant="outline" className="text-emerald-600 border-emerald-300 hover:bg-emerald-50 h-7 text-xs" onClick={() => {
                  const toSign = filteredDispatchedOrders.filter((o: any) => selectedIds.has(o.id) && o.plateNumber && o.driverName);
                  if (toSign.length === 0) { toast.error("所选订单中没有已派车的订单，无法标记签收"); return; }
                  batchUpdateStatus.mutate({ orderIds: toSign.map((o: any) => o.id), status: "signed" });
                }}>
                  <FileCheck className="h-3 w-3 mr-1" />批量标记签收 ({filteredDispatchedOrders.filter((o: any) => selectedIds.has(o.id) && o.plateNumber && o.driverName).length})
                </Button>
                {hasPermission("order.rollback") && (
                  <Button size="sm" variant="outline" className="text-orange-600 border-orange-300 hover:bg-orange-50 h-7 text-xs" onClick={() => { setBatchRollbackOpen(true); setBatchRollbackReason(""); }}>
                    <Undo2 className="h-3 w-3 mr-1" />批量退回 ({selectedIds.size})
                  </Button>
                )}
                <Button size="sm" variant="ghost" className="text-muted-foreground h-7 text-xs" onClick={() => setSelectedIds(new Set())}>
                  清除选择
                </Button>
              </div>
            )}
            <Card>
              <CardContent className="p-0">
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8"><Checkbox checked={sortedDispatchedOrders.length > 0 && sortedDispatchedOrders.every((o: any) => selectedIds.has(o.id))} onCheckedChange={() => { if (sortedDispatchedOrders.every((o: any) => selectedIds.has(o.id))) { const next = new Set(selectedIds); sortedDispatchedOrders.forEach((o: any) => next.delete(o.id)); setSelectedIds(next); } else { const next = new Set(selectedIds); sortedDispatchedOrders.forEach((o: any) => next.add(o.id)); setSelectedIds(next); } }} /></TableHead>
                      <TableHead>客户订单号</TableHead>
                      <SortableHeader sortKey="customerName" currentSort={dispatchedSort} onToggle={toggleDispatchedSort}>客户 · 货物</SortableHeader>
                      <TableHead>路线</TableHead>
                      <SortableHeader sortKey="weight" currentSort={dispatchedSort} onToggle={toggleDispatchedSort}>吨位</SortableHeader>
                      <SortableHeader sortKey="dispatchPrice" currentSort={dispatchedSort} onToggle={toggleDispatchedSort}>调度价</SortableHeader>
                      <SortableHeader sortKey="actualFreight" currentSort={dispatchedSort} onToggle={toggleDispatchedSort}>报价</SortableHeader>
                      <TableHead>车牌/司机</TableHead>
                      <TableHead>状态</TableHead>
                      <TableHead>回单/押金</TableHead>
                      <TableHead>操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredDispatchedOrders.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={10} className="text-center py-8 text-muted-foreground">
                          暂无待派车订单。正式外请分组会在此优先按“分组/车次”展示，纯零担内部整理不会在这里生成正式外请组。
                        </TableCell>
                      </TableRow>
                    ) : (() => {
                      // 已调度区优先按正式外请分组展示，未形成正式分组时回退按车次展示
                      const groups = new Map<string, any[]>();
                      const ungrouped: any[] = [];
                      filteredDispatchedOrders.forEach((o: any) => {
                        const key = getDispatchGroupKey(o);
                        if (key.startsWith("single_")) {
                          ungrouped.push(o);
                          return;
                        }
                        const arr = groups.get(key) || [];
                        arr.push(o);
                        groups.set(key, arr);
                      });
                      return (
                        <>
                          {Array.from(groups.entries()).map(([planNumber, groupOrders]) => {
                            const isExpanded = pendingExpanded.has(planNumber);
                            const totalWeight = groupOrders.reduce((sum: number, o: any) => sum + parseFloat(o.weight || "0"), 0);
                            const totalDispatch = groupOrders.reduce((sum: number, o: any) => sum + (parseFloat(o.dispatchPrice) || 0), 0);
                            const totalFreight = groupOrders.reduce((sum: number, o: any) => sum + (parseFloat(o.actualFreight) || 0), 0);
                            const allHaveVehicle = groupOrders.every((o: any) => o.plateNumber && o.driverName);
                            const anyHaveVehicle = groupOrders.some((o: any) => o.plateNumber && o.driverName);
                            return (
                              <React.Fragment key={planNumber}>
                                <TableRow
                                  className="bg-blue-50 hover:bg-blue-100/80 cursor-pointer border-l-2 border-l-blue-500"
                                  onClick={() => togglePendingGroup(planNumber)}
                                >
                                  <TableCell onClick={(e: React.MouseEvent) => e.stopPropagation()}>
                                    <Checkbox
                                      checked={groupOrders.every((o: any) => selectedIds.has(o.id))}
                                      onCheckedChange={() => {
                                        const allSelected = groupOrders.every((o: any) => selectedIds.has(o.id));
                                        setSelectedIds(prev => {
                                          const next = new Set(prev);
                                          groupOrders.forEach((o: any) => allSelected ? next.delete(o.id) : next.add(o.id));
                                          return next;
                                        });
                                      }}
                                    />
                                  </TableCell>
                                  <TableCell>
                                    <div className="space-y-1">
                                      <div className="flex items-center gap-2">
                                        {isExpanded ? <ChevronDown className="h-4 w-4 text-blue-600" /> : <ChevronRight className="h-4 w-4 text-blue-600" />}
                                        <Layers className="h-4 w-4 text-blue-600" />
                                        <span className="font-bold text-blue-700">{getDispatchHeadline(groupOrders[0])}</span>
                                        <Badge variant="outline" className="text-[10px] px-1.5 bg-blue-100 text-blue-700 border-blue-300">{groupOrders.length}单</Badge>
                                        <Badge variant="outline" className="text-[10px] px-1.5 border-blue-200 bg-white/80 text-blue-700">
                                          {getVisibleDispatchGroup(groupOrders[0]) ? "正式外请分组优先" : "回退车次展示"}
                                        </Badge>
                                      </div>
                                      <div className="pl-6 text-[10px] text-blue-700/80">{getDispatchSubline(groupOrders[0])}</div>
                                      <div className="pl-6 text-[10px] text-blue-700/70">{getTripSupportLine(groupOrders[0])}</div>
                                      <div className="pl-6 text-[10px] text-blue-700/60">该组送达、回单与财务移交均按当前组头口径联动。</div>
                                    </div>
                                  </TableCell>
                                  <TableCell className="text-xs">
                                    {(() => {
                                      const customers = Array.from(new Set(groupOrders.map((o: any) => o.customerName).filter(Boolean)));
                                      const cargos = Array.from(new Set(groupOrders.map((o: any) => o.cargoName).filter(Boolean)));
                                      return `${customers.join("/") || "-"} · ${cargos.join("/") || "-"}`;
                                    })()}
                                  </TableCell>
                                  <TableCell className="text-sm">
                                    {groupOrders[0]?.originCity || "-"} → {Array.from(new Set(groupOrders.map((o: any) => o.destinationCity).filter(Boolean))).join("、")}
                                  </TableCell>
                                  <TableCell className="text-sm font-bold text-blue-700">{totalWeight.toFixed(3)}t</TableCell>
                                  <TableCell className="text-xs text-orange-600 font-medium">{formatMoney(totalDispatch.toString())}</TableCell>
                                  <TableCell className="text-xs font-medium">{totalFreight > 0 ? `¥${totalFreight}` : "-"}</TableCell>
                                  <TableCell className="text-xs">
                                    {anyHaveVehicle ? (
                                      <span>{groupOrders[0]?.plateNumber || "-"} / {groupOrders[0]?.driverName || "-"}</span>
                                    ) : (
                                      <Badge variant="outline" className="text-[10px] text-amber-600 border-amber-300">待填写</Badge>
                                    )}
                                  </TableCell>
                                  <TableCell>
                                    {allHaveVehicle ? (
                                      <Badge className="bg-green-100 text-green-700 text-[10px]">已派车</Badge>
                                    ) : (
                                      <Badge className="bg-amber-100 text-amber-700 text-[10px]">待派车</Badge>
                                    )}
                                  </TableCell>
                                  <TableCell className="align-top">
                                    <div className="space-y-1 text-xs">
                                      {(() => {
                                        const podTotal = groupOrders.length;
                                        const podReceived = groupOrders.filter((item: any) => getOrderPodOriginalStatus(item) === "received").length;
                                        const podSent = groupOrders.filter((item: any) => hasPodBeenSent(item)).length;
                                        const depositOrders = groupOrders.filter((item: any) => parseFloat(String(item.depositAmount || "0")) > 0);
                                        const pendingDeposit = depositOrders.filter((item: any) => item.depositStatus === "paid").length;
                                        const refundedDeposit = depositOrders.filter((item: any) => item.depositStatus === "refunded").length;
                                        const nonRefundableDeposit = depositOrders.filter((item: any) => item.depositStatus === "not_refundable").length;
                                        return (
                                          <>
                                            <div>
                                              <Badge variant="secondary" className={podReceived === podTotal && podTotal > 0 ? "bg-green-100 text-green-700" : podSent > 0 ? "bg-amber-100 text-amber-700" : "bg-slate-100 text-slate-700"}>
                                                {podReceived === podTotal && podTotal > 0
                                                  ? `回单已全部收到 ${podReceived}/${podTotal}`
                                                  : podSent > 0
                                                    ? `回单在途 ${podReceived}/${podTotal}`
                                                    : `回单待寄出 0/${podTotal}`}
                                              </Badge>
                                            </div>
                                            <div>
                                              <Badge variant="secondary" className={pendingDeposit > 0 ? "bg-red-100 text-red-700" : refundedDeposit > 0 ? "bg-green-100 text-green-700" : nonRefundableDeposit > 0 ? "bg-slate-100 text-slate-700" : "bg-slate-100 text-slate-600"}>
                                                {depositOrders.length === 0
                                                  ? "无押金"
                                                  : pendingDeposit > 0
                                                    ? `押金待处理 ${pendingDeposit}`
                                                    : refundedDeposit > 0
                                                      ? `押金已退还 ${refundedDeposit}`
                                                      : `押金不退还 ${nonRefundableDeposit}`}
                                              </Badge>
                                            </div>
                                            <div className="text-[10px] leading-4 text-muted-foreground">回单确认与退押金已统一收口到本页“回单处理”页签，可在该页签继续完成闭环。</div>
                                          </>
                                        );
                                      })()}
                                    </div>
                                  </TableCell>
                                  <TableCell onClick={(e: React.MouseEvent) => e.stopPropagation()}>
                                    <div className="flex items-center gap-1">
                                      {!allHaveVehicle && (
                                        <Button size="sm" onClick={() => { setConfirmVehicleOrder(groupOrders[0]); setConfirmVehicleGroupOrders(groupOrders); }}>
                                          <Truck className="h-3 w-3 mr-1" />整组派车
                                        </Button>
                                      )}
                                      {allHaveVehicle && (
                                        <Button
                                          size="sm"
                                          variant="outline"
                                          className="text-green-600 border-green-300 hover:bg-green-50"
                                          onClick={() => {
                                            groupOrders.forEach((o: any) => updateStatus.mutate({ id: o.id, status: "delivered" }));
                                            toast.success(`已整组标记送达 ${groupOrders.length} 个订单`);
                                          }}
                                        >
                                          <CheckCircle2 className="h-3 w-3 mr-1" />整组标记送达
                                        </Button>
                                      )}
                                      {hasPermission("order.rollback") && <Button size="sm" variant="ghost" className="text-orange-500 hover:text-orange-600 h-7 w-7 p-0" onClick={() => { const ids = groupOrders.map((o: any) => o.id); setSelectedIds(new Set(ids)); setBatchRollbackOpen(true); setBatchRollbackReason(""); }} title="整组退回">
                                        <Undo2 className="h-3.5 w-3.5" />
                                      </Button>}
                                    </div>
                                  </TableCell>
                                </TableRow>
                                {isExpanded && groupOrders.map((order: any) => (
                                  <TableRow key={order.id} className="bg-blue-50/30 border-l-2 border-l-blue-200">
                                    <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                                    <TableCell className="table-cell-readable font-mono text-xs align-top">
                                      <div className="flex flex-col gap-1">
                                        <div><span className="text-muted-foreground pl-2">└</span> {order.orderNumber || order.systemCode}</div>
                                        {renderOutsourceSuborderPreview(order)}
                                      </div>
                                    </TableCell>
                                    <TableCell className="text-xs">{order.customerName} · {order.cargoName}</TableCell>
                                    <TableCell className="text-xs">{order.originCity} → {order.destinationCity}</TableCell>
                                    <TableCell className="text-xs">
                            <div>{order.weight ? `${order.weight}t` : "-"}</div>
                            {order.chargeableWeight ? <div className="mt-1 text-[11px] text-muted-foreground">计费：{order.chargeableWeight}t</div> : null}
                          </TableCell>
                                    <TableCell className="text-xs text-orange-600">{formatMoney(order.dispatchPrice)}</TableCell>
                                    <TableCell className="text-xs">{order.actualFreight ? `¥${order.actualFreight}` : "-"}</TableCell>
                                    <TableCell className="text-xs">{order.plateNumber || "-"} / {order.driverName || "-"}</TableCell>
                                    <TableCell>
                                      {order.plateNumber && order.driverName ? (
                                        <Badge className="bg-green-100 text-green-700 text-[10px]">已派车</Badge>
                                      ) : (
                                        <Badge className="bg-amber-100 text-amber-700 text-[10px]">待派车</Badge>
                                      )}
                                    </TableCell>
                                    <TableCell>
                                      <div className="space-y-1 text-xs">
                                        <Badge className={`text-[10px] ${getPodStatusToneClass(getOrderPodBusinessStatus(order))}`}>
                                          {POD_STATUS_LABELS[getOrderPodBusinessStatus(order)] || getOrderPodBusinessStatus(order)}
                                        </Badge>
                                        {parseFloat(String(order.depositAmount || "0")) > 0 ? (
                                          <Badge variant="secondary" className={order.depositStatus === "paid" ? "bg-red-100 text-red-700" : order.depositStatus === "refunded" ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-700"}>
                                            {order.depositStatus === "paid" ? "押金待处理" : order.depositStatus === "refunded" ? "押金已退还" : "押金不退还"}
                                          </Badge>
                                        ) : (
                                          <Badge variant="secondary" className="bg-slate-100 text-slate-600">无押金</Badge>
                                        )}
                                      </div>
                                    </TableCell>
                                    <TableCell>
                                      <span className="text-[10px] text-muted-foreground">跟随当前分组/车次整组操作</span>
                                    </TableCell>
                                  </TableRow>
                                ))}
                              </React.Fragment>
                            );
                          })}
                          {ungrouped.map((order: any) => (
                            <TableRow key={order.id}>
                              <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                              <TableCell className="font-mono text-xs">
                              <div className="flex flex-col gap-1">
                                <div>{order.orderNumber || order.systemCode}</div>
                                {renderOutsourceSuborderPreview(order)}
                              </div>
                            </TableCell>
                              <TableCell className="text-xs">{order.customerName} · {order.cargoName}</TableCell>
                              <TableCell className="text-xs">{order.originCity} → {order.destinationCity}</TableCell>
                              <TableCell className="text-xs">
                            <div>{order.weight ? `${order.weight}t` : "-"}</div>
                            {order.chargeableWeight ? <div className="mt-1 text-[11px] text-muted-foreground">计费：{order.chargeableWeight}t</div> : null}
                          </TableCell>
                              <TableCell className="text-xs text-orange-600">{formatMoney(order.dispatchPrice)}</TableCell>
                              <TableCell className="text-xs">{order.actualFreight ? `¥${order.actualFreight}` : "-"}</TableCell>
                              <TableCell className="text-xs">{order.plateNumber || "-"} / {order.driverName || "-"}</TableCell>
                              <TableCell>
                                {order.plateNumber && order.driverName ? (
                                  <Badge className="bg-green-100 text-green-700 text-[10px]">已派车</Badge>
                                ) : (
                                  <Badge className="bg-amber-100 text-amber-700 text-[10px]">待派车</Badge>
                                )}
                              </TableCell>
                              <TableCell>
                                <div className="space-y-1 text-xs">
                                  <Badge className={`text-[10px] ${getPodStatusToneClass(getOrderPodBusinessStatus(order))}`}>
                                    {POD_STATUS_LABELS[getOrderPodBusinessStatus(order)] || getOrderPodBusinessStatus(order)}
                                  </Badge>
                                  {parseFloat(String(order.depositAmount || "0")) > 0 ? (
                                    <Badge variant="secondary" className={order.depositStatus === "paid" ? "bg-red-100 text-red-700" : order.depositStatus === "refunded" ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-700"}>
                                      {order.depositStatus === "paid" ? "押金待处理" : order.depositStatus === "refunded" ? "押金已退还" : "押金不退还"}
                                    </Badge>
                                  ) : (
                                    <Badge variant="secondary" className="bg-slate-100 text-slate-600">无押金</Badge>
                                  )}
                                </div>
                              </TableCell>
                              <TableCell>
                                <div className="flex items-center gap-1">
                                  {(!order.plateNumber || !order.driverName) ? (
                                    <Button size="sm" onClick={() => { setConfirmVehicleOrder(order); setConfirmVehicleGroupOrders([]); }}>
                                      <Truck className="h-3 w-3 mr-1" />确认派车
                                    </Button>
                                  ) : (
                                    <Button size="sm" variant="outline" className="text-green-600 border-green-300 hover:bg-green-50"
                                      onClick={() => updateStatus.mutate({ id: order.id, status: "delivered" })}>
                                      <CheckCircle2 className="h-3 w-3 mr-1" />标记送达
                                    </Button>
                                  )}
                                  <DangerActionMenu
                                    onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(order) : undefined}
                                    rollbackDisabled={Boolean(getRollbackLockReason(order))}
                                  />
                                </div>
                              </TableCell>
                            </TableRow>
                          ))}
                        </>
                      );
                    })()}
                  </TableBody>
                </Table>
                <TablePagination total={filteredDispatchedOrders.length} page={dispatchedPage} pageSize={dispatchedPageSize} onPageChange={setDispatchedPage} onPageSizeChange={setDispatchedPageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 运输中Tab已移除，流程简化：已调度直接标记送达到回单 */}

          {/* 统一回单处理区：回单寄出与财务确认衔接 */}
          <TabsContent value="pod-processing">
            <div className="flex items-center gap-2 mb-3">
              <div className="relative min-w-[200px]">
                <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                <Input placeholder="搜索订单号/客户/车牌..." value={podSearch} onChange={(e) => setPodSearch(e.target.value)} className="pl-9 h-8" />
              </div>
            </div>
            {/* 批量操作栏 */}
            {selectedIds.size > 0 && activeTab === "pod-processing" && (
              <div className="mb-3 flex flex-wrap items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
                <span className="text-sm font-medium text-slate-700">已选 <span className="font-bold text-blue-600">{selectedIds.size}</span> 个订单</span>
                <div className="h-4 w-px bg-slate-200" />
                <Button
                  size="sm"
                  className="h-8 rounded-lg bg-amber-500 hover:bg-amber-600 text-white px-4 text-sm font-medium"
                  onClick={async () => {
                    const sel = signedOrders.filter((o) => selectedIds.has(o.id));
                    await handleMarkPodSent(sel, { scopeLabel: "批量", clearSelection: true });
                  }}
                  disabled={markPodSent.isPending}
                >
                  <Send className="h-3 w-3 mr-1" />批量寄出
                </Button>
                <Button
                  size="sm"
                  className="h-8 rounded-lg bg-blue-500 hover:bg-blue-600 text-white px-4 text-sm font-medium"
                  onClick={async () => {
                    const sel = signedOrders.filter((o) => selectedIds.has(o.id) && canCancelPodSent(o));
                    await handleCancelPodSent(sel, { scopeLabel: "批量", clearSelection: true });
                  }}
                  disabled={cancelPodSent.isPending}
                >
                  <Undo2 className="h-3 w-3 mr-1" />批量撤销
                </Button>
                <Button
                  size="sm"
                  className="h-8 rounded-lg bg-emerald-500 hover:bg-emerald-600 text-white px-4 text-sm font-medium"
                  onClick={async () => {
                    const ids = signedOrders.filter((o) => selectedIds.has(o.id)).map((o) => o.id);
                    await batchRefundDepositMutation.mutateAsync({ ids });
                    setSelectedIds(new Set());
                  }}
                  disabled={batchRefundDepositMutation.isPending}
                >
                  <DollarSign className="h-3 w-3 mr-1" />批量退押金
                </Button>
                <button
                  className="ml-2 text-sm text-slate-400 hover:text-slate-600"
                  onClick={() => setSelectedIds(new Set())}
                >
                  清空选择
                </button>
              </div>
            )}
            <Card>
              <CardContent className="p-0">
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8">
                        <Checkbox
                          checked={filteredSignedOrders.length > 0 && filteredSignedOrders.every((o: any) => selectedIds.has(o.id))}
                          onCheckedChange={() => {
                            if (filteredSignedOrders.every((o: any) => selectedIds.has(o.id))) {
                              const next = new Set(selectedIds); signedOrders.forEach((o: any) => next.delete(o.id)); setSelectedIds(next);
                            } else {
                              const next = new Set(selectedIds); signedOrders.forEach((o: any) => next.add(o.id)); setSelectedIds(next);
                            }
                          }}
                        />
                      </TableHead>
                      <TableHead>客户订单号</TableHead>
                      <TableHead>路线</TableHead>
                      <TableHead>车牌/司机</TableHead>
                      <SortableHeader sortKey="createdAt" currentSort={podSort} onToggle={togglePodSort}>签收日期</SortableHeader>
                      <SortableHeader sortKey="podStatus" currentSort={podSort} onToggle={togglePodSort}>回单状态</SortableHeader>
                      <TableHead>寄出日期</TableHead>
                      <TableHead>快递单号</TableHead>
                      <TableHead>操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {sortedSignedOrders.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={9} className="text-center py-8 text-muted-foreground">
                          暂无已送达/已签收订单。后续一旦出现“司机已寄出原件”的记录，这里会优先按正式外请分组展示回单跟踪；尚未形成正式外请记录的订单，则会回退为同车次口径展示。
                        </TableCell>
                      </TableRow>
                    ) : (
                      <>
                        {groupedSignedOrders.groups.map((group) => {
                          const isExpanded = expandedPodGroups.has(group.key);
                          const allIds = group.items.map((item: any) => item.id);
                          const allSelected = allIds.every((id: number) => selectedIds.has(id));
                          const eligibleMark = group.items.filter((item: any) => canMarkPodAsSent(item));
                          const eligibleCancel = group.items.filter((item: any) => canCancelPodSent(item));
                          const signedTimes = group.items
                            .map((item: any) => new Date((item as any).signedDate || item.deliveryDate || item.createdAt).getTime())
                            .filter((time: number) => Number.isFinite(time));
                          const signedDateSummary = signedTimes.length === 0
                            ? "-"
                            : signedTimes.length === 1
                              ? fmtDate(new Date(signedTimes[0]))
                              : `${fmtDate(new Date(Math.min(...signedTimes)))} ~ ${fmtDate(new Date(Math.max(...signedTimes)))}`;
                          const trackingFilledCount = group.items.filter((item: any) => String((item as any).podTrackingNumber || "").trim().length > 0).length;
                          return (
                            <React.Fragment key={group.key}>
                              <TableRow className="bg-blue-50 hover:bg-blue-100/80 cursor-pointer border-l-2 border-l-blue-500" onClick={() => togglePodGroup(group.key)}>
                                <TableCell onClick={(e) => e.stopPropagation()}>
                                  <Checkbox
                                    checked={allSelected}
                                    onCheckedChange={() => {
                                      setSelectedIds(prev => {
                                        const next = new Set(prev);
                                        if (allSelected) allIds.forEach((id: number) => next.delete(id));
                                        else allIds.forEach((id: number) => next.add(id));
                                        return next;
                                      });
                                    }}
                                  />
                                </TableCell>
                                <TableCell>
                                  <div className="space-y-1">
                                    <div className="flex flex-wrap items-center gap-1.5 text-xs">
                                      {isExpanded ? <ChevronDown className="h-4 w-4 text-blue-600" /> : <ChevronRight className="h-4 w-4 text-blue-600" />}
                                      <Layers className="h-4 w-4 text-blue-600" />
                                      <span className="font-medium text-blue-700">{group.groupHeadline}</span>
                                      <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-300 bg-blue-100 text-blue-700">同批 {group.items.length} 单</Badge>
                                      <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-200 bg-white/80 text-blue-700">回单跟踪口径</Badge>
                                    </div>
                                    <div className="text-[10px] text-blue-700/80">{group.groupSubline}</div>
                                    <div className="text-[10px] text-blue-700/70">该组回单寄出与财务移交均按当前组头口径联动，子订单仅展示明细。</div>
                                  </div>
                                </TableCell>
                                <TableCell className="text-xs">{group.routeSummary}</TableCell>
                                <TableCell className="text-xs">{group.vehicleSummary}</TableCell>
                                <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">{signedDateSummary}</TableCell>
                                <TableCell>
                                  <div className="flex flex-wrap items-center gap-1">
                                    <PodProgressBadge sentCount={group.sentCount} totalCount={group.totalCount} compact />
                                    <span className="text-[10px] text-blue-700/80">{group.allPodsSent ? "该组原件已全部寄出" : `已寄出 ${group.sentCount}/${group.totalCount}`}</span>
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">{group.allPodsSent ? "已完成整组寄出" : `剩余 ${Math.max(group.totalCount - group.sentCount, 0)} 份`}</TableCell>
                                <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">已录快递单号 {trackingFilledCount}/{group.items.length}</TableCell>
                                <TableCell onClick={(e) => e.stopPropagation()}>
                                  <div className="flex flex-wrap items-center gap-1">
                                    {eligibleMark.length > 0 && (
                                      <Button
                                        size="sm"
                                        variant="outline"
                                        className="h-7 text-xs"
                                        onClick={async () => {
                                          await handleMarkPodSent(eligibleMark, { scopeLabel: "整组" });
                                        }}
                                        disabled={markPodSent.isPending}
                                      >
                                        <Send className="h-3 w-3 mr-1" />整组标记已寄出
                                      </Button>
                                    )}
                                    {eligibleCancel.length > 0 && (
                                      <Button
                                        size="sm"
                                        variant="outline"
                                        className="h-7 text-xs text-orange-600 border-orange-300 hover:bg-orange-50"
                                        onClick={async () => {
                                          await handleCancelPodSent(eligibleCancel, { scopeLabel: "整组" });
                                        }}
                                        disabled={cancelPodSent.isPending}
                                      >
                                        <Undo2 className="h-3 w-3 mr-1" />整组取消标记
                                      </Button>
                                    )}
                                    {eligibleMark.length === 0 && eligibleCancel.length === 0 && (
                                      <span className="text-[10px] text-muted-foreground">当前组头下暂无可操作的回单寄出动作</span>
                                    )}
                                  </div>
                                </TableCell>
                              </TableRow>
                              {isExpanded && group.items.map((order: any) => {
                                const podStatus = getOrderPodBusinessStatus(order);
                                return (
                                  <TableRow key={order.id} className="bg-blue-50/30 border-l-2 border-l-blue-200">
                                    <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                                    <TableCell className="table-cell-readable font-mono text-xs align-top">
                                      <div className="flex flex-col gap-1">
                                        <div><span className="text-muted-foreground pl-2">└</span> {order.orderNumber || order.systemCode}</div>
                                        {renderOutsourceSuborderPreview(order)}
                                      </div>
                                    </TableCell>
                                    <TableCell className="text-xs">{order.originCity} → {order.destinationCity}</TableCell>
                                    <TableCell className="text-xs">{order.plateNumber || "-"} / {order.driverName || "-"}</TableCell>
                                    <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">{fmtDate((order as any).signedDate || order.deliveryDate)}</TableCell>
                                    <TableCell>
                                      <Badge className={`text-[10px] ${getPodStatusToneClass(podStatus)}`}>
                                        {POD_STATUS_LABELS[podStatus] || podStatus}
                                      </Badge>
                                    </TableCell>
                                    <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">{formatPodSentDate(order)}</TableCell>
                                    <TableCell>
                                      <InlineEdit
                                        value={(order as any).podTrackingNumber || ""}
                                        placeholder="填写快递单号"
                                        onSave={(val) => updateOrderFields.mutate({ id: order.id, podTrackingNumber: val })}
                                        className="max-w-[120px]"
                                      />
                                    </TableCell>
                                    <TableCell>
                                      <span className="text-[10px] text-muted-foreground">跟随当前分组/车次整组操作</span>
                                    </TableCell>
                                  </TableRow>
                                );
                              })}
                            </React.Fragment>
                          );
                        })}
                        {groupedSignedOrders.ungrouped.map((order) => {
                          const podStatus = getOrderPodBusinessStatus(order);
                          const canMarkSent = canMarkPodAsSent(order);
                          const canCancelMark = canCancelPodSent(order);
                          return (
                            <TableRow key={order.id}>
                              <TableCell>
                                <Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} />
                              </TableCell>
                              <TableCell className="font-mono text-xs">
                                <div className="flex flex-col gap-1">
                                  <div>{order.orderNumber || order.systemCode}</div>
                                  {renderOutsourceSuborderPreview(order)}
                                </div>
                              </TableCell>
                              <TableCell className="text-xs">{order.originCity} → {order.destinationCity}</TableCell>
                              <TableCell className="text-xs">
                                {order.plateNumber || "-"} / {order.driverName || "-"}
                              </TableCell>
                              <TableCell className="text-xs text-muted-foreground">
                                {fmtDate((order as any).signedDate || order.deliveryDate)}
                              </TableCell>
                              <TableCell>
                                <div className="flex items-center gap-1">
                                  <Badge className={`text-[10px] ${getPodStatusToneClass(podStatus)}`}>
                                    {POD_STATUS_LABELS[podStatus] || podStatus}
                                  </Badge>
                                  {(() => {
                                    const visibleDispatchGroup = getVisibleDispatchGroup(order as any);
                                    const progress = (order as any).mergedPlanNumber
                                      ? podTrackingProgressMap?.[(order as any).mergedPlanNumber]
                                      : null;
                                    if (progress) {
                                      return (
                                        <PodProgressBadge
                                          sentCount={progress.sentCount}
                                          totalCount={progress.totalCount}
                                          compact
                                        />
                                      );
                                    }
                                    return (
                                      <span className="text-[10px] text-muted-foreground">
                                        {visibleDispatchGroup ? "正式外请分组跟踪中" : "回退车次跟踪中"}
                                      </span>
                                    );
                                  })()}
                                </div>
                              </TableCell>
                              <TableCell className="text-xs text-muted-foreground">
                                {formatPodSentDate(order)}
                              </TableCell>
                              <TableCell>
                                <InlineEdit
                                  value={(order as any).podTrackingNumber || ""}
                                  placeholder="填写快递单号"
                                  onSave={(val) => updateOrderFields.mutate({ id: order.id, podTrackingNumber: val })}
                                  className="max-w-[120px]"
                                />
                              </TableCell>
                              <TableCell>
                                <div className="flex items-center gap-1">
                                  {canMarkSent && (
                                    <Button
                                      size="sm"
                                      variant="outline"
                                      className="h-7 text-xs"
                                      onClick={async () => {
                                        await handleMarkPodSent([order]);
                                      }}
                                      disabled={markPodSent.isPending}
                                    >
                                      <Send className="h-3 w-3 mr-1" />
                                      标记已寄出
                                    </Button>
                                  )}
                                  {canCancelMark && (
                                    <Button
                                      size="sm"
                                      variant="outline"
                                      className="h-7 text-xs text-orange-600 border-orange-300 hover:bg-orange-50"
                                      onClick={async () => {
                                        await handleCancelPodSent([order]);
                                      }}
                                      disabled={cancelPodSent.isPending}
                                    >
                                      <Undo2 className="h-3 w-3 mr-1" />
                                      取消标记
                                    </Button>
                                  )}
                                  {!canMarkSent && !canCancelMark && (
                                    <span className="text-[10px] text-muted-foreground">
                                      {isCurrentOrderPodOwner(order) ? "当前回单已完成寄出处理" : "请在负责回单原件流转的订单上操作"}
                                    </span>
                                  )}
                                </div>
                              </TableCell>
                            </TableRow>
                          );
                        })}
                      </>
                    )}
                  </TableBody>
                </Table>
                <TablePagination total={sortedSignedOrders.length} page={podPage} pageSize={podPageSize} onPageChange={setPodPage} onPageSizeChange={setPodPageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 统一回单处理区：退押金闭环 */}
          <TabsContent value="pod-processing">
            <div className="mt-4 space-y-3">
              <div className="flex items-center justify-between rounded-xl border border-slate-200 bg-slate-50/80 px-4 py-3">
                <div>
                  <div className="text-sm font-medium text-slate-900">退押金处理</div>
                  <div className="text-xs text-slate-600">财务在回单台确认收到原件后，调度继续在当前页签完成押金退还。</div>
                </div>
              </div>
              {/* 批量操作栏 */}
              {selectedIds.size > 0 && activeTab === "pod-processing" && (
                <div className="flex flex-wrap items-center gap-2 rounded-lg border border-blue-200 bg-blue-50 p-2">
                  <span className="text-sm text-blue-700">已选 {selectedIds.size} 个</span>
                  <Badge variant="secondary" className="bg-green-100 text-green-700">
                    可直接退押金 {selectedPendingRefundSummary.refundableIds.length} 个
                  </Badge>
                  {selectedPendingRefundSummary.awaitingFinanceIds.length > 0 && (
                    <Badge variant="secondary" className="bg-blue-100 text-blue-700">
                      待财务确认 {selectedPendingRefundSummary.awaitingFinanceIds.length} 个
                    </Badge>
                  )}
                  {selectedPendingRefundSummary.blockedIds.length > 0 && (
                    <Badge variant="secondary" className="bg-amber-100 text-amber-700">
                      仍待司机寄出 {selectedPendingRefundSummary.blockedIds.length} 个
                    </Badge>
                  )}
                  <Button
                    size="sm"
                    variant="outline"
                    className="h-7 text-xs border-green-300 text-green-700 hover:bg-green-50"
                    disabled={batchRefundDepositMutation.isPending || selectedPendingRefundSummary.refundableIds.length === 0}
                    onClick={async () => {
                      if (selectedPendingRefundSummary.refundableIds.length === 0) {
                        toast.error(selectedPendingRefundSummary.awaitingFinanceIds.length > 0 ? "请先等待财务确认收到回单" : "请先补齐回单寄出标记");
                        return;
                      }
                      await batchRefundDepositMutation.mutateAsync({ ids: selectedPendingRefundSummary.refundableIds });
                    }}
                  >
                    <DollarSign className="h-3 w-3 mr-1" />批量退押金
                  </Button>
                </div>
              )}
            </div>
            <Card>
              <CardContent className="p-0">
                <div className="p-3 flex items-center gap-2">
                  <div className="relative min-w-[200px]">
                    <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                    <Input placeholder="搜索订单号/客户/车牌..." value={depositSearch} onChange={(e) => setDepositSearch(e.target.value)} className="pl-9 h-8" />
                  </div>
                </div>
                <div className="mx-3 mb-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800">
                  当前页签已经合并为“回单处理”，由调度在同一处连续完成“标记原件已寄出 → 等待财务确认收到 → 退还押金”。财务工作台仅负责确认收到回单，不再承担退押金操作。
                </div>
                <div className="mx-3 mb-3 flex flex-wrap items-center gap-2 rounded-lg border border-red-200 bg-red-50/70 px-3 py-2 text-xs text-red-800">
                  <Badge variant="secondary" className="bg-white text-red-700">
                    待处理 {groupedPendingRefund.length} 个正式外请组/车次
                  </Badge>
                  <span>
                    当前共有 {filteredPendingRefund.length} 笔押金相关记录，其中 {blockedPendingRefundOrderIds.size} 笔待司机寄出、{awaitingFinanceConfirmOrderIds.size} 笔待财务确认、{Math.max(filteredPendingRefund.length - blockedPendingRefundOrderIds.size - awaitingFinanceConfirmOrderIds.size, 0)} 笔可直接退押金。
                  </span>
                  {blockedPendingRefundOrderIds.size > 0 ? (
                    <span className="text-red-700/80">
                      请先在上方“回单处理”区补齐寄出标记；全部寄出后，财务回单台即可确认收到原件。
                    </span>
                  ) : awaitingFinanceConfirmOrderIds.size > 0 ? (
                    <span className="text-red-700/80">
                      财务确认收到前，押金按钮会保持锁定；一旦确认收件，调度即可在当前页签直接退押金。
                    </span>
                  ) : (
                    <span className="text-red-700/80">
                      当前可退押金记录已满足条件，调度可直接在本页完成退押金闭环。
                    </span>
                  )}
                </div>
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8">
                        <Checkbox
                          checked={filteredPendingRefund.length > 0 && filteredPendingRefund.every((o: any) => selectedIds.has(o.id))}
                          onCheckedChange={() => {
                            if (filteredPendingRefund.every((o: any) => selectedIds.has(o.id))) {
                              const next = new Set(selectedIds); filteredPendingRefund.forEach((o: any) => next.delete(o.id)); setSelectedIds(next);
                            } else {
                              const next = new Set(selectedIds); filteredPendingRefund.forEach((o: any) => next.add(o.id)); setSelectedIds(next);
                            }
                          }}
                        />
                      </TableHead>
                      <TableHead className="w-6"></TableHead>
                      <TableHead>客户订单号</TableHead>
                      <TableHead>客户 · 路线</TableHead>
                      <TableHead>押金金额</TableHead>
                      <TableHead>车牌 · 司机</TableHead>
                      <TableHead>货站开单</TableHead>
                      <TableHead>操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {depositLoading ? (
                      <TableRow><TableCell colSpan={8} className="text-center py-8 text-muted-foreground">加载中...</TableCell></TableRow>
                    ) : groupedPendingRefund.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={8} className="text-center py-8 text-muted-foreground">
                          {depositSearch ? "未找到匹配的押金记录" : "暂无待处理押金记录。后续当押金仍为待退还时，这里会在“回单处理”页签内按待寄出、待财务确认、可退押金三个阶段自动跟踪。"}
                        </TableCell>
                      </TableRow>
                    ) : groupedPendingRefund.map((group) => {
                      const isExpanded = expandedDepositGroups.has(group.key);

                      if (!group.isMerged) {
                        // 单个订单
                        const order = group.items[0];
                        return (
                          <TableRow key={order.id}>
                            <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                            <TableCell></TableCell>
                            <TableCell className="font-mono text-xs">
                              <div className="flex flex-col gap-1">
                                <div>{order.orderNumber || order.systemCode}</div>
                                {renderOutsourceSuborderPreview(order)}
                              </div>
                            </TableCell>
                            <TableCell>
                              <div className="text-sm">{order.customerName || "-"}</div>
                              <div className="flex items-center gap-1 text-xs text-muted-foreground">{order.originCity || "?"} <ArrowRight className="h-3 w-3" /> {order.destinationCity || "?"}</div>
                            </TableCell>
                            <TableCell className="font-medium text-red-600">{formatMoney(order.depositAmount)}</TableCell>
                            <TableCell className="text-xs">
                              <div>{order.plateNumber || "-"}</div>
                              <div className="text-muted-foreground">{order.driverName || "-"} {order.driverPhone || ""}</div>
                            </TableCell>
                            <TableCell>
                              {order.stationReceiptUrl ? <Button size="sm" variant="ghost" onClick={() => handleViewImage(order.stationReceiptUrl!)}><Eye className="h-3 w-3 mr-1" /> 查看</Button> : <span className="text-xs text-muted-foreground">-</span>}
                            </TableCell>
                            <TableCell>
                              <div className="flex flex-col items-start gap-1.5">
                                <div className="flex items-center gap-1">
                                  {!group.allPodsSent && (
                                    <PodProgressBadge sentCount={group.podSentCount} totalCount={group.podTotalCount} compact />
                                  )}
                                  {parseFloat(String(order.depositAmount || "0")) === 0 ? (
                                    // 押金为0，直接显示退还按钮，无需回单寄出和财务确认
                                    <Button
                                      size="sm"
                                      variant="outline"
                                      className="border-green-300 text-green-700 hover:bg-green-50"
                                      disabled={refundDepositMutation.isPending}
                                      onClick={async () => {
                                        await refundDepositMutation.mutateAsync({ id: order.id });
                                      }}
                                    >
                                      <DollarSign className="h-3 w-3 mr-1" />退还（0元）
                                    </Button>
                                  ) : !group.allPodsSent ? (
                                    <div className="relative group/tip">
                                      <Button size="sm" variant="destructive" disabled>
                                        <DollarSign className="h-3 w-3 mr-1" />待寄出回单
                                      </Button>
                                      <div className="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 bg-gray-800 text-white text-xs rounded whitespace-nowrap opacity-0 group-hover/tip:opacity-100 transition-opacity z-50">
                                        {group.podTotalCount > 1
                                          ? `当前分组/车次仍有 ${Math.max(group.podTotalCount - group.podSentCount, 0)} 份回单未寄出，暂不能退押金`
                                          : "当前分组/车次的回单原件尚未寄出，暂不能退押金"}
                                      </div>
                                    </div>
                                  ) : !group.allPodsReceived ? (
                                    <Button size="sm" variant="outline" className="border-blue-300 text-blue-700 hover:bg-blue-50" disabled>
                                      <FileText className="h-3 w-3 mr-1" />待财务确认收到
                                    </Button>
                                  ) : (
                                    <Button
                                      size="sm"
                                      variant="outline"
                                      className="border-green-300 text-green-700 hover:bg-green-50"
                                      disabled={refundDepositMutation.isPending}
                                      onClick={async () => {
                                        await refundDepositMutation.mutateAsync({ id: order.id });
                                      }}
                                    >
                                      <DollarSign className="h-3 w-3 mr-1" />退押金
                                    </Button>
                                  )}
                                  <DangerActionMenu
                                    onRollback={hasPermission("order.rollback") ? () => openRollbackDialog(order) : undefined}
                                    rollbackDisabled={Boolean(getRollbackLockReason(order))}
                                    onDelete={hasPermission("order.delete") ? () => openDeleteDialog(order) : undefined}
                                    deleteDisabled={Boolean(getDeleteLockReason(order))}
                                  />
                                </div>
                                {!group.allPodsSent ? (
                                  <p className="text-[11px] leading-4 text-muted-foreground">
                                    {group.podTotalCount > 1
                                      ? `当前正式外请分组/车次已寄出 ${group.podSentCount}/${group.podTotalCount} 份回单，剩余 ${Math.max(group.podTotalCount - group.podSentCount, 0)} 份寄出后才可进入财务确认。`
                                      : "请先在“回单处理”页签将该车次回单标记为“原件已寄出”，再等待财务确认收到。"}
                                  </p>
                                ) : !group.allPodsReceived ? (
                                  <p className="text-[11px] leading-4 text-blue-700">
                                    财务已确认 {group.podReceivedCount}/{group.podTotalCount} 份回单，全部确认收到后即可在当前页签直接退押金。
                                  </p>
                                ) : (
                                  <p className="text-[11px] leading-4 text-green-700">
                                    财务已确认收到该回单，调度可直接在当前页签完成退押金。
                                  </p>
                                )}
                              </div>
                            </TableCell>
                          </TableRow>
                        );
                      }

                      // 合并组
                      const allIds = group.items.map((o: any) => o.id);
                      const allSelected = allIds.every((id: number) => selectedIds.has(id));
                      return [
                        <TableRow key={`group_${group.key}`} className="bg-blue-50 hover:bg-blue-100/80 cursor-pointer border-l-2 border-l-blue-500" onClick={() => toggleDepositGroup(group.key)}>
                          <TableCell onClick={(e) => e.stopPropagation()}>
                            <Checkbox checked={allSelected} onCheckedChange={() => {
                              const next = new Set(selectedIds);
                              if (allSelected) allIds.forEach((id: number) => next.delete(id));
                              else allIds.forEach((id: number) => next.add(id));
                              setSelectedIds(next);
                            }} />
                          </TableCell>
                          <TableCell>{isExpanded ? <ChevronDown className="h-4 w-4 text-blue-600" /> : <ChevronRight className="h-4 w-4 text-blue-600" />}</TableCell>
                          <TableCell>
                            <div className="space-y-1">
                              <div className="flex items-center gap-1.5 text-xs">
                                <Layers className="h-3.5 w-3.5 text-blue-600" />
                                <span className="font-medium text-blue-700">{group.groupHeadline}</span>
                                <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-300 bg-blue-100 text-blue-700">同批 {group.items.length} 单</Badge>
                                <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-200 bg-white/80 text-blue-700">回单处理口径</Badge>
                              </div>
                              <div className="text-[10px] text-blue-700/80">{group.groupSubline}</div>
                              <div className="text-[10px] text-blue-700/70">共 {group.items.length} 单，本组回单寄出、财务确认与退押金均按当前组头口径联动，子订单仅保留明细预览。</div>
                            </div>
                          </TableCell>
                          <TableCell>
                            <div className="text-sm">{getGroupCustomerCargoSummary(group.items)}</div>
                            <div className="text-xs text-muted-foreground">{getGroupRouteSummary(group.items)}</div>
                          </TableCell>
                          <TableCell className="font-bold text-red-600">¥{group.totalDeposit.toFixed(2)}</TableCell>
                          <TableCell className="text-xs"><div className="font-medium">{group.plateNumber}</div><div className="text-muted-foreground">{group.driverName} {group.driverPhone}</div></TableCell>
                          <TableCell className="text-xs text-muted-foreground">已录货站开单 {group.items.filter((order: any) => Boolean(order.stationReceiptUrl)).length}/{group.items.length}</TableCell>
                          <TableCell onClick={(e) => e.stopPropagation()}>
                            <div className="flex flex-col items-start gap-1.5">
                              <div className="flex items-center gap-2">
                                {!group.allPodsSent && (
                                  <PodProgressBadge sentCount={group.podSentCount} totalCount={group.podTotalCount} />
                                )}
                                {group.totalDeposit === 0 ? (
                                  // 押金为0，直接显示退还按钮，无需回单寄出和财务确认
                                  <Button
                                    size="sm"
                                    variant="outline"
                                    className="border-green-300 text-green-700 hover:bg-green-50"
                                    disabled={batchRefundDepositMutation.isPending}
                                    onClick={async () => {
                                      await batchRefundDepositMutation.mutateAsync({ ids: allIds });
                                    }}
                                  >
                                    <DollarSign className="h-3 w-3 mr-1" />整组退还（0元）
                                  </Button>
                                ) : !group.allPodsSent ? (
                                  <div className="relative group/tip inline-block">
                                    <Button size="sm" variant="destructive" disabled>
                                      <DollarSign className="h-3 w-3 mr-1" />整组待寄出 ¥{group.totalDeposit.toFixed(0)}
                                    </Button>
                                    <div className="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 bg-gray-800 text-white text-xs rounded whitespace-nowrap opacity-0 group-hover/tip:opacity-100 transition-opacity z-50">当前组头对应的正式外请分组/回退车次仍有回单未寄出，暂不能退押金</div>
                                  </div>
                                ) : !group.allPodsReceived ? (
                                  <Button size="sm" variant="outline" className="border-blue-300 text-blue-700 hover:bg-blue-50" disabled>
                                    <FileText className="h-3 w-3 mr-1" />整组待财务确认 ¥{group.totalDeposit.toFixed(0)}
                                  </Button>
                                ) : (
                                  <Button
                                    size="sm"
                                    variant="outline"
                                    className="border-green-300 text-green-700 hover:bg-green-50"
                                    disabled={batchRefundDepositMutation.isPending}
                                    onClick={async () => {
                                      await batchRefundDepositMutation.mutateAsync({ ids: allIds });
                                    }}
                                  >
                                    <DollarSign className="h-3 w-3 mr-1" />整组退押金 ¥{group.totalDeposit.toFixed(0)}
                                  </Button>
                                )}
                              </div>
                              {!group.allPodsSent ? (
                                <p className="text-[11px] leading-4 text-muted-foreground">
                                  当前组头对应的正式外请分组/回退车次已寄出 {group.podSentCount}/{group.podTotalCount} 份回单，剩余 {Math.max(group.podTotalCount - group.podSentCount, 0)} 份寄出后才可进入财务确认。
                                </p>
                              ) : !group.allPodsReceived ? (
                                <p className="text-[11px] leading-4 text-blue-700">
                                  当前组头对应的正式外请分组/回退车次已确认收到 {group.podReceivedCount}/{group.podTotalCount} 份回单，全部确认后即可整组退押金。
                                </p>
                              ) : (
                                <p className="text-[11px] leading-4 text-green-700">
                                  当前组头对应的正式外请分组/回退车次已全部确认收到回单，可直接在找车台整组退押金。
                                </p>
                              )}
                            </div>
                          </TableCell>
                        </TableRow>,
                        ...(isExpanded ? group.items.map((order: any) => (
                          <TableRow key={order.id} className="bg-blue-50/30 border-l-2 border-l-blue-200">
                            <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                            <TableCell></TableCell>
                            <TableCell className="font-mono text-xs pl-6">
                              <div className="flex flex-col gap-1">
                                <div><span className="text-muted-foreground pl-2">└</span> {order.orderNumber || order.systemCode}</div>
                                {renderOutsourceSuborderPreview(order)}
                              </div>
                            </TableCell>
                            <TableCell>
                              <div className="text-sm">{order.customerName || "-"}</div>
                              <div className="flex items-center gap-1 text-xs text-muted-foreground">{order.originCity || "?"} <ArrowRight className="h-3 w-3" /> {order.destinationCity || "?"}</div>
                            </TableCell>
                            <TableCell className="font-medium text-red-600">{formatMoney(order.depositAmount)}</TableCell>
                            <TableCell className="text-xs"><div>{order.plateNumber || "-"}</div><div className="text-muted-foreground">{order.driverName || "-"}</div></TableCell>
                            <TableCell>
                              {order.stationReceiptUrl ? <Button size="sm" variant="ghost" onClick={() => handleViewImage(order.stationReceiptUrl!)}><Eye className="h-3 w-3 mr-1" /> 查看</Button> : <span className="text-xs text-muted-foreground">-</span>}
                            </TableCell>
                            <TableCell>
                              <span className="text-[10px] text-muted-foreground">跟随当前分组/车次整组处理回单与退押金</span>
                            </TableCell>
                          </TableRow>
                        )) : []),
                      ];
                    })}
                  </TableBody>
                </Table>
                <TablePagination total={groupedPendingRefund.length} page={depositPendingPage} pageSize={depositPendingPageSize} onPageChange={setDepositPendingPage} onPageSizeChange={setDepositPendingPageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 历史押金已处理内容已迁移至回单押金台，保留代码仅作兼容占位 */}
          <TabsContent value="legacy-deposit-done-hidden">
            {/* 批量操作栏 */}
            {selectedIds.size > 0 && activeTab === "deposit_done" && (
              <div className="flex flex-wrap items-center gap-2 mb-3 rounded-lg border border-blue-200 bg-blue-50 p-2">
                <span className="text-sm text-blue-700">已选 {selectedIds.size} 个</span>
                <Badge variant="secondary" className="bg-green-100 text-green-700">
                  已退还 {filteredDoneDeposit.filter((o) => selectedIds.has(o.id) && o.depositStatus === "refunded").length} 个
                </Badge>
                <Badge variant="secondary" className="bg-slate-100 text-slate-700">
                  不退还 {filteredDoneDeposit.filter((o) => selectedIds.has(o.id) && o.depositStatus === "not_refundable").length} 个
                </Badge>
                <span className="text-xs text-blue-700/80">
                  已处理押金仅支持逐单补原因后退回；当前批量操作会按你勾选的记录逐个打开退回流程。
                </span>
                <Button size="sm" variant="outline" className="text-orange-600 border-orange-300 h-7 text-xs" onClick={() => {
                  const toRollback = filteredDoneDeposit.filter(o => selectedIds.has(o.id));
                  if (toRollback.length === 0) return;
                  toRollback.forEach(o => { setRollbackTargetId(o.id); setRollbackReason(""); });
                  toast.info(`请逐个确认退回操作（共 ${toRollback.length} 个）`);
                }}>
                  <Undo2 className="h-3 w-3 mr-1" />批量退回
                </Button>
              </div>
            )}
            <Card>
              <CardContent className="p-0">
                <div className="mx-3 mt-3 rounded-lg border border-green-200 bg-green-50 px-3 py-2 text-xs text-green-800">
                  已处理押金用于回看“已退还 / 不退还”结果。若需回退，请逐单补充原因后退回上一流程节点，避免直接覆盖已完成的财务状态。
                </div>
                <div className="mx-3 mt-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700">
                  当前筛选下共有 {filteredDoneDeposit.length} 笔已处理押金，其中已退还 {filteredDoneDeposit.filter((order) => order.depositStatus === "refunded").length} 笔，不退还 {filteredDoneDeposit.filter((order) => order.depositStatus === "not_refundable").length} 笔。
                  {selectedIds.size > 0
                    ? ` 已勾选 ${selectedIds.size} 笔；如需回退，将按勾选顺序逐笔要求补充退回原因。`
                    : " 如需回退，请先勾选目标记录，再逐单确认退回原因。"}
                </div>
                <div className="p-3 flex items-center gap-2">
                  <div className="relative min-w-[200px]">
                    <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
                    <Input placeholder="搜索订单号/客户/车牌..." value={depositSearch} onChange={(e) => setDepositSearch(e.target.value)} className="pl-9 h-8" />
                  </div>
                  <Select value={depositStatusFilter} onValueChange={setDepositStatusFilter}>
                    <SelectTrigger className="w-[120px] h-8">
                      <SelectValue placeholder="押金状态" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="all">全部</SelectItem>
                      <SelectItem value="refunded">已退还</SelectItem>
                      <SelectItem value="not_refundable">不退还</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead className="w-8">
                        <Checkbox
                          checked={filteredDoneDeposit.length > 0 && filteredDoneDeposit.every((o: any) => selectedIds.has(o.id))}
                          onCheckedChange={() => {
                            if (filteredDoneDeposit.every((o: any) => selectedIds.has(o.id))) {
                              const next = new Set(selectedIds); filteredDoneDeposit.forEach((o: any) => next.delete(o.id)); setSelectedIds(next);
                            } else {
                              const next = new Set(selectedIds); filteredDoneDeposit.forEach((o: any) => next.add(o.id)); setSelectedIds(next);
                            }
                          }}
                        />
                      </TableHead>
                      <TableHead>客户订单号</TableHead>
                      <TableHead>客户 · 路线</TableHead>
                      <TableHead>押金金额</TableHead>
                      <TableHead>状态</TableHead>
                      <TableHead>退押日期</TableHead>
                      <TableHead>车牌 · 司机</TableHead>
                      <TableHead>操作</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredDoneDeposit.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={8} className="text-center py-8 text-muted-foreground">
                          {depositSearch ? "未找到匹配的记录" : "暂无已处理押金；完成退押金或确认不退还后，这里会展示处理结果与退押日期。"}
                        </TableCell>
                      </TableRow>
                    ) : (
                      <>
                        {groupedDoneDeposit.groups.map((group) => {
                          const isExpanded = expandedDoneDepositGroups.has(group.key);
                          const allIds = group.items.map((item: any) => item.id);
                          const allSelected = allIds.every((id: number) => selectedIds.has(id));
                          const refundTimes = group.items
                            .map((item: any) => item.depositRefundDate ? new Date(item.depositRefundDate).getTime() : NaN)
                            .filter((time: number) => Number.isFinite(time));
                          const refundDateSummary = refundTimes.length ? fmtDate(new Date(Math.max(...refundTimes))) : "-";
                          return (
                            <React.Fragment key={group.key}>
                              <TableRow className="bg-blue-50 hover:bg-blue-100/80 cursor-pointer border-l-2 border-l-blue-500" onClick={() => toggleDoneDepositGroup(group.key)}>
                                <TableCell onClick={(e) => e.stopPropagation()}>
                                  <Checkbox
                                    checked={allSelected}
                                    onCheckedChange={() => {
                                      setSelectedIds(prev => {
                                        const next = new Set(prev);
                                        if (allSelected) allIds.forEach((id: number) => next.delete(id));
                                        else allIds.forEach((id: number) => next.add(id));
                                        return next;
                                      });
                                    }}
                                  />
                                </TableCell>
                                <TableCell className="table-cell-readable font-mono text-xs align-top">
                                  <div className="space-y-1">
                                    <div className="flex flex-wrap items-center gap-1.5">
                                      {isExpanded ? <ChevronDown className="h-4 w-4 text-blue-600" /> : <ChevronRight className="h-4 w-4 text-blue-600" />}
                                      <Layers className="h-4 w-4 text-blue-600" />
                                      <span className="font-medium text-blue-700">{group.groupHeadline}</span>
                                      <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-300 bg-blue-100 text-blue-700">同批 {group.items.length} 单</Badge>
                                      <Badge variant="outline" className="h-5 px-1.5 text-[10px] border-blue-200 bg-white/80 text-blue-700">押金已处理口径</Badge>
                                    </div>
                                    <div className="text-[10px] text-blue-700/80">{group.groupSubline}</div>
                                    <div className="text-[10px] text-blue-700/70">已处理押金结果按当前组头聚合回看；如需回退，请先勾选整组再使用顶部批量退回。</div>
                                  </div>
                                </TableCell>
                                <TableCell>
                                  <div className="text-sm">{group.customerCargoSummary}</div>
                                  <div className="flex items-center gap-1 text-xs text-muted-foreground">{group.routeSummary}</div>
                                </TableCell>
                                <TableCell className="font-medium">{formatMoney(group.totalDeposit)}</TableCell>
                                <TableCell>
                                  <div className="flex flex-wrap items-center gap-1">
                                    {group.refundedCount > 0 && <Badge variant="secondary" className="bg-green-100 text-green-700">已退还 {group.refundedCount}</Badge>}
                                    {group.notRefundableCount > 0 && <Badge variant="secondary" className="bg-gray-100 text-gray-700">不退还 {group.notRefundableCount}</Badge>}
                                  </div>
                                </TableCell>
                                <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">{refundDateSummary}</TableCell>
                                <TableCell className="text-xs">{group.vehicleSummary}</TableCell>
                                <TableCell>
                                  <span className="text-[10px] text-muted-foreground">如需回退，请勾选整组后使用顶部批量退回</span>
                                </TableCell>
                              </TableRow>
                              {isExpanded && group.items.map((order: any) => (
                                <TableRow key={order.id} className="bg-blue-50/30 border-l-2 border-l-blue-200">
                                  <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                                  <TableCell className="table-cell-readable font-mono text-xs align-top"><span className="text-muted-foreground pl-2">└</span> {order.orderNumber || order.systemCode}</TableCell>
                                  <TableCell>
                                    <div className="text-sm">{order.customerName || "-"}</div>
                                    <div className="flex items-center gap-1 text-xs text-muted-foreground">
                                      {order.originCity || "?"} <ArrowRight className="h-3 w-3" /> {order.destinationCity || "?"}
                                    </div>
                                  </TableCell>
                                  <TableCell className="font-medium">{formatMoney(order.depositAmount)}</TableCell>
                                  <TableCell>
                                    <Badge variant="secondary" className={order.depositStatus === "refunded" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700"}>
                                      {order.depositStatus === "refunded" ? "已退还" : "不退还"}
                                    </Badge>
                                  </TableCell>
                                  <TableCell className="table-cell-readable text-xs text-muted-foreground align-top">
                                    {(order as any).depositRefundDate ? new Date((order as any).depositRefundDate).toLocaleDateString("zh-CN") : "-"}
                                  </TableCell>
                                  <TableCell className="text-xs">
                                    <div>{order.plateNumber || "-"}</div>
                                    <div className="text-muted-foreground">{order.driverName || "-"}</div>
                                  </TableCell>
                                  <TableCell>
                                    <span className="text-[10px] text-muted-foreground">跟随当前分组/车次整组回看与退回</span>
                                  </TableCell>
                                </TableRow>
                              ))}
                            </React.Fragment>
                          );
                        })}
                        {groupedDoneDeposit.ungrouped.map((order) => (
                          <TableRow key={order.id}>
                            <TableCell><Checkbox checked={selectedIds.has(order.id)} onCheckedChange={() => toggleSelect(order.id)} /></TableCell>
                            <TableCell className="font-mono text-xs">{order.orderNumber || order.systemCode}</TableCell>
                            <TableCell>
                              <div className="text-sm">{order.customerName || "-"}</div>
                              <div className="flex items-center gap-1 text-xs text-muted-foreground">
                                {order.originCity || "?"} <ArrowRight className="h-3 w-3" /> {order.destinationCity || "?"}
                              </div>
                            </TableCell>
                            <TableCell className="font-medium">{formatMoney(order.depositAmount)}</TableCell>
                            <TableCell>
                              <Badge variant="secondary" className={order.depositStatus === "refunded" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700"}>
                                {order.depositStatus === "refunded" ? "已退还" : "不退还"}
                              </Badge>
                            </TableCell>
                            <TableCell className="text-xs text-muted-foreground">
                              {(order as any).depositRefundDate ? new Date((order as any).depositRefundDate).toLocaleDateString("zh-CN") : "-"}
                            </TableCell>
                            <TableCell className="text-xs">
                              <div>{order.plateNumber || "-"}</div>
                              <div className="text-muted-foreground">{order.driverName || "-"}</div>
                            </TableCell>
                            <TableCell>
                              <div className="flex items-center gap-1">
                                {hasPermission("order.rollback") && (
                                  <Button variant="ghost" size="sm" className="h-7 px-2 text-orange-600 hover:text-orange-700 hover:bg-orange-50"
                                    onClick={() => openRollbackDialog(order)} title={getRollbackLockReason(order) || "退回上一步"} disabled={Boolean(getRollbackLockReason(order))}>
                                    <Undo2 className="h-3.5 w-3.5 mr-1" />退回订单状态
                                  </Button>
                                )}
                              </div>
                            </TableCell>
                          </TableRow>
                        ))}
                      </>
                    )}
                  </TableBody>
                </Table>
                <TablePagination total={filteredDoneDeposit.length} page={depositDonePage} pageSize={depositDonePageSize} onPageChange={setDepositDonePage} onPageSizeChange={setDepositDonePageSize} />
              </CardContent>
            </Card>
          </TabsContent>

          {/* 历史超期回单监控内容已迁移至回单押金台，保留代码仅作兼容占位 */}
          <TabsContent value="legacy-overdue-outsource-hidden">
            <div className="mb-3 rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs text-red-800">
              该页签仅监控外请订单的回单超期情况。若某单仍停留在待签收、未进入回单跟踪，需先在运输流程中推进订单状态后，超期提醒才会进入本页统计。
            </div>
            {/* 超期预警横幅 */}
            {outsourceOverdueData.total > 0 && (
              <div className="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg flex items-center gap-3">
                <Siren className="w-6 h-6 text-red-500 animate-pulse" />
                <div className="flex-1">
                  <p className="font-semibold text-red-700">外请回单超期预警：共 {outsourceOverdueData.total} 笔超期</p>
                  <p className="text-sm text-red-600">
                    黄色预警（≤5天）{outsourceOverdueData.yellow}笔 ·
                    橙色警告（5-15天）{outsourceOverdueData.orange}笔 ·
                    红色紧急（≥15天）{outsourceOverdueData.red}笔
                  </p>
                </div>
                <Button variant="outline" size="sm" onClick={() => refetchOutsourceOverdue()}>
                  <RefreshCw className="w-3.5 h-3.5 mr-1" /> 刷新
                </Button>
              </div>
            )}

            {/* 超期分级统计卡片 */}
            <div className="grid grid-cols-4 gap-3 mb-4">
              <Card className={`cursor-pointer border-2 transition-all ${
                overdueFilter === "all" ? "border-blue-500 bg-blue-50" : "hover:border-gray-300"
              }`} onClick={() => setOverdueFilter("all")}>
                <CardContent className="p-3 text-center">
                  <p className="text-2xl font-bold">{outsourceOverdueData.total}</p>
                  <p className="text-xs text-muted-foreground">全部超期</p>
                </CardContent>
              </Card>
              <Card className={`cursor-pointer border-2 transition-all ${
                overdueFilter === "yellow" ? "border-yellow-500 bg-yellow-50" : "hover:border-yellow-200"
              }`} onClick={() => setOverdueFilter("yellow")}>
                <CardContent className="p-3 text-center">
                  <p className="text-2xl font-bold text-yellow-600">{outsourceOverdueData.yellow}</p>
                  <p className="text-xs text-yellow-600">黄色预警（≤5天）</p>
                </CardContent>
              </Card>
              <Card className={`cursor-pointer border-2 transition-all ${
                overdueFilter === "orange" ? "border-orange-500 bg-orange-50" : "hover:border-orange-200"
              }`} onClick={() => setOverdueFilter("orange")}>
                <CardContent className="p-3 text-center">
                  <p className="text-2xl font-bold text-orange-600">{outsourceOverdueData.orange}</p>
                  <p className="text-xs text-orange-600">橙色警告（5-15天）</p>
                </CardContent>
              </Card>
              <Card className={`cursor-pointer border-2 transition-all ${
                overdueFilter === "red" ? "border-red-500 bg-red-50" : "hover:border-red-200"
              }`} onClick={() => setOverdueFilter("red")}>
                <CardContent className="p-3 text-center">
                  <p className="text-2xl font-bold text-red-600">{outsourceOverdueData.red}</p>
                  <p className="text-xs text-red-600">红色紧急（≥15天）</p>
                </CardContent>
              </Card>
            </div>

            <div className="mb-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700">
              当前筛选：
              {overdueFilter === "all"
                ? "全部超期等级"
                : overdueFilter === "yellow"
                  ? "黄色预警（≤5天）"
                  : overdueFilter === "orange"
                    ? "橙色警告（5-15天）"
                    : "红色紧急（≥15天）"}
              ，共 {filteredOutsourceOverdueItems.length} 笔。
              {filteredOutsourceOverdueItems.length > 0
                ? " 建议优先处理红色与橙色订单，并回到回单跟踪页签补齐寄出或收回动作。"
                : " 若本页为空，可先确认订单是否已推进到签收后的回单跟踪阶段，达到预警阈值后才会出现在这里。"}
            </div>

            {/* 超期回单列表 */}
            <Card>
              <CardContent className="p-0">
                <Table>
                  <TableHeader>
                    <TableRow>
                      <TableHead>超期等级</TableHead>
                      <TableHead>订单号</TableHead>
                      <TableHead>客户名</TableHead>
                      <TableHead>路线</TableHead>
                      <TableHead>车牌号</TableHead>
                      <TableHead>司机</TableHead>
                      <TableHead>超期天数</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {filteredOutsourceOverdueItems.length === 0 ? (
                      <TableRow>
                        <TableCell colSpan={7} className="text-center py-8 text-muted-foreground">
                          <CheckCircle2 className="h-8 w-8 mx-auto mb-2 text-green-400" />
                          {overdueFilter === "all"
                            ? "当前暂无外请超期回单；已签收但尚未超时的订单会在达到预警阈值后自动进入这里。"
                            : "该等级暂无超期回单，可切换其他等级或返回全部查看。"}
                        </TableCell>
                      </TableRow>
                    ) : (
                      filteredOutsourceOverdueItems.map((item: any, idx: number) => (
                        <TableRow
                          key={idx}
                          className={`${
                            item.level === "red"
                              ? "bg-red-50"
                              : item.level === "orange"
                                ? "bg-orange-50"
                                : item.level === "yellow"
                                  ? "bg-yellow-50"
                                  : ""
                          }`}
                        >
                          <TableCell>
                            <Badge
                              className={`${
                                item.level === "red"
                                  ? "bg-red-500"
                                  : item.level === "orange"
                                    ? "bg-orange-500"
                                    : "bg-yellow-500"
                              } text-white`}
                            >
                              {item.level === "red" ? "🔴 紧急" : item.level === "orange" ? "🟠 警告" : "🟡 预警"}
                            </Badge>
                          </TableCell>
                          <TableCell className="font-mono text-xs">{item.orderNumber || item.systemCode || "-"}</TableCell>
                          <TableCell>{item.customerName || "-"}</TableCell>
                          <TableCell className="text-xs">{item.originCity || "-"} → {item.destinationCity || "-"}</TableCell>
                          <TableCell>{item.plateNumber || "-"}</TableCell>
                          <TableCell>{item.driverName || "-"}</TableCell>
                          <TableCell>
                            <span
                              className={`font-bold ${
                                item.level === "red"
                                  ? "text-red-600"
                                  : item.level === "orange"
                                    ? "text-orange-600"
                                    : "text-yellow-600"
                              }`}
                            >
                              {item.overdueDays}天
                            </span>
                          </TableCell>
                        </TableRow>
                      ))
                    )}
                  </TableBody>
                </Table>
                <TablePagination total={filteredOutsourceOverdueItems.length} page={overduePage} pageSize={overduePageSize} onPageChange={setOverduePage} onPageSizeChange={setOverduePageSize} />
              </CardContent>
            </Card>
          </TabsContent>

        </Tabs>

        {/* 找车+报价弹窗 - 显示完整订单信息 */}
        <Dialog open={!!dispatchDialog} onOpenChange={(open) => !open && setDispatchDialog(null)}>
          <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
            <DialogHeader>
              <DialogTitle className="flex items-center gap-2">
                <Truck className="h-5 w-5 text-blue-500" />
                外请找车 + 填报价
                {dispatchDialog?.isUrgent && <Badge variant="destructive">加急</Badge>}
              </DialogTitle>
            </DialogHeader>
            {dispatchDialog && (
              <div className="space-y-4">
                {/* 完整订单信息区域 */}
                <div className="bg-muted/50 rounded-lg p-4 space-y-3">
                  <div className="text-sm font-semibold text-foreground border-b pb-2 mb-2">订单详情</div>
                  
                  {/* 订单号和状态 */}
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-2">
                      <FileText className="h-4 w-4 text-muted-foreground" />
                      <span className="text-sm font-medium">客户订单号：</span>
                      <span className="text-sm font-mono">{dispatchDialog.orderNumber || "未填写"}</span>
                    </div>
                    <span className="text-xs text-muted-foreground font-mono">{dispatchDialog.orderNumber || dispatchDialog.systemCode}</span>
                  </div>

                  {/* 客户信息 */}
                  <div className="flex items-center gap-2">
                    <User className="h-4 w-4 text-muted-foreground" />
                    <span className="text-sm font-medium">客户：</span>
                    <span className="text-sm">{dispatchDialog.customerName || "-"}</span>
                    {dispatchDialog.customerPhone && (
                      <span className="text-xs text-muted-foreground ml-2">
                        <Phone className="h-3 w-3 inline mr-0.5" />{dispatchDialog.customerPhone}
                      </span>
                    )}
                  </div>

                  {/* 货物信息 */}
                  <div className="flex items-center gap-2">
                    <Package className="h-4 w-4 text-muted-foreground" />
                    <span className="text-sm font-medium">货物：</span>
                    <span className="text-sm">{dispatchDialog.cargoName || "-"}</span>
                    <span className="text-sm text-muted-foreground">
                      {dispatchDialog.weight ? `${dispatchDialog.weight}t` : ""}
                      {dispatchDialog.packagingType === "pallet" ? " · 托盘" : dispatchDialog.packagingType === "loose" ? " · 散装" : dispatchDialog.packagingType === "pallet_loaded" ? " · 托盘装车" : ""}
                    </span>
                  </div>
                  {dispatchDialog.cargoSpec && (
                    <div className="text-xs text-muted-foreground ml-6">规格：{dispatchDialog.cargoSpec}</div>
                  )}
                  {dispatchDialog.specialRequirements && (
                    <div className="text-xs text-orange-600 ml-6">特殊要求：{dispatchDialog.specialRequirements}</div>
                  )}

                  {/* 发货信息 */}
                  <div className="bg-blue-50 rounded p-2.5 space-y-1">
                    <div className="flex items-center gap-2">
                      <MapPin className="h-4 w-4 text-blue-500" />
                      <span className="text-sm font-medium text-blue-700">发货地</span>
                    </div>
                    <div className="text-sm ml-6">
                      <span className="font-medium">{dispatchDialog.originCity || "-"}</span>
                      {dispatchDialog.warehouseName && (
                        <span className="text-muted-foreground"> · 仓库：{dispatchDialog.warehouseName}</span>
                      )}
                    </div>
                  </div>

                  {/* 卸货信息 */}
                  <div className="bg-green-50 rounded p-2.5 space-y-1">
                    <div className="flex items-center gap-2">
                      <MapPin className="h-4 w-4 text-green-500" />
                      <span className="text-sm font-medium text-green-700">卸货地</span>
                    </div>
                    <div className="text-sm ml-6">
                      <span className="font-medium">{dispatchDialog.destinationCity || "-"}</span>
                      {dispatchDialog.deliveryAddress && (
                        <div className="text-muted-foreground text-xs mt-0.5">地址：{dispatchDialog.deliveryAddress}</div>
                      )}
                      {(dispatchDialog.receiverName || dispatchDialog.receiverPhone) && (
                        <div className="text-muted-foreground text-xs mt-0.5">
                          收货人：{dispatchDialog.receiverName || "-"} {dispatchDialog.receiverPhone || ""}
                        </div>
                      )}
                    </div>
                  </div>

                  {/* 调度价 */}
                  {dispatchDialog.dispatchPrice && (
                    <div className="flex items-center gap-2 bg-orange-50 rounded p-2.5">
                      <DollarSign className="h-4 w-4 text-orange-500" />
                      <span className="text-sm font-medium text-orange-700">调度价：{formatMoney(dispatchDialog.dispatchPrice)}</span>
                    </div>
                  )}

                  {/* 订单备注 */}
                  {dispatchDialog.remarks && (
                    <div className="note-panel-readable bg-yellow-50">
                      <div className="field-label-muted text-yellow-700">订单备注</div>
                      <div className="field-value-readable text-yellow-800 text-wrap-keep-linebreaks">{dispatchDialog.remarks}</div>
                    </div>
                  )}

                  {/* 加急原因 */}
                  {dispatchDialog.isUrgent && dispatchDialog.urgentReason && (
                    <div className="note-panel-readable bg-red-50">
                      <div className="field-label-muted text-red-700">加急原因</div>
                      <div className="field-value-readable text-red-800 text-wrap-keep-linebreaks">{dispatchDialog.urgentReason}</div>
                    </div>
                  )}
                </div>

                  {mergedLtlPickupNeedsApproval && (
                    <div className="rounded-lg border border-purple-200 bg-purple-50 px-3 py-2 text-xs leading-5 text-purple-800">
                      当前订单属于<strong>零担前段合并外请</strong>，找车完成后必须先进入外请审批，审批通过后才会进入确认派车。
                    </div>
                  )}

                  {/* 报价信息填写区域 */}

                <div className="space-y-3 border-t pt-4">
                  <div className="text-sm font-semibold">报价与押金信息</div>
                  <div>
                    <Label>实际运费（报价）</Label>
                    <Input
                      type="number"
                      placeholder="与车队谈好的运费"
                      value={quotePrice}
                      onChange={(e) => setQuotePrice(e.target.value)}
                      className="mt-1"
                    />
                    {quotePrice && dispatchDialog?.dispatchPrice && parseFloat(quotePrice) > parseFloat(dispatchDialog.dispatchPrice) && (
                      <p className="text-xs text-red-500 mt-1 flex items-center gap-1">
                        <AlertTriangle className="h-3 w-3" />
                        运费超出调度价 ¥{(parseFloat(quotePrice) - parseFloat(dispatchDialog.dispatchPrice)).toFixed(0)}元，需提交审批
                      </p>
                    )}
                  </div>
                  <div className="grid grid-cols-2 gap-3">
                    <div>
                      <Label>押金金额 <span className="text-red-500">*</span></Label>
                      <Input
                        type="number"
                        placeholder="押金金额（无押金填0）"
                        value={depositAmount}
                        onChange={(e) => { setDepositAmount(e.target.value); setDepositError(false); }}
                        className={`mt-1 ${depositError ? "border-red-500 ring-2 ring-red-200 animate-pulse" : ""}`}
                      />
                      {depositError && (
                        <p className="text-xs text-red-500 mt-1 flex items-center gap-1">
                          <AlertTriangle className="h-3 w-3" />
                          请填写押金金额，无押金请填 0
                        </p>
                      )}
                    </div>
                    <div>
                      <Label>押金退还</Label>
                      <Select value={depositRefundable} onValueChange={setDepositRefundable}>
                        <SelectTrigger className="mt-1">
                          <SelectValue />
                        </SelectTrigger>
                        <SelectContent>
                          <SelectItem value="yes">可退还</SelectItem>
                          <SelectItem value="no">不退还</SelectItem>
                        </SelectContent>
                      </Select>
                    </div>
                  </div>

                  {/* 收货备注已在列表中填写，此处显示已填写的备注 */}
                  {dispatchDialog?.receivingNote && (
                    <div className="note-panel-readable bg-orange-50">
                      <div className="field-label-muted text-orange-700">收货备注</div>
                      <div className="field-value-readable text-orange-800 text-wrap-keep-linebreaks">{dispatchDialog.receivingNote}</div>
                    </div>
                  )}

                  {/* 调度员备注 */}
                  <div>
                    <Label>调度员备注（选填）</Label>
                    <Textarea
                      placeholder="如：卸货马上付款、卸货3日内付款、司机要求XXX等"
                      value={dispatcherRemark}
                      onChange={(e) => setDispatcherRemark(e.target.value)}
                      className="mt-1"
                      rows={2}
                    />
                    {dispatcherRemark.trim() && (
                      <p className="text-xs text-amber-600 mt-1 flex items-center gap-1">
                        <AlertTriangle className="h-3 w-3" />
                        填写备注后将自动提交审批，由主管确认
                      </p>
                    )}
                  </div>

                  <p className="text-xs text-muted-foreground">
                    {needsApproval
                      ? "⚠ 运费超出调度价或有备注，将提交审批"
                      : "✅ 运费未超出调度价且无备注，提交后进入已调度"}
                  </p>
                  <p className="text-xs text-blue-500 flex items-center gap-1">
                    <AlertTriangle className="h-3 w-3" />
                    车辆与司机信息在"已调度"Tab确认派车时填写
                  </p>
                </div>
              </div>
            )}
            <DialogFooter>
              <Button variant="outline" onClick={() => setDispatchDialog(null)}>取消</Button>
              <Button
                onClick={confirmDispatch}
                disabled={updateStatus.isPending}
                variant={needsApproval ? "default" : "default"}
                className={needsApproval ? "bg-purple-600 hover:bg-purple-700" : ""}
              >
                {updateStatus.isPending && <Loader2 className="h-4 w-4 mr-1 animate-spin" />}
                {updateStatus.isPending ? "处理中..." : needsApproval ? "提交审批" : "确认派车"}
              </Button>
            </DialogFooter>
          </DialogContent>
        </Dialog>
      </div>

      {/* 删除确认弹窗 */}
      <AlertDialog open={deleteTargetId !== null} onOpenChange={(open) => !open && setDeleteTargetId(null)}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>确认删除</AlertDialogTitle>
            <AlertDialogDescription>确定要删除这个订单吗？删除后不可恢复。</AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>取消</AlertDialogCancel>
            <AlertDialogAction
              className="bg-destructive text-destructive-foreground hover:bg-destructive/90"
              onClick={() => deleteTargetId && deleteMutation.mutate({ id: deleteTargetId })}
              disabled={deleteMutation.isPending}
            >
              {deleteMutation.isPending ? "删除中..." : "确认删除"}
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
      <AlertDialog open={batchDeleteOpen} onOpenChange={(open) => !open && setBatchDeleteOpen(false)}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>确认批量删除</AlertDialogTitle>
            <AlertDialogDescription>
              已选择 {selectedIds.size} 个订单。批量删除后不可恢复，请确认是否继续。
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>取消</AlertDialogCancel>
            <AlertDialogAction
              className="bg-destructive text-destructive-foreground hover:bg-destructive/90"
              onClick={() => batchDeleteMutation.mutate({ ids: Array.from(selectedIds) })}
              disabled={batchDeleteMutation.isPending}
            >
              {batchDeleteMutation.isPending ? "删除中..." : `确认删除 ${selectedIds.size} 个`}
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
      <Dialog open={!!urgentDialogInfo} onOpenChange={(open) => { if (!open) { setUrgentDialogInfo(null); setUrgentReason(""); } }}>
        <DialogContent className="max-w-lg">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Flame className="h-5 w-5 text-amber-500" />
              {urgentDialogInfo?.action === "clear" ? "取消加急" : "标记加急"}
            </DialogTitle>
          </DialogHeader>
          {urgentDialogInfo && (
            <div className="space-y-4">
              <p className="text-sm text-muted-foreground">
                {urgentDialogInfo.scopeLabel}已选中 <span className="font-medium text-foreground">{urgentDialogInfo.orderIds.length}</span> 个订单。
                {urgentDialogInfo.action === "mark" ? " 请填写加急原因，提交后将同步更新所选订单。" : " 确认后将移除所选订单的加急标记。"}
              </p>
              <div className="rounded-lg border bg-muted/40 p-3">
                <div className="mb-2 text-xs font-medium text-foreground">涉及订单</div>
                <div className="flex flex-wrap gap-1.5">
                  {urgentDialogInfo.orders.slice(0, 6).map((order: any) => (
                    <Badge key={order.id} variant="outline" className="text-[10px]">
                      {order.orderNumber || order.systemCode || `#${order.id}`}
                    </Badge>
                  ))}
                  {urgentDialogInfo.orders.length > 6 && (
                    <span className="text-[10px] text-muted-foreground">等 {urgentDialogInfo.orders.length} 单</span>
                  )}
                </div>
              </div>
              {urgentDialogInfo.action === "mark" && (
                <div>
                  <Label>加急原因 *</Label>
                  <Textarea
                    value={urgentReason}
                    onChange={(e) => setUrgentReason(e.target.value)}
                    placeholder="请输入加急原因，如客户催货、现场排队、时效临近等"
                    rows={3}
                  />
                </div>
              )}
              <DialogFooter>
                <Button variant="outline" onClick={() => { setUrgentDialogInfo(null); setUrgentReason(""); }}>取消</Button>
                <Button
                  className={urgentDialogInfo.action === "clear" ? "bg-slate-700 hover:bg-slate-800 text-white" : "bg-amber-500 hover:bg-amber-600 text-white"}
                  onClick={confirmUrgentToggle}
                  disabled={(urgentDialogInfo.action === "mark" && !urgentReason.trim()) || updateOrderFields.isPending}
                >
                  {updateOrderFields.isPending
                    ? (urgentDialogInfo.action === "clear" ? "取消中..." : "提交中...")
                    : (urgentDialogInfo.action === "clear" ? `确认取消 ${urgentDialogInfo.orderIds.length} 个` : `确认加急 ${urgentDialogInfo.orderIds.length} 个`)}
                </Button>
              </DialogFooter>
            </div>
          )}
        </DialogContent>
      </Dialog>
      {/* 批量退回确认弹窗 */}
      <Dialog open={batchRollbackOpen} onOpenChange={(open) => { if (!open) { setBatchRollbackOpen(false); setBatchRollbackReason(""); } }}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Undo2 className="h-5 w-5 text-orange-500" />
              批量退回上一步
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <p className="text-sm text-muted-foreground">已选择 <span className="font-medium text-foreground">{selectedIds.size}</span> 个订单，将全部退回到上一个流程节点。</p>
            <div>
              <Label>退回原因 *</Label>
              <Textarea value={batchRollbackReason} onChange={(e) => setBatchRollbackReason(e.target.value)} placeholder="请说明批量退回原因" rows={3} />
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => { setBatchRollbackOpen(false); setBatchRollbackReason(""); }}>取消</Button>
              <Button className="bg-orange-500 hover:bg-orange-600 text-white" disabled={!batchRollbackReason.trim() || batchRollbackMutation.isPending} onClick={() => { if (batchRollbackReason.trim()) batchRollbackMutation.mutate({ ids: Array.from(selectedIds), reason: batchRollbackReason.trim() }); }}>
                {batchRollbackMutation.isPending ? "退回中..." : `确认退回 ${selectedIds.size} 个`}
              </Button>
            </DialogFooter>
          </div>
        </DialogContent>
      </Dialog>
      {/* 批量审批弹窗 */}
      <Dialog open={batchApproveOpen} onOpenChange={(open) => { if (!open) { setBatchApproveOpen(false); setBatchApproveComment(""); } }}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              {batchApproveAction === "approve" ? (
                <><CheckCircle2 className="h-5 w-5 text-green-500" />批量审批通过</>
              ) : (
                <><XCircle className="h-5 w-5 text-red-500" />批量驳回</>
              )}
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <p className="text-sm text-muted-foreground">
              已选择 <span className="font-medium text-foreground">{selectedIds.size}</span> 个订单，
              {batchApproveAction === "approve"
                ? "将对其中待审批的订单统一通过审批。"
                : "将对其中待审批的订单统一驳回。"}
            </p>
            <div>
              <Label>{batchApproveAction === "approve" ? "审批意见（可选）" : "驳回原因 *"}</Label>
              <Textarea
                value={batchApproveComment}
                onChange={(e) => setBatchApproveComment(e.target.value)}
                placeholder={batchApproveAction === "approve" ? "可填写审批意见" : "请填写驳回原因"}
                rows={3}
              />
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => { setBatchApproveOpen(false); setBatchApproveComment(""); }}>取消</Button>
              <Button
                className={batchApproveAction === "approve" ? "bg-green-600 hover:bg-green-700 text-white" : "bg-red-600 hover:bg-red-700 text-white"}
                disabled={(batchApproveAction === "reject" && !batchApproveComment.trim()) || batchApprove.isPending}
                onClick={() => {
                  const approvalRows = (approvalData?.items ?? []).filter((item: any) => selectedIds.has(item.orderId) && item.status === "pending");
                  if (approvalRows.length === 0) {
                    toast.error("选中的订单中没有待审批的记录");
                    return;
                  }
                  batchApprove.mutate({
                    ids: approvalRows.map((item: any) => item.id),
                    action: batchApproveAction,
                    approverComment: batchApproveComment.trim() || undefined,
                  });
                }}
              >
                {batchApprove.isPending && <Loader2 className="h-4 w-4 mr-1 animate-spin" />}
                {batchApprove.isPending ? "处理中..." : batchApproveAction === "approve" ? "确认通过" : "确认驳回"}
              </Button>
            </DialogFooter>
          </div>
        </DialogContent>
      </Dialog>
      {/* 退回确认弹窗（增强版：支持指定目标状态） */}
      <Dialog open={rollbackTargetId !== null} onOpenChange={(open) => { if (!open) { setRollbackTargetId(null); setRollbackReason(""); setRevertTargetStatus("pending_vehicle"); } }}>
        <DialogContent className="max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Undo2 className="h-5 w-5 text-orange-500" />
              退回订单
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            <p className="text-sm text-muted-foreground">订单将被退回到指定状态，派车信息、押金和回单将被自动清理。</p>
            <div>
              <Label>退回目标状态 *</Label>
              <Select value={revertTargetStatus} onValueChange={setRevertTargetStatus}>
                <SelectTrigger><SelectValue /></SelectTrigger>
                <SelectContent>
                  <SelectItem value="pending_assign">待指派</SelectItem>
                  <SelectItem value="pending_price">待定价</SelectItem>
                  <SelectItem value="priced">已定价</SelectItem>
                  <SelectItem value="pending_vehicle">待找车</SelectItem>
                  <SelectItem value="pending_dispatch">待派车</SelectItem>
                  <SelectItem value="pending_inquiry">待询价</SelectItem>
                  <SelectItem value="dispatched">已调度</SelectItem>
                  <SelectItem value="on_hold">等通知</SelectItem>
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label>退回原因 *</Label>
              <Textarea value={rollbackReason} onChange={(e) => setRollbackReason(e.target.value)} placeholder="请说明退回原因" rows={3} />
            </div>
            <DialogFooter>
              <Button variant="outline" onClick={() => { setRollbackTargetId(null); setRollbackReason(""); setRevertTargetStatus("pending_vehicle"); }}>取消</Button>
              <Button className="bg-orange-500 hover:bg-orange-600 text-white" disabled={!rollbackReason.trim() || revertMutation.isPending} onClick={() => { if (rollbackTargetId && rollbackReason.trim()) revertMutation.mutate({ id: rollbackTargetId, targetStatus: revertTargetStatus, reason: rollbackReason.trim() }); }}>
                {revertMutation.isPending ? "退回中..." : "确认退回"}
              </Button>
            </DialogFooter>
          </div>
        </DialogContent>
      </Dialog>
      {/* 批量找车+报价弹窗 */}
      <Dialog open={batchDispatchOpen} onOpenChange={(open) => { if (!open) setBatchDispatchOpen(false); }}>
        <DialogContent className="max-w-2xl max-h-[90vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <Truck className="h-5 w-5 text-blue-500" />
              整组找车 + 填报价
              {(() => { const selected = pendingOrders.filter(o => selectedIds.has(o.id)); return selected.some(o => o.isUrgent) ? <Badge variant="destructive">加急</Badge> : null; })()}
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            {/* 完整订单信息区域（与单独找车弹窗保持一致格式） */}
            <div className="bg-muted/50 rounded-lg p-4 space-y-3">
              <div className="text-sm font-semibold text-foreground border-b pb-2 mb-2">订单详情（共{selectedIds.size}单）</div>
              {(() => {
                const selected = pendingOrders.filter(o => selectedIds.has(o.id));
                const totalWeight = selected.reduce((s, o) => s + (parseFloat(String(o.weight)) || 0), 0);
                const totalDispatch = selected.reduce((s, o) => s + (parseFloat(String(o.dispatchPrice)) || 0), 0);
                const first = selected[0];
                const customers = Array.from(new Set(selected.map(o => o.customerName).filter(Boolean)));
                const cargos = Array.from(new Set(selected.map(o => o.cargoName).filter(Boolean)));
                const dispatchHeadline = getDispatchHeadline(first);
                const dispatchSubline = getDispatchSubline(first);
                const hasGroupContext = selected.length > 1 || Boolean(getVisibleDispatchGroup(first));
                return (
                  <>
                    {/* 订单号和状态 */}
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-2">
                        <FileText className="h-4 w-4 text-muted-foreground" />
                        <span className="text-sm font-medium">客户订单号：</span>
                        {hasGroupContext ? (
                          <div className="space-y-1">
                            <div className="flex items-center gap-1">
                              <Layers className="h-4 w-4 text-blue-600" />
                              <span className="text-sm font-bold text-blue-700">{dispatchHeadline}</span>
                              <Badge variant="outline" className="text-[10px] bg-blue-100 text-blue-700 border-blue-300">{selected.length}单</Badge>
                            </div>
                            <div className="text-[11px] text-blue-700/80">{dispatchSubline}</div>
                          </div>
                        ) : (
                          <span className="text-sm font-mono">{selected.map(o => o.orderNumber || o.systemCode).join(", ")}</span>
                        )}
                      </div>
                    </div>

                    {/* 客户信息 */}
                    <div className="flex items-center gap-2">
                      <User className="h-4 w-4 text-muted-foreground" />
                      <span className="text-sm font-medium">客户：</span>
                      <span className="text-sm">{customers.join("、") || "-"}</span>
                      {first?.customerPhone && (
                        <span className="text-xs text-muted-foreground ml-2">
                          <Phone className="h-3 w-3 inline mr-0.5" />{first.customerPhone}
                        </span>
                      )}
                    </div>

                    {/* 货物信息 */}
                    <div className="flex items-center gap-2">
                      <Package className="h-4 w-4 text-muted-foreground" />
                      <span className="text-sm font-medium">货物：</span>
                      <span className="text-sm">{cargos.join("、") || "-"}</span>
                      <span className="text-sm text-muted-foreground">总重量：<span className="font-bold text-blue-700">{totalWeight.toFixed(3)}t</span></span>
                    </div>

                    {/* 发货信息 */}
                    <div className="bg-blue-50 rounded p-2.5 space-y-1">
                      <div className="flex items-center gap-2">
                        <MapPin className="h-4 w-4 text-blue-500" />
                        <span className="text-sm font-medium text-blue-700">发货地</span>
                      </div>
                      <div className="text-sm ml-6">
                        <span className="font-medium">{first?.originCity || "-"}</span>
                        {first?.warehouseName && <span className="text-muted-foreground"> · 仓库：{first.warehouseName}</span>}
                      </div>
                    </div>

                    {/* 卸货信息 */}
                    <div className="bg-green-50 rounded p-2.5 space-y-1">
                      <div className="flex items-center gap-2">
                        <MapPin className="h-4 w-4 text-green-500" />
                        <span className="text-sm font-medium text-green-700">卸货地</span>
                      </div>
                      <div className="text-sm ml-6">
                        <span className="font-medium">{first?.destinationCity || "-"}</span>
                        {first?.deliveryAddress && <div className="text-muted-foreground text-xs mt-0.5">地址：{first.deliveryAddress}</div>}
                        {(first?.receiverName || first?.receiverPhone) && (
                          <div className="text-muted-foreground text-xs mt-0.5">收货人：{first.receiverName || "-"} {first.receiverPhone || ""}</div>
                        )}
                      </div>
                    </div>

                    {/* 调度价 */}
                    {totalDispatch > 0 && (
                      <div className="flex items-center gap-2 bg-orange-50 rounded p-2.5">
                        <DollarSign className="h-4 w-4 text-orange-500" />
                        <span className="text-sm font-medium text-orange-700">总调度价：{formatMoney(totalDispatch.toString())}</span>
                      </div>
                    )}

                    {/* 订单备注 */}
                    {first?.remarks && (
                      <div className="bg-yellow-50 rounded p-2.5">
                        <div className="text-xs font-medium text-yellow-700 mb-1">订单备注：</div>
                        <div className="text-sm text-yellow-800">{first.remarks}</div>
                      </div>
                    )}

                    {/* 加急原因 */}
                    {selected.some(o => o.isUrgent) && (
                      <div className="bg-red-50 rounded p-2.5">
                        <div className="text-xs font-medium text-red-700 mb-1">加急原因：</div>
                        <div className="text-sm text-red-800">{selected.find(o => o.isUrgent)?.urgentReason || "加急订单"}</div>
                      </div>
                    )}
                  </>
                );
              })()}
            </div>
            {/* 车辆信息填写区域（可选，确认派车时也可填） */}
            <div className="border rounded-lg p-3 space-y-3 bg-muted/30">
              <div className="text-sm font-semibold flex items-center gap-2">
                <Truck className="h-4 w-4 text-blue-500" />
                车辆信息（可选填，也可在确认派车时再填）
              </div>
              <DriverInfoPaste onParsed={(info) => {
                if (info.plateNumber) setBatchVehiclePlate(info.plateNumber);
                if (info.driverName) setBatchDriverName(info.driverName);
                if (info.driverPhone) setBatchDriverPhone(info.driverPhone);
              }} />
              <div>
                <Label className="text-xs">车牌号</Label>
                <PlateAutocomplete
                  value={batchVehiclePlate}
                  onChange={setBatchVehiclePlate}
                  onSelect={(v) => {
                    setBatchVehiclePlate(v.plateNumber);
                    if (v.driverName) setBatchDriverName(v.driverName);
                    if (v.driverPhone) setBatchDriverPhone(v.driverPhone);
                  }}
                />
              </div>
              <div className="grid grid-cols-2 gap-2">
                <div>
                  <Label className="text-xs">司机姓名</Label>
                  <Input value={batchDriverName} onChange={(e) => setBatchDriverName(e.target.value)} placeholder="司机姓名" />
                </div>
                <div>
                  <Label className="text-xs">司机电话</Label>
                  <Input value={batchDriverPhone} onChange={(e) => setBatchDriverPhone(e.target.value)} placeholder="司机电话" />
                </div>
              </div>
            </div>
            <div>
              <Label>整车总运费（报价）{selectedIds.size > 1 ? ' *' : ''}</Label>
              <Input type="number" value={batchQuotePrice} onChange={(e) => setBatchQuotePrice(e.target.value)} placeholder="与车队谈好的运费" className="mt-1" />
              {selectedIds.size > 1 && (
                <p className="text-xs text-blue-600 mt-1">
                  ℹ️ 总运费将按各子单重量比例自动分摊，无重量则按数量平分
                </p>
              )}
            </div>
            <div className="grid grid-cols-2 gap-3">
              <div>
                <Label>押金金额 *（必填）</Label>
                <Input type="number" value={batchDepositAmount} onChange={(e) => setBatchDepositAmount(e.target.value)} placeholder="押金金额" />
                {selectedIds.size > 1 && parseFloat(batchDepositAmount) > 0 && (
                  <p className="text-xs text-amber-600 mt-1">
                    ⚠️ 押金仅记录在首单，不会重复收取
                  </p>
                )}
              </div>
              <div>
                <Label>押金退还</Label>
                <Select value={batchDepositRefundable} onValueChange={setBatchDepositRefundable}>
                  <SelectTrigger><SelectValue /></SelectTrigger>
                  <SelectContent>
                    <SelectItem value="yes">可退还</SelectItem>
                    <SelectItem value="no">不退还</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            </div>
            {/* 收货备注已在列表中填写，此处不再重复要求 */}
            <div>
              <Label>调度员备注（选填）</Label>
              <Textarea value={batchDispatcherRemark} onChange={(e) => setBatchDispatcherRemark(e.target.value)} placeholder="如有特殊情况请备注" rows={2} />
            </div>
            <p className="text-xs text-muted-foreground">
              ℹ️ 如运费超过调度价或有备注，将自动提交审批；零担前段“合并外请”即使不溢价也必须先提交审批。
            </p>
            <DialogFooter>
              <Button variant="outline" onClick={() => setBatchDispatchOpen(false)}>取消</Button>
              <Button
                disabled={!batchDepositAmount || batchDispatchMutation.isPending || batchUpdateStatus.isPending}
                onClick={() => {
                  const orderIdsList = Array.from(selectedIds);
                  const isMultiple = orderIdsList.length > 1;
                  const hasRemark = batchDispatcherRemark.trim().length > 0;
                  const freight = parseFloat(batchQuotePrice) || 0;

                  // 溢价检测：比对总运费与总调度价/原定价
                  const selected = pendingOrders.filter((o: any) => selectedIds.has(o.id));
                  const totalQuotedPrice = selected.reduce((s: number, o: any) => s + (parseFloat(String(o.quotedPrice)) || 0), 0);
                  const totalDispatchPrice = selected.reduce((s: number, o: any) => s + (parseFloat(String(o.dispatchPrice)) || 0), 0);
                  const referencePrice = totalQuotedPrice > 0 ? totalQuotedPrice : totalDispatchPrice;
                  const isOverpriced = freight > 0 && referencePrice > 0 && freight > referencePrice;
                  const hasMergedLtlPickupOrder = selected.some((order: any) => isMergedLtlPickupOutsourceOrder(order));
                  const needApproval = isOverpriced || hasRemark || hasMergedLtlPickupOrder;

                  if (needApproval) {
                    // 溢价或有备注：统一走审批流程（batchUpdateStatus + pending_approval）
                    if (isOverpriced) {
                      toast.info(`运费¥${freight} 超出${totalQuotedPrice > 0 ? '原定价' : '调度价'}¥${referencePrice}，已转入审批流程`);
                    } else if (hasMergedLtlPickupOrder) {
                      toast.info("所选订单包含零担前段合并外请，已转入外请审批流程");
                    }
                    batchUpdateStatus.mutate({
                      orderIds: orderIdsList,
                      status: "pending_approval",
                      plateNumber: batchVehiclePlate.trim() || undefined,
                      driverName: batchDriverName.trim() || undefined,
                      driverPhone: batchDriverPhone.trim() || undefined,
                      actualFreight: batchQuotePrice || undefined,
                      depositAmount: batchDepositAmount,
                      depositRefundable: batchDepositRefundable === "yes",
                      dispatcherRemark: batchDispatcherRemark.trim() || undefined,
                      receivingNote: batchReceivingNote.trim() || undefined,
                    });
                  } else if (isMultiple && freight > 0) {
                    // 多单且有运费且未溢价：使用 batchDispatch 接口（运费分摊+押金防重）
                    batchDispatchMutation.mutate({
                      orderIds: orderIdsList,
                      plateNumber: batchVehiclePlate.trim() || "待填写",
                      driverName: batchDriverName.trim() || undefined,
                      driverPhone: batchDriverPhone.trim() || undefined,
                      totalFreight: batchQuotePrice,
                      depositAmount: batchDepositAmount,
                      depositRefundable: batchDepositRefundable === "yes",
                      dispatcherRemark: batchDispatcherRemark.trim() || undefined,
                      receivingNote: batchReceivingNote.trim() || undefined,
                    });
                  } else {
                    // 单单或无运费且无备注：直接派车
                    batchUpdateStatus.mutate({
                      orderIds: orderIdsList,
                      status: "dispatched",
                      actualFreight: batchQuotePrice || undefined,
                      depositAmount: batchDepositAmount,
                      depositRefundable: batchDepositRefundable === "yes",
                      dispatcherRemark: batchDispatcherRemark.trim() || undefined,
                      receivingNote: batchReceivingNote.trim() || undefined,
                    });
                  }
                }}
              >
                {(batchDispatchMutation.isPending || batchUpdateStatus.isPending) && <Loader2 className="h-4 w-4 mr-1 animate-spin" />}
                {(batchDispatchMutation.isPending || batchUpdateStatus.isPending) ? "提交中..." : `确认提交 ${selectedIds.size} 个`}
              </Button>
            </DialogFooter>
          </div>
        </DialogContent>
      </Dialog>

      {/* 收货备注弹窗（独立按钮触发，包含加急标记和关键词自动检测） */}
      <ReceivingNoteDialog
        order={receivingNoteOrder}
        open={!!receivingNoteOrder}
        onClose={() => setReceivingNoteOrder(null)}
        onSaved={() => {
          refetchPending();
          refetchApproval();
          refetchDispatched();
        }}
      />

      {/* 确认派车弹窗（审批通过后补填车辆信息） */}
      <ConfirmVehicleDialog
        order={confirmVehicleOrder}
        open={!!confirmVehicleOrder}
        onClose={() => { setConfirmVehicleOrder(null); setConfirmVehicleGroupOrders([]); }}
        groupOrders={confirmVehicleGroupOrders.length > 0 ? confirmVehicleGroupOrders : undefined}
        onConfirmed={() => {
          refetchDispatched();
          refetchTransit();
        }}
      />
      {/* 图片查看弹窗 */}
      <Dialog open={showImageDialog} onOpenChange={setShowImageDialog}>
        <DialogContent className="max-w-2xl">
          <DialogHeader>
            <DialogTitle>货站开单图片</DialogTitle>
          </DialogHeader>
          {imageUrl && (
            <div className="flex justify-center">
              <img src={imageUrl} alt="货站开单" className="max-h-[70vh] object-contain rounded" />
            </div>
          )}
        </DialogContent>
      </Dialog>
    </DashboardLayout>
  );
}
