      tier2: { min: 0.5, max: 5, label: "0.5-5\u5428" },
      tier3: { min: 5, max: 15, label: "5-15\u5428" },
      tier4: { min: 15, max: 30, label: "15-30\u5428" },
      tier5: { min: 30, max: 999999, label: "30\u5428\u4EE5\u4E0A" }
