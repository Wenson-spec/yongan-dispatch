      createdBy: int("createdBy"),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
    approvals = mysqlTable("approvals", {
      id: int("id").autoincrement().primaryKey(),
      orderId: int("orderId").notNull(),
      approvalType: mysqlEnum("approvalType", ["initial_price", "vehicle_quote", "surcharge"]).notNull(),
      applicantId: int("applicantId").notNull(),
      applicantName: varchar("applicantName", { length: 100 }),
      approverId: int("approverId"),
      approverName: varchar("approverName", { length: 100 }),
      status: mysqlEnum("approvalStatus", ["pending", "approved", "rejected"]).default("pending").notNull(),
      previousStatus: varchar("previousStatus", { length: 50 }),
      // 审批前订单状态，驳回时精准回退
      requestedAmount: decimal("requestedAmount", { precision: 14, scale: 4 }),
      approvedAmount: decimal("approvedAmount", { precision: 14, scale: 4 }),
      reason: text("reason"),
      approverComment: text("approverComment"),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
    operationLogs = mysqlTable("operation_logs", {
      id: int("id").autoincrement().primaryKey(),
      userId: int("userId"),
      userName: varchar("userName", { length: 100 }),
      action: varchar("action", { length: 50 }).notNull(),
      targetType: varchar("targetType", { length: 50 }).notNull(),
      targetId: varchar("targetId", { length: 100 }),
      changes: json("changes"),
      ipAddress: varchar("ipAddress", { length: 50 }),
      description: text("description"),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    dispatcherRegions = mysqlTable("dispatcher_regions", {
      id: int("id").autoincrement().primaryKey(),
      dispatcherId: int("dispatcherId").notNull(),
      province: varchar("province", { length: 100 }).notNull(),
      city: varchar("city", { length: 100 }),
      priority: int("priority").default(0),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    podRecords = mysqlTable("pod_records", {
      id: int("id").autoincrement().primaryKey(),
      orderId: int("orderId").notNull(),
      podOwnership: mysqlEnum("podOwnership", ["current_order", "delivery_outsource", "none"]).default("current_order").notNull(),
      deliveryNoteUrl: text("deliveryNoteUrl"),
      ocrResult: json("ocrResult"),
      ocrVerified: boolean("ocrVerified").default(false),
      ocrVerifiedBy: int("ocrVerifiedBy"),
      ocrVerifiedAt: timestamp("ocrVerifiedAt"),
      originalStatus: mysqlEnum("originalStatus", ["pending", "sent", "received", "lost"]).default("pending").notNull(),
      originalSentAt: timestamp("originalSentAt"),
      originalReceivedAt: timestamp("originalReceivedAt"),
      originalReceivedBy: int("originalReceivedBy"),
      depositLinked: boolean("depositLinked").default(false),
      depositAmount: decimal("depositAmount", { precision: 10, scale: 2 }),
      depositRefunded: boolean("depositRefunded").default(false),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
    ltlInquiries = mysqlTable("ltl_inquiries", {
      id: int("id").autoincrement().primaryKey(),
      orderId: int("orderId").notNull(),
      freightStationId: int("freightStationId").notNull(),
      finalStationName: varchar("finalStationName", { length: 200 }),
      quotedPrice: decimal("quotedPrice", { precision: 14, scale: 4 }),
      confirmedPrice: decimal("confirmedPrice", { precision: 14, scale: 4 }),
      unitPrice: decimal("unitPrice", { precision: 14, scale: 4 }),
      // 单价（元/吨）
      deliveryFee: decimal("deliveryFee", { precision: 14, scale: 2 }),
      // 送货费
      otherFee: decimal("otherFee", { precision: 14, scale: 2 }),
      // 其他费
      packageCount: int("packageCount"),
      // 架数（大板零担用）
      inquiryStatus: mysqlEnum("inquiryStatus", ["pending", "quoted", "confirmed", "cancelled"]).default("pending").notNull(),
      inquiredBy: int("inquiredBy").notNull(),
      remarks: text("remarks"),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    rolePermissions = mysqlTable("role_permissions", {
      id: int("id").autoincrement().primaryKey(),
      role: varchar("role", { length: 50 }).notNull(),
      permissionKey: varchar("permissionKey", { length: 100 }).notNull(),
      allowed: boolean("allowed").default(false).notNull(),
      updatedBy: int("updatedBy"),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
    departments = mysqlTable("departments", {
      id: int("id").autoincrement().primaryKey(),
      name: varchar("name", { length: 200 }).notNull(),
      isActive: boolean("isActive").default(true).notNull(),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    cargoTypes = mysqlTable("cargo_types", {
      id: int("id").autoincrement().primaryKey(),
      name: varchar("name", { length: 200 }).notNull(),
      isActive: boolean("isActive").default(true).notNull(),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    ltlDispatchBatches = mysqlTable("ltl_dispatch_batches", {
      id: int("id").autoincrement().primaryKey(),
      batchCode: varchar("batchCode", { length: 50 }).notNull(),
      // 批次号，如 LTL20260228001
      plateNumber: varchar("plateNumber", { length: 20 }).notNull(),
      driverName: varchar("driverName", { length: 100 }).notNull(),
      driverPhone: varchar("driverPhone", { length: 20 }),
      dispatchDate: timestamp("dispatchDate").defaultNow().notNull(),
      remark: text("remark"),
      createdBy: int("createdBy"),
      createdByName: varchar("createdByName", { length: 100 }),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    ltlDispatchBatchOrders = mysqlTable("ltl_dispatch_batch_orders", {
      id: int("id").autoincrement().primaryKey(),
      batchId: int("batchId").notNull(),
      orderId: int("orderId").notNull(),
      remark: text("remark"),
      // 每单备注（如运费信息、批次号等）
      sortOrder: int("sortOrder").default(0),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    overdueNotifications = mysqlTable("overdue_notifications", {
      id: int("id").autoincrement().primaryKey(),
      podId: int("podId").notNull(),
      orderId: int("orderId").notNull(),
      level: mysqlEnum("level", ["yellow", "orange", "red"]).notNull(),
      // 预警级别
      recipientRole: varchar("recipientRole", { length: 50 }).notNull(),
      // 接收者角色
      recipientUserId: int("recipientUserId"),
      // 接收者用户ID（调度员时有值）
      overdueDays: int("overdueDays").notNull(),
      sentAt: timestamp("sentAt").defaultNow().notNull(),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    noteChangeLogs = mysqlTable("note_change_logs", {
      id: int("id").autoincrement().primaryKey(),
      orderId: int("orderId").notNull(),
      field: mysqlEnum("field", ["shippingNote", "receivingNote"]).notNull(),
      oldValue: text("oldValue"),
      newValue: text("newValue"),
      changedByUserId: int("changedByUserId").notNull(),
      changedByUserName: varchar("changedByUserName", { length: 100 }).notNull(),
      createdAt: timestamp("createdAt").defaultNow().notNull()
    });
    pasteTemplates = mysqlTable("paste_templates", {
      id: int("id").autoincrement().primaryKey(),
      customerName: varchar("customerName", { length: 200 }).notNull(),
      templateName: varchar("templateName", { length: 200 }),
      // 模板名称，如"XX客户标准格式"
      sampleText: text("sampleText").notNull(),
      // 原始粘贴文本样本
      fieldMapping: json("fieldMapping"),
      // 字段映射规则 JSON
      successCount: int("successCount").default(0).notNull(),
      // 成功使用次数
      lastUsedAt: timestamp("lastUsedAt"),
      createdBy: int("createdBy").notNull(),
      createdByName: varchar("createdByName", { length: 100 }),
      isActive: boolean("isActive").default(true).notNull(),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
    systemConfig = mysqlTable("system_config", {
      id: int("id").autoincrement().primaryKey(),
      configKey: varchar("config_key", { length: 100 }).notNull().unique(),
      configValue: text("config_value").notNull(),
      description: varchar("description", { length: 255 }),
      updatedById: int("updated_by_id"),
      updatedByName: varchar("updated_by_name", { length: 100 }),
      createdAt: timestamp("createdAt").defaultNow().notNull(),
      updatedAt: timestamp("updatedAt").defaultNow().onUpdateNow().notNull()
    });
  }
});

