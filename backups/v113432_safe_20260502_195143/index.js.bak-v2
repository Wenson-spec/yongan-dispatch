var ltlInquiryRouter = router({
  // 创建询价
  create: permissionProcedure("ltl.inquiry").input(
    z7.object({
      orderId: z7.number(),
      freightStationId: z7.number(),
      finalStationName: z7.string().optional(),
      quotedPrice: optionalDecimal(),
      remarks: z7.string().optional()
    })
  ).mutation(async ({ ctx, input }) => {
    const db = await getDb();
    if (!db) throw new Error("\u6570\u636E\u5E93\u4E0D\u53EF\u7528");
    const result = await db.insert(ltlInquiries).values({
      orderId: input.orderId,
      freightStationId: input.freightStationId,
      finalStationName: input.finalStationName || null,
      quotedPrice: input.quotedPrice || null,
      inquiredBy: ctx.user.id,
      remarks: input.remarks || null
    });
    await db.update(orders).set({ status: "pending_inquiry" }).where(eq5(orders.id, input.orderId));
    await createOperationLog({
      userId: ctx.user.id,
      userName: ctx.user.name || ctx.user.username || void 0,
      action: "create",
      targetType: "ltl_inquiry",
      targetId: String(result[0].insertId),
      description: `\u521B\u5EFA\u96F6\u62C5\u8BE2\u4EF7\uFF0C\u8BA2\u5355#${input.orderId}`
    });
    return { id: result[0].insertId };
  }),
  // 询价列表
  listByOrder: protectedProcedure.input(z7.object({ orderId: z7.number() })).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return [];
    return db.select().from(ltlInquiries).where(eq5(ltlInquiries.orderId, input.orderId)).orderBy(desc4(ltlInquiries.createdAt));
  }),
  // 更新询价（报价/确认）
  update: protectedProcedure.input(
    z7.object({
      id: z7.number(),
      quotedPrice: optionalDecimal(),
      confirmedPrice: optionalDecimal(),
      inquiryStatus: z7.enum(["pending", "quoted", "confirmed", "cancelled"]).optional(),
      remarks: z7.string().optional()
    })
  ).mutation(async ({ ctx, input }) => {
    const db = await getDb();
    if (!db) throw new Error("\u6570\u636E\u5E93\u4E0D\u53EF\u7528");
    const { id, ...data } = input;
    const updateData = {};
    if (data.quotedPrice !== void 0) updateData.quotedPrice = data.quotedPrice;
    if (data.confirmedPrice !== void 0) updateData.confirmedPrice = data.confirmedPrice;
    if (data.inquiryStatus !== void 0) updateData.inquiryStatus = data.inquiryStatus;
    if (data.remarks !== void 0) updateData.remarks = data.remarks;
    await db.update(ltlInquiries).set(updateData).where(eq5(ltlInquiries.id, id));
    if (data.inquiryStatus === "confirmed") {
      const inquiry = await db.select().from(ltlInquiries).where(eq5(ltlInquiries.id, id)).limit(1);
      if (inquiry[0]) {
        await db.transaction(async (tx) => {
          await tx.update(ltlInquiries).set({
            inquiryStatus: "cancelled"
          }).where(
            and5(
              eq5(ltlInquiries.orderId, inquiry[0].orderId),
              ne2(ltlInquiries.id, id),
              inArray5(ltlInquiries.inquiryStatus, ["pending", "quoted"])
            )
          );
          await tx.update(orders).set({
            status: "inquiry_confirmed",
            ltlFinalStation: inquiry[0].finalStationName,
            ltlFreightPrice: inquiry[0].confirmedPrice ? String(inquiry[0].confirmedPrice) : null,
            freightStationId: inquiry[0].freightStationId
          }).where(eq5(orders.id, inquiry[0].orderId));
        });
      }
    }
    await createOperationLog({
      userId: ctx.user.id,
      userName: ctx.user.name || ctx.user.username || void 0,
      action: "update",
      targetType: "ltl_inquiry",
      targetId: String(id),
      changes: updateData,
      description: `\u66F4\u65B0\u96F6\u62C5\u8BE2\u4EF7 #${id}`
    });
    return { success: true };
  })
});

// server/routers/stats.ts
import { z as z8 } from "zod";
init_db();
init_schema();
import { eq as eq6, and as and6, desc as desc5, count as count4, gte as gte4, lte as lte2, sql as sql4, inArray as inArray6, isNotNull, or as or4 } from "drizzle-orm";
var statsRouter = router({
  // 统计看板数据
  dashboard: protectedProcedure.input(
    z8.object({
      startDate: z8.string().optional(),
      endDate: z8.string().optional()
    }).optional()
  ).query(async ({ ctx, input }) => {
    const db = await getDb();
    if (!db) return null;
    const conditions = [];
    if (input?.startDate) conditions.push(gte4(orders.orderDate, new Date(input.startDate)));
    if (input?.endDate) conditions.push(lte2(orders.orderDate, new Date(input.endDate)));
    const baseWhere = conditions.length > 0 ? and6(...conditions) : void 0;
    let byType = [];
    let byStatus = [];
    let urgentCount = 0;
    let todayNew = 0;
    let pendingApprovalsCount = 0;
    let pendingPodsCount = 0;
    let dailyTrend = [];
    const today = /* @__PURE__ */ new Date();
    today.setHours(0, 0, 0, 0);
    const sevenDaysAgo = /* @__PURE__ */ new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
    const sevenDaysAgoStr = sevenDaysAgo.toISOString().slice(0, 19).replace("T", " ");
    const [ordersResults, approvalsResult, podsResult, trendResult] = await Promise.allSettled([
      // 组1：orders表 - 合并 byType + byStatus + urgent + todayNew 为 3 次查询
      Promise.allSettled([
        // 按业务类型统计（包含费用汇总，无法与其他合并）
        db.select({
          businessType: orders.businessType,
          cnt: count4(),
          totalFreight: sql4`COALESCE(SUM(CAST(${orders.actualFreight} AS DECIMAL(12,2))), 0)`,
          totalCost: sql4`COALESCE(SUM(CAST(${orders.totalCost} AS DECIMAL(12,2))), 0)`
        }).from(orders).where(baseWhere).groupBy(orders.businessType),
        // 按状态统计（同时统计加急数量，避免单独查询）
        db.select({
          status: orders.status,
          cnt: count4(),
          urgentCnt: sql4`SUM(CASE WHEN ${orders.isUrgent} = true THEN 1 ELSE 0 END)`
        }).from(orders).where(baseWhere).groupBy(orders.status),
        // 今日新增
        db.select({ cnt: count4() }).from(orders).where(gte4(orders.createdAt, today))
      ]),
      // 组2：待审批数量（仅统计仍有关联订单的审批，避免孤儿审批干扰）
      db.select({ cnt: count4() }).from(approvals).innerJoin(orders, eq6(approvals.orderId, orders.id)).where(eq6(approvals.status, "pending")),
      // 组3：回单待处理
      db.select({ cnt: count4() }).from(podRecords).where(eq6(podRecords.originalStatus, "pending")),
      // 组4：最近7天趋势
      db.execute(sql4.raw(`SELECT DATE_FORMAT(createdAt, '%Y-%m-%d') as \`date\`, COUNT(*) as cnt FROM orders WHERE createdAt >= '${sevenDaysAgoStr}' GROUP BY DATE_FORMAT(createdAt, '%Y-%m-%d') ORDER BY \`date\``))
    ]);
    if (ordersResults.status === "fulfilled") {
      const [byTypeResult, byStatusResult, todayResult] = ordersResults.value;
      if (byTypeResult.status === "fulfilled") byType = byTypeResult.value;
      if (byStatusResult.status === "fulfilled") {
        const statusRows = byStatusResult.value;
        byStatus = statusRows.map((r) => ({ status: r.status, cnt: r.cnt }));
        urgentCount = statusRows.reduce((sum, r) => sum + (Number(r.urgentCnt) || 0), 0);
      }
      if (todayResult.status === "fulfilled") todayNew = todayResult.value[0]?.cnt ?? 0;
    }
    if (approvalsResult.status === "fulfilled") pendingApprovalsCount = approvalsResult.value[0]?.cnt ?? 0;
    if (podsResult.status === "fulfilled") pendingPodsCount = podsResult.value[0]?.cnt ?? 0;
    if (trendResult.status === "fulfilled") {
      const rows = Array.isArray(trendResult.value) ? Array.isArray(trendResult.value[0]) ? trendResult.value[0] : trendResult.value : [];
      dailyTrend = rows.map((r) => ({ date: r.date, cnt: Number(r.cnt) }));
    }
    return {
      byType,
      byStatus,
      urgentCount,
      todayNew,
      pendingApprovals: pendingApprovalsCount,
      pendingPods: pendingPodsCount,
      dailyTrend
    };
  }),
  // 运价数据库（五档单价格式，按路线聚合，排除大板订单，含同比/环比）
  freightRates: permissionProcedure("freight_rate.view").input(
    z8.object({
      originProvince: z8.string().optional(),
      originCity: z8.string().optional(),
      destinationProvince: z8.string().optional(),
      destinationCity: z8.string().optional(),
      cargoSpec: z8.string().optional(),
      businessType: z8.enum(["outsource", "ltl"]).optional(),
      startDate: z8.string().optional(),
      endDate: z8.string().optional()
    })
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return { items: [], period: "", momPeriod: "", yoyPeriod: "" };
    const buildBaseConditions = () => {
