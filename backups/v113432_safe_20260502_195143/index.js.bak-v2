          if (avgResponseHours2 < 2) speedScore = 100;
          else if (avgResponseHours2 < 6) speedScore = 80;
          else if (avgResponseHours2 < 12) speedScore = 60;
          else if (avgResponseHours2 < 24) speedScore = 40;
          else speedScore = 20;
        }
        const roleLabel = d.role === "ltl_dispatcher" ? "\u96F6\u62C5" : d.role === "outsource_dispatcher" ? "\u5916\u8BF7" : d.role === "fleet_dispatcher" ? "\u8F66\u961F" : "\u8C03\u5EA6";
        return {
          id: d.id,
          name: d.name || `\u8C03\u5EA6\u5458${d.id}`,
          role: d.role,
          roleLabel,
          processed,
          completed,
          completionRate,
          avgResponseHours: avgResponseHours2,
          minResponseHours: response ? Math.round(response.minSeconds / 3600 * 10) / 10 : null,
          maxResponseHours: response ? Math.round(response.maxSeconds / 3600 * 10) / 10 : null,
          backlog,
          todayNew,
          speedScore,
          // 综合评分
          totalScore: Math.round(processed * 0.4 + speedScore * 0.3 + completionRate * 0.3)
        };
      });
      rankings.sort((a, b) => b.totalScore - a.totalScore || b.processed - a.processed);
      const totalProcessed = rankings.reduce((sum, r) => sum + r.processed, 0);
      const avgResponseAll = rankings.filter((r) => r.avgResponseHours !== null);
      const avgResponseHours = avgResponseAll.length > 0 ? Math.round(avgResponseAll.reduce((sum, r) => sum + (r.avgResponseHours || 0), 0) / avgResponseAll.length * 10) / 10 : 0;
      return {
        rankings,
        summary: {
          totalDispatchers: dispatchers.length,
          totalProcessed,
          avgResponseHours
        }
      };
    } catch (e) {
      console.error("Dispatcher performance error:", e);
      return { rankings: [], summary: { totalDispatchers: 0, totalProcessed: 0, avgResponseHours: 0 } };
    }
  })
});

