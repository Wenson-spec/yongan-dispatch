          isNotNull(orders.assignedDispatcherId),
          inArray6(orders.status, ["dispatched", "in_transit", "shipped"])
        )
      ).groupBy(orders.assignedDispatcherId);
      const backlogMap = new Map(backlogRows.map((r) => [r.dispatcherId, Number(r.backlogCount)]));
      const completedMap = new Map(completedRows.map((r) => [r.dispatcherId, Number(r.completedCount)]));
      const newOrderMap = new Map(newOrderRows.map((r) => [r.dispatcherId, Number(r.newCount)]));
      const inTransitMap = new Map(inTransitRows.map((r) => [r.dispatcherId, Number(r.transitCount)]));
      const dispatchers = dispatcherRows.map((d) => {
        const roleLabel = d.role === "ltl_dispatcher" ? "\u96F6\u62C5" : d.role === "outsource_dispatcher" ? "\u5916\u8BF7" : d.role === "fleet_dispatcher" ? "\u8F66\u961F" : "\u8C03\u5EA6";
        return {
          id: d.id,
          name: d.name || `\u8C03\u5EA6\u5458${d.id}`,
          role: d.role,
