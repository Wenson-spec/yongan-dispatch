import { eq as eq5, and as and5, desc as desc4, count as count3, like as like3, or as or3, inArray as inArray5, sql as sql3, ne as ne2 } from "drizzle-orm";
function isResponsiblePodOwnership(podOwnership) {
  return podOwnership === "current_order";
}
async function resolveGroupOrderIds(db, relatedOrderId, relatedOrder) {
  let groupOrderIds = [relatedOrderId];
  if (relatedOrder.mergedPlanNumber) {
    const groupRows = await db.select({ id: orders.id }).from(orders).where(and5(
      eq5(orders.mergedPlanNumber, relatedOrder.mergedPlanNumber),
      eq5(orders.podOwnership, "current_order")
    ));
    if (groupRows.length > 0) groupOrderIds = groupRows.map((row) => row.id);
  } else if (relatedOrder.plateNumber && relatedOrder.dispatchDate) {
    const groupRows = await db.select({ id: orders.id }).from(orders).where(and5(
      eq5(orders.plateNumber, relatedOrder.plateNumber),
      eq5(orders.dispatchDate, relatedOrder.dispatchDate),
      eq5(orders.podOwnership, "current_order")
    ));
    if (groupRows.length > 0) groupOrderIds = groupRows.map((row) => row.id);
  }
  return groupOrderIds;
}
function resolvePendingDepositStatus(depositAmount, depositRefundable) {
  const numericDepositAmount = Number(depositAmount ?? 0);
  if (!Number.isFinite(numericDepositAmount) || numericDepositAmount <= 0) {
    return "none";
  }
  return depositRefundable === false ? "not_refundable" : "paid";
}
