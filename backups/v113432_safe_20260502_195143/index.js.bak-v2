import { eq as eq7, and as and7, desc as desc6, gte as gte5, lte as lte3, like as like5, sql as sql5 } from "drizzle-orm";
function regexPreParse(text2) {
  const results = {};
  const phoneMatch = text2.match(/1[3-9]\d{9}/);
  results.phone = phoneMatch ? phoneMatch[0] : null;
  const landlineMatch = text2.match(/0\d{2,3}-\d{7,8}/);
  results.landline = landlineMatch ? landlineMatch[0] : null;
  const weightKgMatch = text2.match(/(\d+\.?\d*)\s*[kK][gG]/);
  const weightTonMatch = text2.match(/(\d+\.?\d*)\s*[吨tT]/);
  if (weightKgMatch) {
    results.weight = (safeParseFloat(weightKgMatch[1]) / 1e3).toFixed(3);
    results.weightUnit = "kg";
  } else if (weightTonMatch) {
    results.weight = weightTonMatch[1];
    results.weightUnit = "ton";
  } else {
    results.weight = null;
  }
  const orderNos = text2.match(/[A-Za-z]\d{6,}/g);
  results.orderNumbers = orderNos ? orderNos.join(",") : null;
  const planMatch = text2.match(/P\d{8,}/);
  results.mergedPlanNumber = planMatch ? planMatch[0] : null;
  const receiverMatches = text2.match(/[\u4e00-\u9fa5]{2,3}(?=\s*(?:1[3-9]\d{9}|0\d{2,3}-\d{7,8}))/g);
  results.receiverNames = receiverMatches ? receiverMatches.join(",") : null;
  const specLines = text2.match(/(?:SC|SA)[:：]\s*[^\n]*/gi);
  results.specLines = specLines ? specLines.join("; ") : null;
  const sizeMatches = text2.match(/\d{3,4}\s*[xX×*]\s*\d{3,4}/g);
  results.sizes = sizeMatches ? sizeMatches.join(", ") : null;
  let hasLargeSlab = false;
  if (sizeMatches) {
    for (const s of sizeMatches) {
      const nums = s.match(/\d+/g);
      if (nums && nums.length >= 2) {
        const w = parseInt(nums[0]);
        const h = parseInt(nums[1]);
        if (w >= 1800 && h >= 900 || h >= 1800 && w >= 900) {
          hasLargeSlab = true;
          break;
        }
      }
    }
  }
  if (/大板|岩板|铁架|铁托/.test(text2)) {
    hasLargeSlab = true;
  }
  results.hasLargeSlab = hasLargeSlab ? "true" : "false";
  const tuoMatches = text2.match(/\d+\s*托|[一二三四五六七八九十]+托/g);
  results.tuoInfo = tuoMatches ? tuoMatches.join(", ") : null;
  const jiaMatches = text2.match(/\d+\s*架|铁架\s*\d*\s*个/g);
  results.jiaInfo = jiaMatches ? jiaMatches.join(", ") : null;
  return results;
}
function parseChineseCount(raw) {
  const text2 = raw.trim();
  if (!text2) return null;
  if (/^\d+$/.test(text2)) return parseInt(text2, 10);
  const map = {
    \u96F6: 0,
    \u4E00: 1,
    \u4E8C: 2,
    \u4E24: 2,
    \u4E09: 3,
    \u56DB: 4,
    \u4E94: 5,
    \u516D: 6,
    \u4E03: 7,
    \u516B: 8,
    \u4E5D: 9
  };
  if (text2 === "\u5341") return 10;
  if (text2.includes("\u5341")) {
    const [left, right] = text2.split("\u5341");
    const tens = left ? map[left] ?? 0 : 1;
    const ones = right ? map[right] ?? 0 : 0;
    return tens * 10 + ones;
  }
  return map[text2] ?? null;
}
function normalizeCount(raw) {
  if (!raw) return "";
  const digitMatch = raw.match(/\d+/);
  if (digitMatch) return digitMatch[0];
  const chineseMatch = raw.match(/[零一二两三四五六七八九十]+/);
  if (!chineseMatch) return "";
