      description: `\u63D0\u4EA4${input.approvalType === "initial_price" ? "\u521D\u59CB\u5B9A\u4EF7" : input.approvalType === "vehicle_quote" ? "\u8F66\u8F86\u62A5\u4EF7" : input.approvalType === "surcharge" ? "\u52A0\u4EF7" : "\u57AB\u4ED8"}\u5BA1\u6279\uFF0C\u8BA2\u5355#${input.orderId}`
    });
