  return count8 != null ? String(count8) : "";
}
function normalizeCargoSpec(raw) {
  if (!raw) return "";
  const matches = raw.match(/\d{3,4}\s*[xX×*]\s*\d{3,4}/g);
  if (matches && matches.length > 0) {
    const uniq = Array.from(new Set(matches.map((item) => item.replace(/\s+/g, "").replace(/[xX×]/g, "*"))));
    return uniq.join(" / ");
  }
  return raw.trim();
}
function extractFallbackShippingNote(text2) {
  const notePatterns = [
