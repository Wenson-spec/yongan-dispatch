    const conditions = [];
    if (input.status) conditions.push(eq3(approvals.status, input.status));
    if (input.approvalType) conditions.push(eq3(approvals.approvalType, input.approvalType));
    const whereClause = conditions.length > 0 ? and3(...conditions) : void 0;
    const orphanWhereClause = whereClause ? and3(whereClause, isNull2(orders.id)) : isNull2(orders.id);
    const orphanApprovalRows = await db.select({ id: approvals.id }).from(approvals).leftJoin(orders, eq3(approvals.orderId, orders.id)).where(orphanWhereClause);
    const orphanApprovalIds = orphanApprovalRows.map((item) => item.id).filter((id) => typeof id === "number");
    if (orphanApprovalIds.length > 0) {
      await db.delete(approvals).where(inArray3(approvals.id, orphanApprovalIds));
    }
