  lookupByPlate: protectedProcedure.input(z3.object({
    plateNumber: z3.string().min(1, "\u8F66\u724C\u53F7\u4E0D\u80FD\u4E3A\u7A7A")
  })).mutation(async ({ input, ctx }) => {
    let vehicle = await findVehicleByPlate(input.plateNumber);
    let isNew = false;
    if (!vehicle) {
      const id = await createVehicle({
        plateNumber: input.plateNumber,
        vehicleType: "outsource"
      });
      vehicle = { id, plateNumber: input.plateNumber, vehicleType: "outsource", status: "available", isActive: true, createdAt: /* @__PURE__ */ new Date(), model: null, capacity: null, driverId: null };
      isNew = true;
      await createOperationLog({
        userId: ctx.user.id,
        userName: ctx.user.name ?? void 0,
        action: "create",
        targetType: "vehicle",
        targetId: String(id),
        changes: { plateNumber: input.plateNumber, vehicleType: "outsource" },
        description: `\u8C03\u5EA6\u65F6\u81EA\u52A8\u521B\u5EFA\u8F66\u8F86: ${input.plateNumber}`
      });
    }
    let driver = null;
    if (vehicle.driverId) {
      const allDrivers = await listDrivers(true);
      driver = allDrivers.find((d) => d.id === vehicle.driverId) || null;
    }
    if (!driver) {
      driver = await findDriverByPlate(input.plateNumber);
    }
    return {
      vehicle,
      driver: driver ? { name: driver.name, phone: driver.phone } : null,
      isNew
    };
  }),
