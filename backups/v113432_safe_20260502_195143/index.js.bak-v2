import { z as z11 } from "zod";
init_db();
init_schema();
import { TRPCError as TRPCError8 } from "@trpc/server";
import { sql as sql6, desc as desc7, gte as gte6, count as count6 } from "drizzle-orm";
var adminProcedure3 = protectedProcedure.use(({ ctx, next }) => {
  if (ctx.user.role !== "admin" && ctx.user.role !== "cs_manager") {
    throw new TRPCError8({ code: "FORBIDDEN", message: "\u4EC5\u7BA1\u7406\u5458\u548C\u5BA2\u670D\u7ECF\u7406\u53EF\u67E5\u770B" });
  }
  return next({ ctx });
});
var usageRouter = router({
  // 用户活跃度统计
  getUserActivity: adminProcedure3.input(
    z11.object({
      days: z11.number().min(1).max(365).default(30)
    }).optional()
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) throw new TRPCError8({ code: "INTERNAL_SERVER_ERROR", message: "\u6570\u636E\u5E93\u4E0D\u53EF\u7528" });
    const days = input?.days || 30;
    const since = new Date(Date.now() - days * 24 * 60 * 60 * 1e3);
    const allUsers = await db.select({
      id: users.id,
      name: users.name,
      username: users.username,
      role: users.role,
      isActive: users.isActive,
      lastSignedIn: users.lastSignedIn,
      createdAt: users.createdAt
    }).from(users);
    const opCounts = await db.select({
      userId: operationLogs.userId,
      count: count6()
    }).from(operationLogs).where(gte6(operationLogs.createdAt, since)).groupBy(operationLogs.userId);
    const opCountMap = new Map(opCounts.map((o) => [o.userId, o.count]));
    const orderCounts = await db.select({
      createdBy: orders.createdBy,
      count: count6()
    }).from(orders).where(gte6(orders.createdAt, since)).groupBy(orders.createdBy);
    const orderCountMap = new Map(orderCounts.map((o) => [o.createdBy ?? 0, o.count]));
    const opTypes = await db.select({
      userId: operationLogs.userId,
      action: operationLogs.action,
      count: count6()
    }).from(operationLogs).where(gte6(operationLogs.createdAt, since)).groupBy(operationLogs.userId, operationLogs.action);
    const opTypeMap = /* @__PURE__ */ new Map();
    for (const row of opTypes) {
      const uid = row.userId ?? 0;
      if (!opTypeMap.has(uid)) opTypeMap.set(uid, {});
      opTypeMap.get(uid)[row.action] = row.count;
    }
    return allUsers.map((u) => ({
      id: u.id,
      name: u.name || u.username || "\u672A\u77E5",
      role: u.role,
      isActive: u.isActive,
      lastSignedIn: u.lastSignedIn,
      createdAt: u.createdAt,
      operationCount: opCountMap.get(u.id) || 0,
      orderCount: orderCountMap.get(u.id) || 0,
      actionBreakdown: opTypeMap.get(u.id) || {}
    })).sort((a, b) => b.operationCount - a.operationCount);
  }),
  // 系统整体使用趋势（按天）
  getDailyTrend: adminProcedure3.input(
    z11.object({
      days: z11.number().min(7).max(90).default(30)
    }).optional()
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) throw new TRPCError8({ code: "INTERNAL_SERVER_ERROR", message: "\u6570\u636E\u5E93\u4E0D\u53EF\u7528" });
    const days = input?.days || 30;
    const since = new Date(Date.now() - days * 24 * 60 * 60 * 1e3);
    const dailyOps = await db.select({
      date: sql6`DATE(${operationLogs.createdAt})`.as("date"),
      count: count6()
    }).from(operationLogs).where(gte6(operationLogs.createdAt, since)).groupBy(sql6`DATE(${operationLogs.createdAt})`).orderBy(sql6`DATE(${operationLogs.createdAt})`);
    const dailyOrders = await db.select({
      date: sql6`DATE(${orders.createdAt})`.as("date"),
      count: count6()
    }).from(orders).where(gte6(orders.createdAt, since)).groupBy(sql6`DATE(${orders.createdAt})`).orderBy(sql6`DATE(${orders.createdAt})`);
    const dailyActiveUsers = await db.select({
      date: sql6`DATE(${operationLogs.createdAt})`.as("date"),
      count: sql6`COUNT(DISTINCT ${operationLogs.userId})`.as("count")
    }).from(operationLogs).where(gte6(operationLogs.createdAt, since)).groupBy(sql6`DATE(${operationLogs.createdAt})`).orderBy(sql6`DATE(${operationLogs.createdAt})`);
    return {
      dailyOperations: dailyOps,
      dailyOrders,
      dailyActiveUsers
    };
  }),
  // 操作类型统计
  getActionStats: adminProcedure3.input(
    z11.object({
      days: z11.number().min(1).max(365).default(30)
    }).optional()
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) throw new TRPCError8({ code: "INTERNAL_SERVER_ERROR", message: "\u6570\u636E\u5E93\u4E0D\u53EF\u7528" });
    const days = input?.days || 30;
    const since = new Date(Date.now() - days * 24 * 60 * 60 * 1e3);
    const actionStats = await db.select({
      action: operationLogs.action,
      count: count6()
    }).from(operationLogs).where(gte6(operationLogs.createdAt, since)).groupBy(operationLogs.action).orderBy(desc7(count6()));
    return actionStats;
  })
});

