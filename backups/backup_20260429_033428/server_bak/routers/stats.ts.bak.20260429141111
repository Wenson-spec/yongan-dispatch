import { z } from "zod";
import { protectedProcedure, permissionProcedure } from "../_core/trpc";
import { router } from "../_core/trpc";
import { getDb } from "../db";
import { orders, approvals, podRecords, users, operationLogs } from "../../drizzle/schema";
import { eq, and, desc, count, gte, lte, sql, inArray, isNotNull, like, or } from "drizzle-orm";
import { safeParseFloat } from "@shared/safeParseFloat";

export const statsRouter = router({
  // 统计看板数据
  dashboard: protectedProcedure.input(
    z.object({
      startDate: z.string().optional(),
      endDate: z.string().optional(),
    }).optional(),
  ).query(async ({ ctx, input }) => {
    const db = await getDb();
    if (!db) return null;

    const conditions: any[] = [];
    if (input?.startDate) conditions.push(gte(orders.orderDate, new Date(input.startDate)));
    if (input?.endDate) conditions.push(lte(orders.orderDate, new Date(input.endDate)));

    const baseWhere = conditions.length > 0 ? and(...conditions) : undefined;

    // 优化：并行执行不同表的查询，合并orders表的多次查询为尽可能少的次数
    let byType: any[] = [];
    let byStatus: any[] = [];
    let urgentCount = 0;
    let todayNew = 0;
    let pendingApprovalsCount = 0;
    let pendingPodsCount = 0;
    let dailyTrend: any[] = [];

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
    const sevenDaysAgoStr = sevenDaysAgo.toISOString().slice(0, 19).replace('T', ' ');

    // 并行执行三组查询（orders表、approvals表、podRecords表）
    const [ordersResults, approvalsResult, podsResult, trendResult] = await Promise.allSettled([
      // 组1：orders表 - 合并 byType + byStatus + urgent + todayNew 为 3 次查询
      Promise.allSettled([
        // 按业务类型统计（包含费用汇总，无法与其他合并）
        db.select({
          businessType: orders.businessType,
          cnt: count(),
          totalFreight: sql<string>`COALESCE(SUM(CAST(${orders.actualFreight} AS DECIMAL(12,2))), 0)`,
          totalCost: sql<string>`COALESCE(SUM(CAST(${orders.totalCost} AS DECIMAL(12,2))), 0)`,
        }).from(orders).where(baseWhere).groupBy(orders.businessType),
        // 按状态统计（同时统计加急数量，避免单独查询）
        db.select({
          status: orders.status,
          cnt: count(),
          urgentCnt: sql<number>`SUM(CASE WHEN ${orders.isUrgent} = true THEN 1 ELSE 0 END)`,
        }).from(orders).where(baseWhere).groupBy(orders.status),
        // 今日新增
        db.select({ cnt: count() }).from(orders).where(gte(orders.createdAt, today)),
      ]),
      // 组2：待审批数量（仅统计仍有关联订单的审批，避免孤儿审批干扰）
      db.select({ cnt: count() })
        .from(approvals)
        .innerJoin(orders, eq(approvals.orderId, orders.id))
        .where(eq(approvals.status, "pending")),
      // 组3：回单待处理
      db.select({ cnt: count() }).from(podRecords).where(eq(podRecords.originalStatus, "pending")),
      // 组4：最近7天趋势
      db.execute(sql.raw(`SELECT DATE_FORMAT(createdAt, '%Y-%m-%d') as \`date\`, COUNT(*) as cnt FROM orders WHERE createdAt >= '${sevenDaysAgoStr}' GROUP BY DATE_FORMAT(createdAt, '%Y-%m-%d') ORDER BY \`date\``)),
    ]);

    // 解析orders表结果
    if (ordersResults.status === 'fulfilled') {
      const [byTypeResult, byStatusResult, todayResult] = ordersResults.value;
      if (byTypeResult.status === 'fulfilled') byType = byTypeResult.value;
      if (byStatusResult.status === 'fulfilled') {
        const statusRows = byStatusResult.value;
        byStatus = statusRows.map((r: any) => ({ status: r.status, cnt: r.cnt }));
        // 从状态统计中提取加急订单总数（避免单独查询）
        urgentCount = statusRows.reduce((sum: number, r: any) => sum + (Number(r.urgentCnt) || 0), 0);
      }
      if (todayResult.status === 'fulfilled') todayNew = todayResult.value[0]?.cnt ?? 0;
    }

    // 解析其他表结果
    if (approvalsResult.status === 'fulfilled') pendingApprovalsCount = approvalsResult.value[0]?.cnt ?? 0;
    if (podsResult.status === 'fulfilled') pendingPodsCount = podsResult.value[0]?.cnt ?? 0;
    if (trendResult.status === 'fulfilled') {
      const rows = Array.isArray(trendResult.value) ? (Array.isArray((trendResult.value as any)[0]) ? (trendResult.value as any)[0] : trendResult.value) : [];
      dailyTrend = (rows as any[]).map((r: any) => ({ date: r.date, cnt: Number(r.cnt) }));
    }

    return {
      byType,
      byStatus,
      urgentCount,
      todayNew,
      pendingApprovals: pendingApprovalsCount,
      pendingPods: pendingPodsCount,
      dailyTrend,
    };
  }),

  // 运价数据库（五档单价格式，按路线聚合，排除大板订单，含同比/环比）
  freightRates: permissionProcedure("freight_rate.view").input(
    z.object({
      originProvince: z.string().optional(),
      originCity: z.string().optional(),
      destinationProvince: z.string().optional(),
      destinationCity: z.string().optional(),
      cargoSpec: z.string().optional(),
      businessType: z.enum(["outsource", "ltl"]).optional(),
      startDate: z.string().optional(),
      endDate: z.string().optional(),
    }),
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return { items: [], period: '', momPeriod: '', yoyPeriod: '' };

    // 辅助函数：构建基础条件（不含日期）
    const buildBaseConditions = () => {
      const conds: any[] = [
        sql`${orders.actualFreight} IS NOT NULL AND ${orders.actualFreight} != '' AND CAST(${orders.actualFreight} AS DECIMAL(12,4)) > 0`,
        sql`${orders.weight} IS NOT NULL AND CAST(${orders.weight} AS DECIMAL(12,4)) > 0`,
        sql`${orders.businessType} != 'self'`,
        sql`${orders.originCity} IS NOT NULL AND ${orders.originCity} != ''`,
        sql`${orders.destinationCity} IS NOT NULL AND ${orders.destinationCity} != ''`,
        sql`(${orders.isLargeSlab} IS NULL OR ${orders.isLargeSlab} = false)`,
      ];
      if (input.originProvince) conds.push(sql`${orders.originProvince} LIKE ${`%${input.originProvince}%`}`);
      if (input.originCity) conds.push(sql`${orders.originCity} LIKE ${`%${input.originCity}%`}`);
      if (input.destinationProvince) conds.push(sql`${orders.destinationProvince} LIKE ${`%${input.destinationProvince}%`}`);
      if (input.destinationCity) conds.push(sql`${orders.destinationCity} LIKE ${`%${input.destinationCity}%`}`);
      if (input.cargoSpec) conds.push(sql`${orders.cargoSpec} LIKE ${`%${input.cargoSpec}%`}`);
      if (input.businessType) conds.push(eq(orders.businessType, input.businessType));
      return conds;
    };

    // 辅助函数：查询并聚合运价数据
    const queryAndAggregate = async (dateConditions: any[]) => {
      const conds = [...buildBaseConditions(), ...dateConditions];
      const allOrders = await db.select({
        originCity: orders.originCity,
        originProvince: orders.originProvince,
        destinationCity: orders.destinationCity,
        destinationProvince: orders.destinationProvince,
        weight: orders.weight,
        actualFreight: orders.actualFreight,
        ltlUnitPrice: orders.ltlUnitPrice,
        ltlDeliveryFee: orders.ltlDeliveryFee,
        businessType: orders.businessType,
        chargeableWeight: orders.chargeableWeight,
        isLargeSlab: orders.isLargeSlab,
      }).from(orders).where(and(...conds)).orderBy(orders.originProvince, orders.originCity);

      const routeMap = new Map<string, {
        originProvince: string; originCity: string;
        destinationProvince: string; destinationCity: string;
        tier1: number[]; tier2: number[]; tier3: number[]; tier4: number[]; tier5: number[];
        deliveryFees: number[]; orderCount: number;
      }>();

      for (const o of allOrders) {
        if (!o.originCity || !o.destinationCity) continue;
        const key = `${o.originProvince || ''}|${o.originCity}|${o.destinationProvince || ''}|${o.destinationCity}`;
        if (!routeMap.has(key)) {
          routeMap.set(key, {
            originProvince: o.originProvince || '', originCity: o.originCity,
            destinationProvince: o.destinationProvince || '', destinationCity: o.destinationCity,
            tier1: [], tier2: [], tier3: [], tier4: [], tier5: [],
            deliveryFees: [], orderCount: 0,
          });
        }
        const route = routeMap.get(key)!;
        route.orderCount++;
        const actualW = safeParseFloat(o.weight);
        const freight = safeParseFloat(o.actualFreight);
        const chargeableW = o.chargeableWeight ? safeParseFloat(o.chargeableWeight) : 0;
        const isLargeSlabFtl = o.isLargeSlab && o.businessType !== 'ltl' && chargeableW >= 32;
        const w = isLargeSlabFtl ? chargeableW : actualW;
        const unitPrice = o.ltlUnitPrice ? safeParseFloat(o.ltlUnitPrice) : (w > 0 ? freight / w : 0);
        if (o.ltlDeliveryFee) route.deliveryFees.push(safeParseFloat(o.ltlDeliveryFee));
        if (unitPrice > 0) {
          if (w <= 0.5) route.tier1.push(unitPrice);
          else if (w <= 5) route.tier2.push(unitPrice);
          else if (w <= 15) route.tier3.push(unitPrice);
          else if (w <= 30) route.tier4.push(unitPrice);
          else route.tier5.push(unitPrice);
        }
      }

      const avg = (arr: number[]) => arr.length > 0 ? Math.round(arr.reduce((a, b) => a + b, 0) / arr.length * 100) / 100 : null;
      const result = new Map<string, {
        tier1Price: number | null; tier2Price: number | null; tier3Price: number | null;
        tier4Price: number | null; tier5Price: number | null;
        avgDeliveryFee: number | null; orderCount: number;
      }>();
      Array.from(routeMap.entries()).forEach(([key, r]) => {
        result.set(key, {
          tier1Price: avg(r.tier1), tier2Price: avg(r.tier2), tier3Price: avg(r.tier3),
          tier4Price: avg(r.tier4), tier5Price: avg(r.tier5),
          avgDeliveryFee: avg(r.deliveryFees), orderCount: r.orderCount,
        });
      });
      return { routeMap, result };
    };

    // 计算涨跌幅百分比
    const calcChange = (current: number | null, previous: number | null): number | null => {
      if (current === null || previous === null || previous === 0) return null;
      return Math.round((current - previous) / previous * 10000) / 100; // 保留两位小数
    };

    // 确定当前查询的时间段
    let curStart: Date, curEnd: Date;
    if (input.startDate && input.endDate) {
      curStart = new Date(input.startDate);
      curEnd = new Date(input.endDate);
    } else if (input.startDate) {
      curStart = new Date(input.startDate);
      curEnd = new Date();
    } else if (input.endDate) {
      // 默认查最近一个月
      curEnd = new Date(input.endDate);
      curStart = new Date(curEnd.getFullYear(), curEnd.getMonth() - 1, curEnd.getDate());
    } else {
      // 无日期筛选时，默认查当月
      const now = new Date();
      curStart = new Date(now.getFullYear(), now.getMonth(), 1);
      curEnd = new Date(now.getFullYear(), now.getMonth() + 1, 0, 23, 59, 59);
    }

    // 计算环比时间段（上月同期）
    const diffMs = curEnd.getTime() - curStart.getTime();
    const momStart = new Date(curStart.getTime() - diffMs - 86400000); // 上一个同等时间段
    const momEnd = new Date(curStart.getTime() - 86400000);
    // 计算同比时间段（去年同期）
    const yoyStart = new Date(curStart.getFullYear() - 1, curStart.getMonth(), curStart.getDate());
    const yoyEnd = new Date(curEnd.getFullYear() - 1, curEnd.getMonth(), curEnd.getDate());

    // 并行查询三个时间段
    const [currentData, momData, yoyData] = await Promise.all([
      queryAndAggregate([gte(orders.orderDate, curStart), lte(orders.orderDate, curEnd)]),
      queryAndAggregate([gte(orders.orderDate, momStart), lte(orders.orderDate, momEnd)]),
      queryAndAggregate([gte(orders.orderDate, yoyStart), lte(orders.orderDate, yoyEnd)]),
    ]);

    // 合并结果
    const items = Array.from(currentData.routeMap.entries()).map(([key, r]) => {
      const cur = currentData.result.get(key)!;
      const mom = momData.result.get(key);
      const yoy = yoyData.result.get(key);

      return {
        originProvince: r.originProvince, originCity: r.originCity,
        destinationProvince: r.destinationProvince, destinationCity: r.destinationCity,
        tier1Price: cur.tier1Price, tier2Price: cur.tier2Price, tier3Price: cur.tier3Price,
        tier4Price: cur.tier4Price, tier5Price: cur.tier5Price,
        avgDeliveryFee: cur.avgDeliveryFee, orderCount: cur.orderCount,
        // 环比（vs上月/上期）
        mom: {
          tier1: calcChange(cur.tier1Price, mom?.tier1Price ?? null),
          tier2: calcChange(cur.tier2Price, mom?.tier2Price ?? null),
          tier3: calcChange(cur.tier3Price, mom?.tier3Price ?? null),
          tier4: calcChange(cur.tier4Price, mom?.tier4Price ?? null),
          tier5: calcChange(cur.tier5Price, mom?.tier5Price ?? null),
        },
        // 同比（vs去年同期）
        yoy: {
          tier1: calcChange(cur.tier1Price, yoy?.tier1Price ?? null),
          tier2: calcChange(cur.tier2Price, yoy?.tier2Price ?? null),
          tier3: calcChange(cur.tier3Price, yoy?.tier3Price ?? null),
          tier4: calcChange(cur.tier4Price, yoy?.tier4Price ?? null),
          tier5: calcChange(cur.tier5Price, yoy?.tier5Price ?? null),
        },
      };
    });

    const fmtDate = (d: Date) => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    return {
      items,
      period: `${fmtDate(curStart)} ~ ${fmtDate(curEnd)}`,
      momPeriod: `${fmtDate(momStart)} ~ ${fmtDate(momEnd)}`,
      yoyPeriod: `${fmtDate(yoyStart)} ~ ${fmtDate(yoyEnd)}`,
    };
  }),

  // 大板运价专区（只统计零担大板）
  largeSlabRates: permissionProcedure("freight_rate.view").input(
    z.object({
      originProvince: z.string().optional(),
      originCity: z.string().optional(),
      destinationProvince: z.string().optional(),
      destinationCity: z.string().optional(),
      cargoSpec: z.string().optional(),
      startDate: z.string().optional(),
      endDate: z.string().optional(),
    }),
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return { items: [] };

    const conditions: any[] = [
      sql`${orders.isLargeSlab} = true`,
      sql`${orders.businessType} = 'ltl'`,
      sql`${orders.originCity} IS NOT NULL AND ${orders.originCity} != ''`,
      sql`${orders.destinationCity} IS NOT NULL AND ${orders.destinationCity} != ''`,
    ];
    if (input.originProvince) conditions.push(sql`${orders.originProvince} LIKE ${`%${input.originProvince}%`}`);
    if (input.originCity) conditions.push(sql`${orders.originCity} LIKE ${`%${input.originCity}%`}`);
    if (input.destinationProvince) conditions.push(sql`${orders.destinationProvince} LIKE ${`%${input.destinationProvince}%`}`);
    if (input.destinationCity) conditions.push(sql`${orders.destinationCity} LIKE ${`%${input.destinationCity}%`}`);
    if (input.cargoSpec) conditions.push(sql`${orders.cargoSpec} LIKE ${`%${input.cargoSpec}%`}`);
    if (input.startDate) conditions.push(gte(orders.orderDate, new Date(input.startDate)));
    if (input.endDate) conditions.push(lte(orders.orderDate, new Date(input.endDate)));

    const whereClause = and(...conditions);

    const allOrders = await db.select({
      id: orders.id,
      orderNumber: orders.orderNumber,
      businessType: orders.businessType,
      customerName: orders.customerName,
      cargoName: orders.cargoName,
      cargoSpec: orders.cargoSpec,
      originProvince: orders.originProvince,
      originCity: orders.originCity,
      destinationProvince: orders.destinationProvince,
      destinationCity: orders.destinationCity,
      weight: orders.weight,
      chargeableWeight: orders.chargeableWeight,
      packageCount: orders.packageCount,
      actualFreight: orders.actualFreight,
      ltlDeliveryFee: orders.ltlDeliveryFee,
      ltlOtherFee: orders.ltlOtherFee,
      totalCost: orders.totalCost,
      plateNumber: orders.plateNumber,
      orderDate: orders.orderDate,
    }).from(orders).where(whereClause).orderBy(desc(orders.orderDate));

    // 按路线聚合零担大板运价
    const routeMap = new Map<string, {
      originProvince: string;
      originCity: string;
      destinationProvince: string;
      destinationCity: string;
      ltlPerPackagePrices: number[]; // 元/架（总额/架数）
      ltlTotalCosts: number[]; // 总额
      ltlPackageCounts: number[]; // 架数
      orderCount: number;
      orders: typeof allOrders;
    }>();

    for (const o of allOrders) {
      if (!o.originCity || !o.destinationCity) continue;
      const key = `${o.originProvince || ''}|${o.originCity}|${o.destinationProvince || ''}|${o.destinationCity}`;
      if (!routeMap.has(key)) {
        routeMap.set(key, {
          originProvince: o.originProvince || '',
          originCity: o.originCity,
          destinationProvince: o.destinationProvince || '',
          destinationCity: o.destinationCity,
          ltlPerPackagePrices: [], ltlTotalCosts: [], ltlPackageCounts: [],
          orderCount: 0,
          orders: [],
        });
      }
      const route = routeMap.get(key)!;
      route.orderCount++;
      route.orders.push(o);

      const freight = safeParseFloat(o.actualFreight);
      const deliveryFee = safeParseFloat(o.ltlDeliveryFee);
      const otherFee = safeParseFloat(o.ltlOtherFee);
      const total = safeParseFloat(o.totalCost) || (freight + deliveryFee + otherFee);
      const pkgCount = o.packageCount || 0;

      // 只统计零担大板：元/架 = 总额 / 架数
      if (pkgCount > 0 && total > 0) {
        route.ltlPerPackagePrices.push(total / pkgCount);
        route.ltlTotalCosts.push(total);
        route.ltlPackageCounts.push(pkgCount);
      }
    }

    const avg = (arr: number[]) => arr.length > 0 ? Math.round(arr.reduce((a, b) => a + b, 0) / arr.length) : null;

    const items = Array.from(routeMap.values())
      .filter(r => r.ltlPerPackagePrices.length > 0)
      .map(r => ({
        originProvince: r.originProvince,
        originCity: r.originCity,
        destinationProvince: r.destinationProvince,
        destinationCity: r.destinationCity,
        // 零担大板统计
        ltlAvgPerPackage: avg(r.ltlPerPackagePrices), // 平均元/架
        ltlAvgTotal: avg(r.ltlTotalCosts), // 平均总额
        ltlAvgPackageCount: avg(r.ltlPackageCounts), // 平均架数
        ltlCount: r.ltlPerPackagePrices.length,
        orderCount: r.orderCount,
        recentOrders: r.orders.slice(0, 10), // 最近10条明细
      }));

    return { items };
  }),

  // 大板整车运价专区（独立于普通运价30吨以上档）
  largeSlabFtlRates: permissionProcedure("freight_rate.view").input(
    z.object({
      originProvince: z.string().optional(),
      originCity: z.string().optional(),
      destinationProvince: z.string().optional(),
      destinationCity: z.string().optional(),
      cargoSpec: z.string().optional(),
      startDate: z.string().optional(),
      endDate: z.string().optional(),
    }),
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return { items: [] };

    const conditions: any[] = [
      sql`${orders.isLargeSlab} = true`,
      sql`${orders.businessType} != 'ltl'`,
      sql`${orders.actualFreight} IS NOT NULL AND ${orders.actualFreight} != '' AND CAST(${orders.actualFreight} AS DECIMAL(12,4)) > 0`,
      sql`${orders.originCity} IS NOT NULL AND ${orders.originCity} != ''`,
      sql`${orders.destinationCity} IS NOT NULL AND ${orders.destinationCity} != ''`,
      sql`(
        (${orders.chargeableWeight} IS NOT NULL AND CAST(${orders.chargeableWeight} AS DECIMAL(12,4)) > 0)
        OR (${orders.weight} IS NOT NULL AND CAST(${orders.weight} AS DECIMAL(12,4)) > 0)
      )`,
    ];
    if (input.originProvince) conditions.push(sql`${orders.originProvince} LIKE ${`%${input.originProvince}%`}`);
    if (input.originCity) conditions.push(sql`${orders.originCity} LIKE ${`%${input.originCity}%`}`);
    if (input.destinationProvince) conditions.push(sql`${orders.destinationProvince} LIKE ${`%${input.destinationProvince}%`}`);
    if (input.destinationCity) conditions.push(sql`${orders.destinationCity} LIKE ${`%${input.destinationCity}%`}`);
    if (input.cargoSpec) conditions.push(sql`${orders.cargoSpec} LIKE ${`%${input.cargoSpec}%`}`);
    if (input.startDate) conditions.push(gte(orders.orderDate, new Date(input.startDate)));
    if (input.endDate) conditions.push(lte(orders.orderDate, new Date(input.endDate)));

    const allOrders = await db.select({
      id: orders.id,
      orderNumber: orders.orderNumber,
      businessType: orders.businessType,
      customerName: orders.customerName,
      cargoName: orders.cargoName,
      cargoSpec: orders.cargoSpec,
      originProvince: orders.originProvince,
      originCity: orders.originCity,
      destinationProvince: orders.destinationProvince,
      destinationCity: orders.destinationCity,
      weight: orders.weight,
      chargeableWeight: orders.chargeableWeight,
      actualFreight: orders.actualFreight,
      totalCost: orders.totalCost,
      plateNumber: orders.plateNumber,
      orderDate: orders.orderDate,
    }).from(orders).where(and(...conditions)).orderBy(desc(orders.orderDate));

    const routeMap = new Map<string, {
      originProvince: string;
      originCity: string;
      destinationProvince: string;
      destinationCity: string;
      unitPrices: number[];
      freightTotals: number[];
      chargeableWeights: number[];
      cargoSpecs: Set<string>;
      orderCount: number;
      orders: typeof allOrders;
    }>();

    for (const o of allOrders) {
      if (!o.originCity || !o.destinationCity) continue;
      const key = `${o.originProvince || ''}|${o.originCity}|${o.destinationProvince || ''}|${o.destinationCity}`;
      if (!routeMap.has(key)) {
        routeMap.set(key, {
          originProvince: o.originProvince || '',
          originCity: o.originCity,
          destinationProvince: o.destinationProvince || '',
          destinationCity: o.destinationCity,
          unitPrices: [],
          freightTotals: [],
          chargeableWeights: [],
          cargoSpecs: new Set<string>(),
          orderCount: 0,
          orders: [],
        });
      }

      const route = routeMap.get(key)!;
      route.orderCount++;
      route.orders.push(o);
      if (o.cargoSpec) route.cargoSpecs.add(o.cargoSpec);

      const freight = safeParseFloat(o.actualFreight);
      const effectiveWeight = safeParseFloat(o.chargeableWeight) || safeParseFloat(o.weight);
      if (freight > 0 && effectiveWeight > 0) {
        route.unitPrices.push(freight / effectiveWeight);
        route.freightTotals.push(freight);
        route.chargeableWeights.push(effectiveWeight);
      }
    }

    const avg = (arr: number[]) => arr.length > 0 ? Math.round(arr.reduce((a, b) => a + b, 0) / arr.length * 100) / 100 : null;

    const items = Array.from(routeMap.values())
      .filter((r) => r.unitPrices.length > 0)
      .map((r) => ({
        originProvince: r.originProvince,
        originCity: r.originCity,
        destinationProvince: r.destinationProvince,
        destinationCity: r.destinationCity,
        slabFtlAvgUnitPrice: avg(r.unitPrices),
        slabFtlAvgFreight: avg(r.freightTotals),
        slabFtlAvgChargeableWeight: avg(r.chargeableWeights),
