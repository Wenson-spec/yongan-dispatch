  // 运价趋势（按月聚合，支持多路线对比）
  freightRateTrend: permissionProcedure("freight_rate.view").input(
    z.object({
      routes: z.array(z.object({
        originCity: z.string(),
        destinationCity: z.string(),
      })).min(1).max(5),
      tier: z.enum(["tier1", "tier2", "tier3", "tier4", "tier5"]).default("tier5"),
      months: z.number().min(3).max(24).default(6), // 最近N个月
    }),
  ).query(async ({ input }) => {
    const db = await getDb();
    if (!db) return { series: [] };

    // 计算起始日期
    const now = new Date();
    const startDate = new Date(now.getFullYear(), now.getMonth() - input.months + 1, 1);

    // 重量范围映射
    const tierRanges: Record<string, { min: number; max: number; label: string }> = {
      tier1: { min: 0, max: 0.5, label: '500kg以下' },
      tier2: { min: 0.5, max: 5, label: '0.5-5吨' },
      tier3: { min: 5, max: 15, label: '5-15吨' },
      tier4: { min: 15, max: 30, label: '15-30吨' },
      tier5: { min: 30, max: 999999, label: '30吨以上' },
    };
    const range = tierRanges[input.tier];

    const series: Array<{
      route: string;
      originCity: string;
      destinationCity: string;
      data: Array<{ month: string; avgPrice: number | null; orderCount: number }>;
    }> = [];

    for (const route of input.routes) {
      const conditions: any[] = [
        sql`${orders.actualFreight} IS NOT NULL AND CAST(${orders.actualFreight} AS DECIMAL(12,4)) > 0`,
        sql`${orders.weight} IS NOT NULL AND CAST(${orders.weight} AS DECIMAL(12,4)) > 0`,
        sql`${orders.businessType} != 'self'`,
        sql`${orders.originCity} = ${route.originCity}`,
        sql`${orders.destinationCity} = ${route.destinationCity}`,
        sql`(${orders.isLargeSlab} IS NULL OR ${orders.isLargeSlab} = false)`,
        gte(orders.orderDate, startDate),
      ];

      const routeOrders = await db.select({
        weight: orders.weight,
        actualFreight: orders.actualFreight,
        ltlUnitPrice: orders.ltlUnitPrice,
        chargeableWeight: orders.chargeableWeight,
        isLargeSlab: orders.isLargeSlab,
        businessType: orders.businessType,
        orderDate: orders.orderDate,
      }).from(orders).where(and(...conditions));

      // 按月聚合
      const monthMap = new Map<string, number[]>();
      // 预填所有月份
      for (let i = 0; i < input.months; i++) {
        const d = new Date(now.getFullYear(), now.getMonth() - input.months + 1 + i, 1);
        const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
        monthMap.set(key, []);
      }

      for (const o of routeOrders) {
        if (!o.orderDate) continue;
        const d = new Date(o.orderDate);
        const monthKey = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
        if (!monthMap.has(monthKey)) continue;

        const actualW = safeParseFloat(o.weight);
        const chargeableW = o.chargeableWeight ? safeParseFloat(o.chargeableWeight) : 0;
        const isLargeSlabFtl = o.isLargeSlab && o.businessType !== 'ltl' && chargeableW >= 32;
        const w = isLargeSlabFtl ? chargeableW : actualW;
        const freight = safeParseFloat(o.actualFreight);
        const unitPrice = o.ltlUnitPrice ? safeParseFloat(o.ltlUnitPrice) : (w > 0 ? freight / w : 0);

        // 按重量档位筛选
        if (w > range.min && w <= range.max && unitPrice > 0) {
          monthMap.get(monthKey)!.push(unitPrice);
        }
        // 大板整车特殊处理：始终归入tier5
        if (isLargeSlabFtl && input.tier === 'tier5' && unitPrice > 0) {
          if (!(w > range.min && w <= range.max)) {
            monthMap.get(monthKey)!.push(unitPrice);
          }
        }
      }

      const data = Array.from(monthMap.entries())
        .sort(([a], [b]) => a.localeCompare(b))
        .map(([month, prices]) => ({
          month,
          avgPrice: prices.length > 0 ? Math.round(prices.reduce((a, b) => a + b, 0) / prices.length) : null,
          orderCount: prices.length,
        }));

      series.push({
        route: `${route.originCity} → ${route.destinationCity}`,
        originCity: route.originCity,
        destinationCity: route.destinationCity,
        data,
      });
    }

    return { series, tier: tierRanges[input.tier].label };
  }),

