  // 调度效率分析 + 发货时效监控
  dispatchEfficiency: protectedProcedure.query(async () => {
    const db = await getDb();
    if (!db) return null;

    const now = new Date();
    const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const yesterdayStart = new Date(todayStart.getTime() - 86400000);
    const weekStart = new Date(todayStart.getTime() - todayStart.getDay() * 86400000);
    const lastWeekStart = new Date(weekStart.getTime() - 7 * 86400000);

    const stationStatuses: Record<string, string[]> = {
      "录单台": ["pending_assign"],
      "指挥台": ["pending_price", "pending_approval"],
      "找车台": ["pending_vehicle"],
      "派车台": ["pending_dispatch"],
      "询价台": ["pending_inquiry", "inquiry_confirmed"],
    };

    // 1. 各工位平均处理时间
    let stationAvgHours: Record<string, number> = {};
    try {
      const thirtyDaysAgo = new Date(now.getTime() - 30 * 86400000);
      const thirtyDaysAgoStr = thirtyDaysAgo.toISOString().slice(0, 19).replace('T', ' ');
      const [statusChanges] = await db.execute(sql.raw(`
        SELECT targetId as orderId, description, createdAt
        FROM operation_logs 
        WHERE action = 'status_change' AND targetType = 'order' AND createdAt >= '${thirtyDaysAgoStr}'
        ORDER BY targetId, createdAt
      `)) as any;

      if (statusChanges && statusChanges.length > 0) {
        const orderChanges = new Map<string, Array<{ status: string; time: Date }>>();
        for (const row of statusChanges) {
          const orderId = String(row.orderId);
          if (!orderChanges.has(orderId)) orderChanges.set(orderId, []);
          const desc = String(row.description || '');
          const statusMatch = desc.match(/→\s*(\S+)/) || desc.match(/变更为[\s:]*([\w_]+)/);
          if (statusMatch) {
            orderChanges.get(orderId)!.push({ status: statusMatch[1], time: new Date(row.createdAt) });
          }
        }
        const stationDurations: Record<string, number[]> = {};
        for (const [, changes] of Array.from(orderChanges)) {
          for (let i = 0; i < changes.length - 1; i++) {
            const currentStatus = changes[i].status;
            const durationHours = (changes[i + 1].time.getTime() - changes[i].time.getTime()) / 3600000;
            if (durationHours > 0 && durationHours < 720) {
              for (const [station, statuses] of Object.entries(stationStatuses)) {
                if (statuses.includes(currentStatus)) {
                  if (!stationDurations[station]) stationDurations[station] = [];
                  stationDurations[station].push(durationHours);
                }
              }
            }
          }
        }
        for (const [station, durations] of Object.entries(stationDurations)) {
          if (durations.length > 0) {
            stationAvgHours[station] = Math.round(durations.reduce((a, b) => a + b, 0) / durations.length * 10) / 10;
          }
        }
      }
    } catch (e) { console.error("Station avg hours error:", e); }

    // 2. 各工位当前积压
    let stationBacklog: Array<{ station: string; total: number; over24h: number; over48h: number; maxWaitHours: number }> = [];
    try {
      for (const [station, statuses] of Object.entries(stationStatuses)) {
        const statusList = statuses.map(s => `'${s}'`).join(',');
        const [result] = await db.execute(sql.raw(`
          SELECT COUNT(*) as total,
            SUM(CASE WHEN TIMESTAMPDIFF(HOUR, createdAt, NOW()) > 24 THEN 1 ELSE 0 END) as over24h,
            SUM(CASE WHEN TIMESTAMPDIFF(HOUR, createdAt, NOW()) > 48 THEN 1 ELSE 0 END) as over48h,
            MAX(TIMESTAMPDIFF(HOUR, createdAt, NOW())) as maxWaitHours
          FROM orders WHERE status IN (${statusList}) AND status != 'cancelled'
        `)) as any;
        if (result && result[0]) {
          stationBacklog.push({
            station, total: Number(result[0].total) || 0,
            over24h: Number(result[0].over24h) || 0, over48h: Number(result[0].over48h) || 0,
            maxWaitHours: Math.round(Number(result[0].maxWaitHours) || 0),
          });
        }
      }
    } catch (e) { console.error("Station backlog error:", e); }

    // 3. 今日vs昨日 / 本周vs上周
    let todayProcessed = 0, yesterdayProcessed = 0, thisWeekProcessed = 0, lastWeekProcessed = 0;
    try {
      const todayStr = todayStart.toISOString().slice(0, 19).replace('T', ' ');
      const yesterdayStr = yesterdayStart.toISOString().slice(0, 19).replace('T', ' ');
      const weekStartStr = weekStart.toISOString().slice(0, 19).replace('T', ' ');
      const lastWeekStartStr = lastWeekStart.toISOString().slice(0, 19).replace('T', ' ');
      const [t] = await db.execute(sql.raw(`SELECT COUNT(*) as cnt FROM operation_logs WHERE action='status_change' AND targetType='order' AND createdAt>='${todayStr}'`)) as any;
      todayProcessed = Number(t?.[0]?.cnt) || 0;
      const [y] = await db.execute(sql.raw(`SELECT COUNT(*) as cnt FROM operation_logs WHERE action='status_change' AND targetType='order' AND createdAt>='${yesterdayStr}' AND createdAt<'${todayStr}'`)) as any;
      yesterdayProcessed = Number(y?.[0]?.cnt) || 0;
      const [tw] = await db.execute(sql.raw(`SELECT COUNT(*) as cnt FROM operation_logs WHERE action='status_change' AND targetType='order' AND createdAt>='${weekStartStr}'`)) as any;
      thisWeekProcessed = Number(tw?.[0]?.cnt) || 0;
      const [lw] = await db.execute(sql.raw(`SELECT COUNT(*) as cnt FROM operation_logs WHERE action='status_change' AND targetType='order' AND createdAt>='${lastWeekStartStr}' AND createdAt<'${weekStartStr}'`)) as any;
      lastWeekProcessed = Number(lw?.[0]?.cnt) || 0;
    } catch (e) { console.error("Processed count error:", e); }

    return {
      stationAvgHours, stationBacklog,
      comparison: {
        todayProcessed, yesterdayProcessed,
        todayChange: yesterdayProcessed > 0 ? Math.round((todayProcessed - yesterdayProcessed) / yesterdayProcessed * 100) : null,
        thisWeekProcessed, lastWeekProcessed,
        weekChange: lastWeekProcessed > 0 ? Math.round((thisWeekProcessed - lastWeekProcessed) / lastWeekProcessed * 100) : null,
      },
    };
  }),

  // 发货时效监控（甲方要求：接单后24h必须发货，最迟48h）
  shippingTimeliness: protectedProcedure.query(async () => {
    const db = await getDb();
    if (!db) return null;

    const shippedStatuses = "'shipped','dispatched','in_transit','delivered','signed','settled'";
    const unshippedStatuses = "'pending_assign','pending_dispatch','pending_price','priced','pending_vehicle','pending_approval','pending_inquiry','inquiry_confirmed'";

    // 1. 已发货时效分布（最近30天）
    let within24h = 0, between24and48h = 0, over48h = 0;
    try {
      const thirtyDaysAgo = new Date(Date.now() - 30 * 86400000).toISOString().slice(0, 19).replace('T', ' ');
      const [result] = await db.execute(sql.raw(`
        SELECT 
          SUM(CASE WHEN TIMESTAMPDIFF(HOUR, createdAt, COALESCE(dispatchDate, updatedAt)) <= 24 THEN 1 ELSE 0 END) as within24h,
          SUM(CASE WHEN TIMESTAMPDIFF(HOUR, createdAt, COALESCE(dispatchDate, updatedAt)) > 24 AND TIMESTAMPDIFF(HOUR, createdAt, COALESCE(dispatchDate, updatedAt)) <= 48 THEN 1 ELSE 0 END) as between24and48h,
          SUM(CASE WHEN TIMESTAMPDIFF(HOUR, createdAt, COALESCE(dispatchDate, updatedAt)) > 48 THEN 1 ELSE 0 END) as over48h
        FROM orders WHERE status IN (${shippedStatuses}) AND createdAt >= '${thirtyDaysAgo}'
      `)) as any;
      if (result && result[0]) {
        within24h = Number(result[0].within24h) || 0;
        between24and48h = Number(result[0].between24and48h) || 0;
        over48h = Number(result[0].over48h) || 0;
      }
    } catch (e) { console.error("Timeliness distribution error:", e); }

    // 2. 当前未发货订单时效状态 + 即将超时预警
    let urgentOrders: Array<{
      id: number; orderNumber: string; systemCode: string;
      customerName: string | null; originCity: string | null; destinationCity: string | null;
      mergedPlanNumber: string | null; parentId: number | null;
      status: string; waitHours: number; remainHours: number; isUrgent: boolean; createdAt: string;
    }> = [];
    let unshippedWithin24h = 0, unshippedBetween24and48h = 0, unshippedOver48h = 0;
    try {
      const [unshippedResult] = await db.execute(sql.raw(`
        SELECT id, orderNumber, systemCode, customerName, originCity, destinationCity, mergedPlanNumber, parentId, status,
          isUrgent, createdAt, TIMESTAMPDIFF(HOUR, createdAt, NOW()) as waitHours,
          48 - TIMESTAMPDIFF(HOUR, createdAt, NOW()) as remainHours
        FROM orders WHERE status IN (${unshippedStatuses}) AND status != 'cancelled'
        ORDER BY createdAt ASC
      `)) as any;
      if (unshippedResult) {
        for (const row of unshippedResult) {
          const waitH = Number(row.waitHours) || 0;
          const remainH = Number(row.remainHours) || 0;
          if (waitH <= 24) unshippedWithin24h++;
          else if (waitH <= 48) unshippedBetween24and48h++;
          else unshippedOver48h++;
          if (remainH < 12) {
            urgentOrders.push({
              id: row.id, orderNumber: row.orderNumber, systemCode: row.systemCode,
              customerName: row.customerName, originCity: row.originCity, destinationCity: row.destinationCity,
              mergedPlanNumber: row.mergedPlanNumber ? String(row.mergedPlanNumber) : null,
              parentId: row.parentId === null || row.parentId === undefined ? null : Number(row.parentId),
              status: row.status, waitHours: waitH, remainHours: remainH,
              isUrgent: Boolean(row.isUrgent), createdAt: String(row.createdAt),
            });
          }
        }
      }
    } catch (e) { console.error("Unshipped orders error:", e); }

    const totalShipped = within24h + between24and48h + over48h;
    return {
      shipped: { within24h, between24and48h, over48h, total: totalShipped },
      unshipped: { within24h: unshippedWithin24h, between24and48h: unshippedBetween24and48h, over48h: unshippedOver48h, total: unshippedWithin24h + unshippedBetween24and48h + unshippedOver48h },
      urgentOrders: urgentOrders.slice(0, 20),
      onTimeRate24h: totalShipped > 0 ? Math.round(within24h / totalShipped * 100) : 0,
      onTimeRate48h: totalShipped > 0 ? Math.round((within24h + between24and48h) / totalShipped * 100) : 0,
    };
  }),

  // ============================================================
  // 调度员绩效排名
  // ============================================================
  // 调度员工作量看板（支持年月筛选）
  dispatcherWorkload: protectedProcedure.input(
