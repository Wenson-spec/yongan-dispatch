      const dIds = dispatcherRows.map(d => d.id);

      // 2. 当前积压（未完成的订单，不受月份筛选影响）
      const pendingStatuses = ["pending_price", "pending_approval", "pending_vehicle", "pending_dispatch", "pending_inquiry", "inquiry_confirmed"] as const;
      const backlogRows = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        backlogCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dIds),
          isNotNull(orders.assignedDispatcherId),
          inArray(orders.status, pendingStatuses),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 3. 本月完成量（状态为dispatched及之后，且在选定月份内有更新）
      const completedStatuses = ["dispatched", "in_transit", "delivered", "signed", "settled"] as const;
      const completedRows = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        completedCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dIds),
          isNotNull(orders.assignedDispatcherId),
          inArray(orders.status, completedStatuses),
          gte(orders.updatedAt, monthStart),
          lte(orders.updatedAt, monthEnd),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 4. 本月新接单量
      const newOrderRows = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        newCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dIds),
          isNotNull(orders.assignedDispatcherId),
          gte(orders.autoAssignedAt, monthStart),
          lte(orders.autoAssignedAt, monthEnd),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 5. 本月运输中（当前在运输中的订单数）
      const inTransitRows = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        transitCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dIds),
          isNotNull(orders.assignedDispatcherId),
          inArray(orders.status, ["dispatched", "in_transit", "shipped"]),
        )
      ).groupBy(orders.assignedDispatcherId);

      const backlogMap = new Map(backlogRows.map(r => [r.dispatcherId, Number(r.backlogCount)]));
      const completedMap = new Map(completedRows.map(r => [r.dispatcherId, Number(r.completedCount)]));
      const newOrderMap = new Map(newOrderRows.map(r => [r.dispatcherId, Number(r.newCount)]));
      const inTransitMap = new Map(inTransitRows.map(r => [r.dispatcherId, Number(r.transitCount)]));

      const dispatchers = dispatcherRows.map(d => {
        const roleLabel = d.role === "ltl_dispatcher" ? "零担" :
          d.role === "outsource_dispatcher" ? "外请" :
          d.role === "fleet_dispatcher" ? "车队" : "调度";
        return {
          id: d.id,
          name: d.name || `调度员${d.id}`,
          role: d.role,
          roleLabel,
          backlog: backlogMap.get(d.id) || 0,
          monthCompleted: completedMap.get(d.id) || 0,
          monthNewOrders: newOrderMap.get(d.id) || 0,
          inTransit: inTransitMap.get(d.id) || 0,
        };
      });

      // 按积压数降序排列
      dispatchers.sort((a, b) => b.backlog - a.backlog || b.monthCompleted - a.monthCompleted);

      return { dispatchers };
    } catch (e) {
      console.error("Dispatcher workload error:", e);
      return { dispatchers: [] };
    }
  }),

  dispatcherPerformance: protectedProcedure.input(
    z.object({
      period: z.enum(["today", "week", "month"]).default("today"),
    }).optional(),
  ).query(async ({ ctx, input }) => {
    const db = await getDb();
    if (!db) return { rankings: [], summary: { totalDispatchers: 0, totalProcessed: 0, avgResponseHours: 0 } };

    const period = input?.period ?? "today";
    const now = new Date();
    let periodStart: Date;

    if (period === "today") {
      periodStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    } else if (period === "week") {
      const dayOfWeek = now.getDay();
      const mondayOffset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;
      periodStart = new Date(now.getFullYear(), now.getMonth(), now.getDate() + mondayOffset);
    } else {
      periodStart = new Date(now.getFullYear(), now.getMonth(), 1);
    }

    try {
      // 1. 获取所有调度员角色的用户
      const dispatchers = await db.select({
        id: users.id,
        name: users.name,
        role: users.role,
        isActive: users.isActive,
      }).from(users).where(
        and(
          or(
            eq(users.role, "ltl_dispatcher"),
            eq(users.role, "outsource_dispatcher"),
            eq(users.role, "fleet_dispatcher"),
          ),
          eq(users.isActive, true),
        )
      );

      if (dispatchers.length === 0) {
        return { rankings: [], summary: { totalDispatchers: 0, totalProcessed: 0, avgResponseHours: 0 } };
      }

      const dispatcherIds = dispatchers.map(d => d.id);
      const dispatcherMap = new Map(dispatchers.map(d => [d.id, d]));

      // 2. 统计每个调度员在该时间段内处理的订单数
      //    处理 = 该调度员被分配的订单中，在该时间段内有状态变更的
      const processedCounts = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        processedCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dispatcherIds),
          isNotNull(orders.assignedDispatcherId),
          gte(orders.updatedAt, periodStart),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 3. 统计每个调度员的已完成订单数（状态为dispatched及之后的）
      const completedStatuses = ["dispatched", "in_transit", "delivered", "signed", "settled"] as const;
      const completedCounts = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        completedCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dispatcherIds),
          isNotNull(orders.assignedDispatcherId),
          inArray(orders.status, completedStatuses),
          gte(orders.updatedAt, periodStart),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 4. 统计每个调度员的平均响应时间
      //    响应时间 = 从autoAssignedAt（分配时间）到dispatchDate（派车时间）的差值
      const responseTimeRows = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        avgResponseMs: sql<number>`AVG(TIMESTAMPDIFF(SECOND, ${orders.autoAssignedAt}, ${orders.dispatchDate}))`,
        minResponseMs: sql<number>`MIN(TIMESTAMPDIFF(SECOND, ${orders.autoAssignedAt}, ${orders.dispatchDate}))`,
        maxResponseMs: sql<number>`MAX(TIMESTAMPDIFF(SECOND, ${orders.autoAssignedAt}, ${orders.dispatchDate}))`,
        responseCount: sql<number>`COUNT(${orders.dispatchDate})`,
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dispatcherIds),
          isNotNull(orders.assignedDispatcherId),
          isNotNull(orders.autoAssignedAt),
          isNotNull(orders.dispatchDate),
          gte(orders.dispatchDate, periodStart),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 5. 统计当前积压（分配给该调度员但尚未派车的订单）
      const pendingStatuses = ["pending_price", "pending_approval", "pending_vehicle", "pending_dispatch"] as const;
      const backlogCounts = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        backlogCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dispatcherIds),
          isNotNull(orders.assignedDispatcherId),
          inArray(orders.status, pendingStatuses),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 6. 统计今日新分配的订单数
      const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const todayAssigned = await db.select({
        dispatcherId: orders.assignedDispatcherId,
        todayCount: count(),
      }).from(orders).where(
        and(
          inArray(orders.assignedDispatcherId, dispatcherIds),
          isNotNull(orders.assignedDispatcherId),
          gte(orders.autoAssignedAt, todayStart),
        )
      ).groupBy(orders.assignedDispatcherId);

      // 构建排名数据
      const processedMap = new Map(processedCounts.map(r => [r.dispatcherId, Number(r.processedCount)]));
      const completedMap = new Map(completedCounts.map(r => [r.dispatcherId, Number(r.completedCount)]));
      const responseMap = new Map(responseTimeRows.map(r => [r.dispatcherId, {
        avgSeconds: Number(r.avgResponseMs) || 0,
        minSeconds: Number(r.minResponseMs) || 0,
        maxSeconds: Number(r.maxResponseMs) || 0,
        count: Number(r.responseCount) || 0,
      }]));
      const backlogMap = new Map(backlogCounts.map(r => [r.dispatcherId, Number(r.backlogCount)]));
      const todayMap = new Map(todayAssigned.map(r => [r.dispatcherId, Number(r.todayCount)]));

      const rankings = dispatchers.map(d => {
        const processed = processedMap.get(d.id) || 0;
        const completed = completedMap.get(d.id) || 0;
        const response = responseMap.get(d.id);
        const backlog = backlogMap.get(d.id) || 0;
        const todayNew = todayMap.get(d.id) || 0;
        const avgResponseHours = response ? Math.round(response.avgSeconds / 3600 * 10) / 10 : null;
        const completionRate = processed > 0 ? Math.round(completed / processed * 100) : 0;

        // 综合评分：处理量权重40% + 响应速度权重30% + 完成率权重30%
        // 响应速度分数：<2h=100, 2-6h=80, 6-12h=60, 12-24h=40, >24h=20
        let speedScore = 50; // 默认分数（无数据时）
        if (avgResponseHours !== null) {
          if (avgResponseHours < 2) speedScore = 100;
          else if (avgResponseHours < 6) speedScore = 80;
          else if (avgResponseHours < 12) speedScore = 60;
          else if (avgResponseHours < 24) speedScore = 40;
          else speedScore = 20;
        }

        const roleLabel = d.role === "ltl_dispatcher" ? "零担" :
          d.role === "outsource_dispatcher" ? "外请" :
          d.role === "fleet_dispatcher" ? "车队" : "调度";

        return {
          id: d.id,
          name: d.name || `调度员${d.id}`,
          role: d.role,
          roleLabel,
          processed,
          completed,
          completionRate,
          avgResponseHours,
          minResponseHours: response ? Math.round(response.minSeconds / 3600 * 10) / 10 : null,
          maxResponseHours: response ? Math.round(response.maxSeconds / 3600 * 10) / 10 : null,
          backlog,
          todayNew,
          speedScore,
          // 综合评分
          totalScore: Math.round(processed * 0.4 + speedScore * 0.3 + completionRate * 0.3),
        };
      });

      // 按综合评分降序排名
      rankings.sort((a, b) => b.totalScore - a.totalScore || b.processed - a.processed);

      // 汇总
      const totalProcessed = rankings.reduce((sum, r) => sum + r.processed, 0);
      const avgResponseAll = rankings.filter(r => r.avgResponseHours !== null);
      const avgResponseHours = avgResponseAll.length > 0
        ? Math.round(avgResponseAll.reduce((sum, r) => sum + (r.avgResponseHours || 0), 0) / avgResponseAll.length * 10) / 10
        : 0;

      return {
        rankings,
        summary: {
          totalDispatchers: dispatchers.length,
          totalProcessed,
          avgResponseHours,
        },
      };
    } catch (e) {
      console.error("Dispatcher performance error:", e);
      return { rankings: [], summary: { totalDispatchers: 0, totalProcessed: 0, avgResponseHours: 0 } };
    }
  }),
});
